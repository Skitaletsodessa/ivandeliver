---
interface Props {
	title: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Deliverability Monitoring Hub" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<nav class="global-nav">
			<div class="nav-container">
				<div class="nav-brand">
					<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="brand-icon"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
					<span class="brand-text">Deliverability Hub</span>
				</div>
				<div class="nav-links">
					<a href="/domains" class={currentPath.includes('/domains') || currentPath === '/' ? 'active' : ''}>
						<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
						DNS Monitor
					</a>
					<a href="/postmaster" class={currentPath.includes('/postmaster') ? 'active' : ''}>
						<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.21 15.89A10 10 0 1 1 8 2.83"></path><path d="M22 12A10 10 0 0 0 12 2v10z"></path></svg>
						Postmaster
					</a>
				</div>
			</div>
		</nav>
		<slot />
	</body>
</html>

<style is:global>
	:root {
		--bg-color: #f7fafc;
		--nav-bg: #1a202c;
		--nav-text: #a0aec0;
		--nav-active: #ffffff;
		--accent: #3182ce;
	}
	
	html {
		font-family: system-ui, -apple-system, sans-serif;
		background: var(--bg-color);
		color: #1a202c;
	}
	
	body {
		margin: 0;
		padding: 0;
		min-height: 100vh;
	}

	/* Глобальная навигация */
	.global-nav {
		background-color: var(--nav-bg);
		border-bottom: 1px solid #2d3748;
		padding: 0 2rem;
		position: sticky;
		top: 0;
		z-index: 100;
	}

	.nav-container {
		max-width: 1400px;
		margin: 0 auto;
		display: flex;
		justify-content: space-between;
		align-items: center;
		height: 64px;
	}

	.nav-brand {
		display: flex;
		align-items: center;
		gap: 12px;
		color: #fff;
	}

	.brand-icon {
		color: var(--accent);
	}

	.brand-text {
		font-size: 1.25rem;
		font-weight: 800;
		letter-spacing: -0.5px;
	}

	.nav-links {
		display: flex;
		gap: 8px;
	}

	.nav-links a {
		display: flex;
		align-items: center;
		gap: 8px;
		color: var(--nav-text);
		text-decoration: none;
		font-weight: 600;
		font-size: 0.95rem;
		padding: 8px 16px;
		border-radius: 8px;
		transition: all 0.2s ease;
	}

	.nav-links a:hover {
		color: var(--nav-active);
		background-color: rgba(255, 255, 255, 0.05);
	}

	.nav-links a.active {
		color: var(--nav-active);
		background-color: rgba(49, 130, 206, 0.2);
		border: 1px solid rgba(49, 130, 206, 0.5);
	}

	/* Фиксы для цвета заголовков, чтобы они не сливались с фоном */
	.title-area h1 { color: #1a202c !important; }
	.title-area p { color: #4a5568 !important; }
</style>