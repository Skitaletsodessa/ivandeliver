---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Postmaster Monitor | ivandeliver.email">
  <main class="domains-wrapper">
    <div class="content-header">
      <div class="title-area">
        <h1>Google Postmaster Monitor</h1>
        <p>Domain & IP Reputation, Spam Rates, and Delivery Auth Metrics.</p>
      </div>
      <div class="header-actions">
        <button class="btn-primary" onclick="window.syncPostmaster(this)">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.5 2v6h-6M21.34 15.57a10 10 0 1 1-.92-10.44l5.08 5.08"/></svg>
          Sync with Google
        </button>
      </div>
    </div>

    <div class="summary-grid" id="pm-summary"></div>

    <div class="table-actions-bar">
      <input type="text" id="domainSearch" placeholder="Filter by domain..." class="input-field" />
    </div>

    <div class="card table-outer-container">
      <div class="table-scroll">
        <table>
          <thead>
            <tr>
              <th class="sortable" onclick="window.sortBy('domain')">Domain</th>
              <th class="center sortable" onclick="window.sortBy('spam_rate')">Spam Rate</th>
              <th class="center sortable" onclick="window.sortBy('domain_rep')">Domain Rep</th>
              <th class="center">IP Rep (Detailed)</th>
              <th class="center">Delivery Errors</th>
              <th class="center sortable" onclick="window.sortBy('spf_success_rate')">SPF Auth</th>
              <th class="center sortable" onclick="window.sortBy('dkim_success_rate')">DKIM Auth</th>
              <th class="center sortable" onclick="window.sortBy('dmarc_success_rate')">DMARC Auth</th>
              <th class="sortable" onclick="window.sortBy('last_updated')">Last Data</th>
            </tr>
          </thead>
          <tbody id="tableBody">
            <tr><td colspan="9" class="center" style="padding: 40px;">Loading Postmaster data...</td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <dialog id="detailsModal" class="modal">
      <div class="modal-content">
        <div class="modal-header">
          <h2 id="modalTitle">Domain Details</h2>
          <button onclick="document.getElementById('detailsModal').close()" class="close-btn">&times;</button>
        </div>
        <div class="modal-body" id="modalBody">
        </div>
      </div>
    </dialog>

  </main>
</Layout>

<script>
  const API_URL = 'https://postmaster-sync.skitalets-od.workers.dev/api/domains';
  const SYNC_URL = 'https://postmaster-sync.skitalets-od.workers.dev/api/sync-now';
  const DISCOVER_URL = 'https://postmaster-sync.skitalets-od.workers.dev/api/discover';
  
  let rawData = [];
  let sortCol = 'domain';
  let sortAsc = true;

  async function init() {
    try {
      const response = await fetch(API_URL);
      rawData = await response.json();
      applyFiltersAndRender();
      document.getElementById('domainSearch')?.addEventListener('input', applyFiltersAndRender);
    } catch (err) {
      console.error("Fetch Error:", err);
      document.getElementById('tableBody').innerHTML = `<tr><td colspan="9" class="center error-text">Error loading data</td></tr>`;
    }
  }

  function applyFiltersAndRender() {
    const searchTerm = (document.getElementById('domainSearch') as HTMLInputElement)?.value.toLowerCase() || '';
    let filtered = rawData.filter(d => d.domain.toLowerCase().includes(searchTerm));

    filtered.sort((a, b) => {
      let valA = a[sortCol] || '';
      let valB = b[sortCol] || '';

      if (sortCol === 'last_updated') {
        let timeA = new Date(valA).getTime() || 0;
        let timeB = new Date(valB).getTime() || 0;
        return sortAsc ? timeA - timeB : timeB - timeA;
      }
      
      if (typeof valA === 'number' && typeof valB === 'number') {
        return sortAsc ? valA - valB : valB - valA;
      }

      let strA = valA.toString().toLowerCase();
      let strB = valB.toString().toLowerCase();
      if (strA < strB) return sortAsc ? -1 : 1;
      if (strA > strB) return sortAsc ? 1 : -1;
      return 0;
    });

    renderSummary(filtered);
    renderTable(filtered);
  }

  function renderSummary(data) {
    const container = document.getElementById('pm-summary');
    if (!container) return;
    
    const badRepCount = data.filter(d => d.domain_rep === 'LOW' || d.domain_rep === 'BAD').length;
    const highSpamCount = data.filter(d => (d.spam_rate || 0) >= 0.003).length; // >= 0.3%
    const total = data.length;

    container.innerHTML = `
      <div class="stat-card info">
        <span class="stat-label">Tracked Domains</span>
        <span class="stat-value">${total}</span>
      </div>
      <div class="stat-card ${badRepCount > 0 ? 'danger' : 'success'}">
        <span class="stat-label">Low/Bad Reputation</span>
        <span class="stat-value">${badRepCount}</span>
      </div>
      <div class="stat-card ${highSpamCount > 0 ? 'danger' : 'success'}">
        <span class="stat-label">Spam Rate > 0.3%</span>
        <span class="stat-value">${highSpamCount}</span>
      </div>
    `;
  }

  function renderTable(data) {
    const tbody = document.getElementById('tableBody');
    if (!tbody) return;
    
    if (data.length === 0) {
      tbody.innerHTML = `<tr><td colspan="9" class="center" style="padding: 20px;">No domains found.</td></tr>`;
      return;
    }

    let html = '';
    data.forEach(row => {
      html += `
        <tr class="domain-row">
          <td class="domain-text">
            <a href="javascript:void(0)" onclick="window.showDetails('${row.domain}')" class="domain-link" title="Click for details">
              <strong>${row.domain}</strong>
            </a>
          </td>
          <td class="center">${formatSpamRate(row.spam_rate)}</td>
          <td class="center">${formatReputation(row.domain_rep)}</td>
          <td class="center">${formatIpRepDetailed(row.ip_rep_detailed, row.ip_rep)}</td>
          <td class="center">${formatDeliveryErrors(row.delivery_errors)}</td>
          <td class="center">${formatAuth(row.spf_success_rate)}</td>
          <td class="center">${formatAuth(row.dkim_success_rate)}</td>
          <td class="center">${formatAuth(row.dmarc_success_rate)}</td>
          <td class="date-col">${formatDate(row.last_updated)}</td>
        </tr>
      `;
    });
    tbody.innerHTML = html;
  }

  // Helpers
  function formatSpamRate(rate) {
    if (rate === null || rate === undefined) return `<span class="badge badge-gray">N/A</span>`;
    const pct = (rate * 100).toFixed(2);
    let cls = 'badge-green';
    if (rate >= 0.003) cls = 'badge-red';
    else if (rate >= 0.001) cls = 'badge-yellow';
    return `<span class="badge ${cls}">${pct}%</span>`;
  }

  function formatReputation(rep) {
    if (!rep || rep === 'UNKNOWN') return `<span class="badge badge-gray">UNKNOWN</span>`;
    let cls = 'badge-gray';
    if (rep === 'HIGH') cls = 'badge-green';
    if (rep === 'MEDIUM') cls = 'badge-yellow';
    if (rep === 'LOW' || rep === 'BAD') cls = 'badge-red';
    return `<span class="badge ${cls}">${rep}</span>`;
  }

  function formatIpRepDetailed(detailedStr, fallbackStr) {
    try {
      if (!detailedStr) return formatReputation(fallbackStr);
      const reps = JSON.parse(detailedStr);
      if (!reps || reps.length === 0) return formatReputation(fallbackStr);
      
      return reps.map(r => {
        let cls = 'badge-gray';
        if (r.reputation === 'HIGH') cls = 'badge-green';
        if (r.reputation === 'MEDIUM') cls = 'badge-yellow';
        if (r.reputation === 'LOW' || r.reputation === 'BAD') cls = 'badge-red';
        
        // Достаем количество IP
        const count = r.ipCount || r.numIps || (r.sampleIps ? r.sampleIps.length : 0);
        const countDisplay = count > 0 ? ` (${count})` : '';
        
        return `<span class="badge ${cls}" style="margin: 2px; display: inline-block;">${r.reputation}${countDisplay}</span>`;
      }).join('');
    } catch (e) {
      return formatReputation(fallbackStr);
    }
  }

  function formatDeliveryErrors(errorsStr) {
    try {
      if (!errorsStr) return `<span class="text-gray">—</span>`;
      const errors = JSON.parse(errorsStr);
      if (!errors || errors.length === 0) return `<span class="text-gray">—</span>`;
      
      const tooltipTexts = errors.map(e => {
        const ratio = e.errorRatio || 0;
        const pct = (ratio * 100).toFixed(1) + '%';
        return `${e.errorType}: ${pct}`;
      }).join(' | ');

      const mainRatio = errors[0].errorRatio || 0;
      const mainErrorRatio = (mainRatio * 100).toFixed(1);
      
      return `<span class="badge badge-red" title="${tooltipTexts}" style="cursor: help;">⚠️ ${mainErrorRatio}% Err</span>`;
    } catch (e) {
      return `<span class="text-gray">—</span>`;
    }
  }

  function formatAuth(rate) {
    if (rate === null || rate === undefined) return `<span class="text-gray">—</span>`;
    const pct = Math.round(rate * 100);
    const color = pct >= 95 ? '#38a169' : (pct >= 80 ? '#d69e2e' : '#e53e3e');
    return `<span style="color: ${color}; font-weight: bold;">${pct}%</span>`;
  }

  function formatDate(d) {
    if (!d) return '—';
    return new Date(d).toLocaleDateString('cs-CZ', { day: '2-digit', month: '2-digit', year: 'numeric' });
  }

  // Функция вызова модалки с детализацией
  (window as any).showDetails = (domain) => {
    const row = rawData.find(d => d.domain === domain);
    if (!row) return;

    const modal = document.getElementById('detailsModal') as HTMLDialogElement;
    document.getElementById('modalTitle').innerText = `Details: ${domain}`;
    
    let html = '';

    // Блок 1: Ошибки доставки
    html += `<div class="details-section"><h3>🛑 Delivery Errors</h3>`;
    try {
      const errors = JSON.parse(row.delivery_errors || '[]');
      if (errors.length === 0) {
        html += `<p class="text-gray">No delivery errors recorded for the latest date.</p>`;
      } else {
        html += `<ul class="error-list">`;
        errors.forEach(e => {
          const ratio = e.errorRatio || 0;
          const pct = (ratio * 100).toFixed(2);
          html += `<li><strong>${e.errorClass}</strong> / <strong>${e.errorType}</strong><br>Affected traffic: <span style="color:#e53e3e; font-weight:bold;">${pct}%</span></li>`;
        });
        html += `</ul>`;
      }
    } catch (e) {
      html += `<p class="text-gray">No error data parsed.</p>`;
    }
    html += `</div>`;

    // Блок 2: Детализация IP адресов
    html += `<div class="details-section"><h3>🌐 IP Reputation (Sample IPs)</h3>`;
    try {
      const ipReps = JSON.parse(row.ip_rep_detailed || '[]');
      if (ipReps.length === 0) {
        html += `<p class="text-gray">No detailed IP data available.</p>`;
      } else {
        ipReps.forEach(r => {
           const ips = r.sampleIps && r.sampleIps.length > 0 ? r.sampleIps.join('<br>') : '<span class="text-gray">No specific IPs provided by Google API</span>';
           const count = r.ipCount || r.numIps || (r.sampleIps ? r.sampleIps.length : 0);
           
           let badgeCls = 'badge-gray';
           if (r.reputation === 'HIGH') badgeCls = 'badge-green';
           if (r.reputation === 'MEDIUM') badgeCls = 'badge-yellow';
           if (r.reputation === 'LOW' || r.reputation === 'BAD') badgeCls = 'badge-red';

           html += `
             <div style="margin-bottom: 15px;">
               <span class="badge ${badgeCls}">${r.reputation}</span> 
               <span style="font-size: 0.85rem; color: #4a5568; font-weight: bold; margin-left: 5px;">(Total IPs: ${count})</span>
               <div class="ip-list">${ips}</div>
             </div>
           `;
        });
      }
    } catch (e) {
      html += `<p class="text-gray">No detailed IP data parsed.</p>`;
    }
    html += `</div>`;

    document.getElementById('modalBody').innerHTML = html;
    modal.showModal();
  };

  (window as any).sortBy = (col) => {
    if (sortCol === col) sortAsc = !sortAsc;
    else { sortCol = col; sortAsc = true; }
    applyFiltersAndRender();
  };

  (window as any).syncPostmaster = async (btn) => {
    const originalText = btn.innerHTML;
    btn.style.opacity = '0.7';
    
    try {
      // 1. Сначала обнаруживаем новые домены
      btn.innerHTML = '⏳ Discovering...';
      await fetch(DISCOVER_URL);
      
      // 2. Затем синхронизируем пачку старых
      btn.innerHTML = '⏳ Syncing Batch...';
      await fetch(SYNC_URL);
      
      // 3. Обновляем таблицу
      await init(); 
    } catch (e) {
      alert("Sync failed. Check console.");
      console.error(e);
    } finally {
      btn.innerHTML = originalText;
      btn.style.opacity = '1';
    }
  };

  init();
</script>

<style is:global>
  .domains-wrapper { padding: 2rem; max-width: 1400px; margin: 0 auto; font-family: system-ui, -apple-system, sans-serif; }
  .content-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 2rem; }
  .title-area h1 { font-size: 2.25rem; font-weight: 800; color: #ffffff !important; margin: 0; }
  .title-area p { color: #a0aec0 !important; font-size: 1.1rem; margin: 0.5rem 0 0 0; }
  
  .header-actions { display: flex; gap: 15px; }
  .btn-primary { display: flex; align-items: center; gap: 8px; background: #3182ce; color: #fff; padding: 12px 24px; border-radius: 8px; font-weight: 700; border: none; cursor: pointer; transition: 0.2s; }
  .btn-primary:hover { background: #2b6cb0; }
  
  .summary-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1rem; margin-bottom: 2rem; }
  .stat-card { background: #fff !important; padding: 1.5rem; border-radius: 12px; border: 1px solid #cbd5e0; box-shadow: 0 4px 6px rgba(0,0,0,0.05); }
  .stat-card.danger { border-left: 6px solid #e53e3e !important; }
  .stat-card.success { border-left: 6px solid #48bb78 !important; }
  .stat-card.info { border-left: 6px solid #3182ce !important; }
  
  .stat-label { font-size: 0.8rem; font-weight: 800; text-transform: uppercase; color: #4a5568 !important; display: block; }
  .stat-value { font-size: 2.5rem; font-weight: 900; color: #1a202c !important; line-height: 1.2; }

  .table-actions-bar { margin-bottom: 1rem; }
  .input-field { padding: 12px 18px; border: 2px solid #cbd5e0; border-radius: 10px; width: 350px; font-weight: 600; background: #fff !important; color: #000 !important; }
  
  .table-outer-container { background: #fff !important; border-radius: 12px; border: 1px solid #cbd5e0; overflow: hidden; }
  .table-scroll { max-height: 70vh; overflow-y: auto; }
  
  table { width: 100%; border-collapse: separate; border-spacing: 0; }
  thead th { position: sticky; top: 0; background: #f7fafc !important; font-weight: 800; text-transform: uppercase; font-size: 0.75rem; padding: 16px 12px; border-bottom: 2px solid #cbd5e0; color: #1a202c !important; text-align: left; }
  .sortable { cursor: pointer; user-select: none; }
  .sortable:hover { background: #edf2f7 !important; }
  
  td { padding: 16px 12px; border-bottom: 1px solid #edf2f7; font-size: 0.95rem; color: #2d3748 !important; }
  .domain-row:hover { background-color: #f7fafc !important; }
  .center { text-align: center; }
  .domain-text strong { font-size: 1.05rem; }
  .domain-link { color: #3182ce; text-decoration: none; border-bottom: 1px dashed #3182ce; padding-bottom: 2px; transition: 0.2s; }
  .domain-link:hover { color: #2b6cb0; border-bottom: 1px solid #2b6cb0; }
  
  .date-col { font-size: 0.85rem; font-weight: 500; }
  .text-gray { color: #a0aec0 !important; }

  .badge { padding: 6px 12px; border-radius: 6px; font-size: 0.75rem; font-weight: 900; }
  .badge-green { background: #c6f6d5 !important; color: #22543d !important; }
  .badge-red { background: #fed7d7 !important; color: #822727 !important; }
  .badge-yellow { background: #feebc8 !important; color: #744210 !important; }
  .badge-gray { background: #edf2f7 !important; color: #4a5568 !important; }

  /* Стили модального окна */
  .modal { border: none; border-radius: 12px; padding: 0; width: 90%; max-width: 600px; box-shadow: 0 10px 25px rgba(0,0,0,0.2); background: #fff; color: #1a202c; }
  .modal::backdrop { background: rgba(0, 0, 0, 0.6); backdrop-filter: blur(2px); }
  .modal-content { display: flex; flex-direction: column; }
  .modal-header { padding: 1rem 1.5rem; border-bottom: 1px solid #e2e8f0; display: flex; justify-content: space-between; align-items: center; background: #f7fafc; }
  .modal-header h2 { margin: 0; font-size: 1.25rem; font-weight: 800; color: #2d3748; }
  .close-btn { background: none; border: none; font-size: 1.5rem; cursor: pointer; color: #a0aec0; transition: 0.2s; }
  .close-btn:hover { color: #1a202c; }
  .modal-body { padding: 1.5rem; max-height: 60vh; overflow-y: auto; }
  .details-section { margin-bottom: 1.5rem; }
  .details-section h3 { margin-top: 0; font-size: 1.05rem; color: #4a5568; border-bottom: 2px solid #edf2f7; padding-bottom: 0.5rem; }
  .ip-list { font-family: monospace; background: #edf2f7; padding: 10px 15px; border-radius: 6px; font-size: 0.85rem; max-height: 150px; overflow-y: auto; margin-top: 8px; border: 1px solid #e2e8f0; line-height: 1.6; }
  .error-list { padding-left: 1.2rem; margin: 0; }
  .error-list li { margin-bottom: 0.5rem; font-size: 0.95rem; }
</style>