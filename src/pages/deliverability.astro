---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Deliverability Hub | ivandeliver.email">
  <main class="hub-container">
    <header class="hub-header">
      <div class="brand-line">
        <img src="/images/tinyco-logo.png" alt="TinyCo Logo" class="tiny-logo" />
        <span class="brand-text">Tiny Email Deliverability Tools</span>
      </div>
      
      <h1>Deliverability Monitoring Hub</h1>
      <p>A centralized suite of tools for monitoring DNS health, IP reputation, and Google Postmaster metrics.</p>
    </header>

    <div class="hub-grid">
      <a href="/domains" class="hub-card">
        <div class="card-icon dns">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
        </div>
        <div class="card-content">
          <h3>DNS Monitor</h3>
          <p>Real-time validation of SPF, DMARC, DKIM, and Return-Path for client domains.</p>
          <span class="card-link dns">Launch Monitor →</span>
        </div>
      </a>

      <a href="/monitor" class="hub-card">
        <div class="card-icon snds">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect><line x1="8" y1="21" x2="16" y2="21"></line><line x1="12" y1="17" x2="12" y2="21"></line></svg>
        </div>
        <div class="card-content">
          <h3>SNDS Monitor</h3>
          <p>Microsoft SNDS tracking for IP reputation, complaints, and trap hits.</p>
          <span class="card-link snds">Check IP Health →</span>
        </div>
      </a>

      <a href="/postmaster" class="hub-card">
        <div class="card-icon gpt">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21.21 15.89A10 10 0 1 1 8 2.83"></path><path d="M22 12A10 10 0 0 0 12 2v10z"></path></svg>
        </div>
        <div class="card-content">
          <h3>GPT Monitor</h3>
          <p>Google Postmaster Tools integration for Spam Rate and Domain/IP Reputation.</p>
          <span class="card-link gpt">View Reputation →</span>
        </div>
      </a>
      
      <a href="/ip-inventory" class="hub-card">
        <div class="card-icon inventory" style="background: linear-gradient(135deg, #ed8936, #dd6b20);">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="8" rx="2" ry="2"></rect><rect x="2" y="14" width="20" height="8" rx="2" ry="2"></rect><line x1="6" y1="6" x2="6.01" y2="6"></line><line x1="6" y1="18" x2="6.01" y2="18"></line></svg>
        </div>
        <div class="card-content">
          <h3>IP Inventory</h3>
          <p>Unified tracking of IP pools mapping to Microsoft and Google health statuses.</p>
          <span class="card-link" style="color: #ed8936 !important;">View Inventory →</span>
        </div>
      </a>
    </div>

    <footer class="hub-footer">
      <p>&copy; 2026 ivandeliver.email • Built for TinyEmail Deliverability Team</p>
    </footer>
  </main>
</Layout>

<style>
  .hub-container {
    max-width: 1400px; /* Увеличено для 4 карточек */
    margin: 0 auto;
    padding: 3rem 2rem 5rem 2rem;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    z-index: 10;
  }

  .hub-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .brand-line {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 2rem;
    padding: 10px 24px;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 100px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    backdrop-filter: blur(8px);
  }

  .tiny-logo {
    height: 24px;
    width: auto;
    display: block;
  }

  .brand-text {
    font-size: 0.9rem;
    font-weight: 800;
    color: #48bb78;
    text-transform: uppercase;
    letter-spacing: 1.2px;
  }

  .hub-header h1 {
    font-size: 3.5rem;
    font-weight: 900;
    color: #ffffff !important; 
    margin: 0 0 1rem 0;
    letter-spacing: -1px;
    line-height: 1.1;
  }

  .hub-header p {
    font-size: 1.15rem;
    color: #cbd5e1 !important; 
    max-width: 700px;
    margin: 0 auto;
    line-height: 1.6;
    font-weight: 500;
  }

  /* ЖЕСТКАЯ СЕТКА ИЗ 4 КОЛОНОК */
  .hub-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  .hub-card {
    background: rgba(255, 255, 255, 0.98);
    border: 1px solid #e2e8f0;
    border-radius: 20px;
    padding: 2rem 1.5rem; /* Уменьшен паддинг */
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.23, 1, 0.32, 1);
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    box-shadow: 0 4px 6px rgba(0,0,0,0.02);
  }

  .hub-card:hover {
    transform: translateY(-8px) scale(1.01);
    border-color: #3182ce;
    box-shadow: 0 20px 40px -12px rgba(0, 0, 0, 0.15);
  }

  .card-icon {
    width: 54px;
    height: 54px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
  }
  .card-icon svg { width: 26px; height: 26px; }

  .card-icon.dns { background: linear-gradient(135deg, #3182ce, #2b6cb0); }
  .card-icon.snds { background: linear-gradient(135deg, #38a169, #2f855a); }
  .card-icon.gpt { background: linear-gradient(135deg, #805ad5, #6b46c1); }

  .card-content h3 {
    font-size: 1.4rem;
    font-weight: 800;
    color: #1a202c !important; 
    margin: 0 0 0.5rem 0;
    letter-spacing: -0.5px;
  }

  .card-content p {
    color: #64748b !important; 
    line-height: 1.5;
    margin: 0 0 1.5rem 0;
    font-size: 0.95rem;
    font-weight: 500;
  }

  .card-link {
    font-weight: 700;
    font-size: 0.95rem;
    transition: all 0.2s;
    margin-top: auto;
  }
  
  .card-link.dns { color: #3182ce !important; }
  .card-link.snds { color: #38a169 !important; }
  .card-link.gpt { color: #805ad5 !important; }

  .hub-card:hover .card-link { gap: 8px; text-decoration: underline; }

  .hub-footer { margin-top: 5rem; text-align: center; color: #4a5568 !important; font-size: 0.9rem; font-weight: 500; }

  /* Адаптивность: перенос на новые строки на небольших экранах */
  @media (max-width: 1200px) {
    .hub-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 768px) {
    .hub-header h1 { font-size: 2.8rem; }
    .hub-container { padding: 3rem 1rem; }
    .hub-grid { grid-template-columns: 1fr; }
    .tiny-logo { height: 20px; }
  }
</style>