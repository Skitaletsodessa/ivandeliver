---
import Layout from '../layouts/Layout.astro';
---

<Layout title="SNDS Monitor | ivandeliver.email">
  <main class="monitor-wrapper">
    <div class="header">
      <h1>SNDS Deliverability Hub</h1>
      <p>Статус репутации IP. Строки с ловушками (Traps > 0) выделены цветом.</p>
    </div>

    <div class="card chart-container">
      <canvas id="sndsChart"></canvas>
    </div>

    <div class="card table-container">
      <div class="table-header">
        <h3>Детальный лог</h3>
        <div class="pagination-controls">
          <button id="prevPage" class="btn">← Назад</button>
          <span id="pageInfo">Страница 1</span>
          <button id="nextPage" class="btn">Вперед →</button>
        </div>
      </div>
      
      <div class="scroll-area">
        <table id="sndsTable">
          <thead>
            <tr>
              <th>Дата</th>
              <th>IP Адрес</th>
              <th>Статус</th>
              <th>Жалобы</th>
              <th>Ловушки</th>
            </tr>
          </thead>
          <tbody>
            </tbody>
        </table>
      </div>
    </div>
  </main>
</Layout>

<script>
  import Chart from 'chart.js/auto';

  const API_URL = 'https://d1-template.skitalets-od.workers.dev/api/data';
  let allData = [];
  let currentPage = 1;
  const pageSize = 100;

  async function init() {
    try {
      const response = await fetch(API_URL);
      const data = await response.json();
      
      // 1. Сортировка: сначала те, где есть Traps > 0, затем по дате
      allData = data.sort((a, b) => {
        if (b.traps !== a.traps) return b.traps - a.traps;
        return new Date(b.date).getTime() - new Date(a.date).getTime();
      });

      renderChart(allData);
      renderTable();
      updatePaginationControls();
    } catch (err) {
      console.error("Data load error:", err);
    }
  }

  function renderTable() {
    const tbody = document.querySelector('#sndsTable tbody');
    if (!tbody) return;

    const start = (currentPage - 1) * pageSize;
    const end = start + pageSize;
    const pageData = allData.slice(start, end);

    tbody.innerHTML = pageData.map(row => {
      // Подсветка строки, если есть ловушки
      const rowClass = row.traps > 0 ? 'row-danger' : '';
      
      return `
        <tr class="${rowClass}">
          <td>${row.date}</td>
          <td><code>${row.ip}</code></td>
          <td style="text-align: center;">
            <span class="badge ${row.filter_result.toLowerCase()}">${row.filter_result}</span>
          </td>
          <td style="text-align: center;">${row.complaints}</td>
          <td style="text-align: center;"><strong>${row.traps}</strong> ${row.traps > 0 ? '⚠️' : ''}</td>
        </tr>
      `;
    }).join('');

    document.getElementById('pageInfo').innerText = `Страница ${currentPage} из ${Math.ceil(allData.length / pageSize)}`;
  }

  function updatePaginationControls() {
    document.getElementById('prevPage').onclick = () => {
      if (currentPage > 1) {
        currentPage--;
        renderTable();
        window.scrollTo({ top: document.querySelector('.table-container').offsetTop, behavior: 'smooth' });
      }
    };
    document.getElementById('nextPage').onclick = () => {
      if (currentPage * pageSize < allData.length) {
        currentPage++;
        renderTable();
        window.scrollTo({ top: document.querySelector('.table-container').offsetTop, behavior: 'smooth' });
      }
    };
  }

  function renderChart(data) {
    const ctx = document.getElementById('sndsChart') as HTMLCanvasElement;
    if (!ctx) return;
    const labels = [...new Set(data.map(item => item.date))].sort();
    const complaints = labels.map(d => data.filter(i => i.date === d).reduce((s, c) => s + c.complaints, 0));
    const traps = labels.map(d => data.filter(i => i.date === d).reduce((s, c) => s + c.traps, 0));

    new Chart(ctx, {
      type: 'line',
      data: {
        labels: labels,
        datasets: [
          { label: 'Complaints', data: complaints, borderColor: '#3b82f6', backgroundColor: 'rgba(59, 130, 246, 0.1)', fill: true },
          { label: 'Spam Traps', data: traps, borderColor: '#ef4444', backgroundColor: 'rgba(239, 68, 68, 0.1)', fill: true }
        ]
      },
      options: { responsive: true, maintainAspectRatio: false }
    });
  }

  init();
</script>

<style is:global>
  .monitor-wrapper { padding: 2rem; max-width: 1200px; margin: 0 auto; color: #1a202c !important; }
  .card { background: white !important; border-radius: 12px; border: 1px solid #cbd5e0 !important; padding: 1.5rem; margin-bottom: 2rem; }
  .chart-container { height: 400px; }
  
  /* Хедер таблицы с пагинацией */
  .table-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; }
  .pagination-controls { display: flex; align-items: center; gap: 1rem; }
  .btn { padding: 6px 12px; background: #edf2f7; border: 1px solid #cbd5e0; border-radius: 6px; cursor: pointer; font-size: 14px; }
  .btn:hover { background: #e2e8f0; }

  table { width: 100%; border-collapse: collapse; background: white !important; }
  th { background: #f7fafc !important; padding: 12px; border: 1px solid #cbd5e0 !important; text-align: left; }
  td { padding: 12px; border: 1px solid #e2e8f0 !important; color: #1a202c !important; }

  /* Подсветка проблемных строк */
  .row-danger { background-color: #fff5f5 !important; }
  .row-danger td { color: #c53030 !important; font-weight: 500; }

  .badge { display: inline-block; padding: 4px 10px; border-radius: 6px; font-size: 11px; font-weight: 800; text-transform: uppercase; min-width: 70px; text-align: center; }
  .green { background: #c6f6d5 !important; color: #22543d !important; }
  .yellow { background: #feebc8 !important; color: #744210 !important; }
  .red { background: #fed7d7 !important; color: #822727 !important; }
  
  code { background: #ebf8ff; color: #2b6cb0; padding: 2px 5px; border-radius: 4px; font-family: monospace; }
</style>