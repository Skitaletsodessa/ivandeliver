---
import Layout from '../layouts/Layout.astro';
---

<Layout title="SNDS Monitor | ivandeliver.email">
  <main class="monitor-wrapper">
    <div class="header">
      <h1>SNDS Deliverability Hub</h1>
      <p>IP reputation and status for Microsoft (Outlook/Hotmail)</p>
    </div>

    <div class="dashboard-grid">
      <div class="card chart-container">
        <canvas id="sndsChart"></canvas>
      </div>

      <div class="card table-container">
        <h3>Детальный лог (Last 100)</h3>
        <div class="scroll-area">
          <table id="sndsTable">
            <thead>
              <tr>
                <th>Дата</th>
                <th>IP</th>
                <th>Status</th>
                <th>Complaints</th>
                <th>Traps</th>
              </tr>
            </thead>
            <tbody>
              </tbody>
          </table>
        </div>
      </div>
    </div>
  </main>
</Layout>

<script>
  import Chart from 'chart.js/auto';

  // Твоя ссылка на воркер
  const API_URL = 'https://d1-template.skitalets-od.workers.dev/api/data';

  async function loadData() {
    try {
      const response = await fetch(API_URL);
      const data = await response.json();
      
      renderChart(data);
      renderTable(data);
    } catch (err) {
      console.error("Failed to fetch SNDS data:", err);
    }
  }

  function renderTable(data) {
    const tbody = document.querySelector('#sndsTable tbody');
    if (!tbody) return;
    
    tbody.innerHTML = data.slice(0, 100).map(row => `
      <tr>
        <td>${row.date}</td>
        <td><code>${row.ip}</code></td>
        <td><span class="badge ${row.filter_result.toLowerCase()}">${row.filter_result}</span></td>
        <td>${row.complaints}</td>
        <td>${row.traps}</td>
      </tr>
    `).join('');
  }

  function renderChart(data) {
    const ctx = document.getElementById('sndsChart') as HTMLCanvasElement;
    if (!ctx) return;

    const labels = [...new Set(data.map(item => item.date))].sort();
    const complaints = labels.map(d => data.filter(i => i.date === d).reduce((s, c) => s + c.complaints, 0));
    const traps = labels.map(d => data.filter(i => i.date === d).reduce((s, c) => s + c.traps, 0));

    new Chart(ctx, {
      type: 'line',
      data: {
        labels: labels,
        datasets: [
          { label: 'Complaints', data: complaints, borderColor: '#3b82f6', tension: 0.3, fill: true, backgroundColor: 'rgba(59, 130, 246, 0.1)' },
          { label: 'Spam Traps', data: traps, borderColor: '#ef4444', tension: 0.3, fill: true, backgroundColor: 'rgba(239, 68, 68, 0.1)' }
        ]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { position: 'bottom' } }
      }
    });
  }

  loadData();
</script>

<style is:global>
  /* Используем is:global, чтобы стили точно применились к динамическому контенту */
  
  .monitor-wrapper { 
    padding: 2rem; 
    max-width: 1200px; 
    margin: 0 auto; 
    color: #1a202c !important; /* Насильно ставим темный цвет текста */
  }
  
  .card { 
    background-color: #ffffff !important; 
    border-radius: 12px; 
    border: 1px solid #cbd5e0 !important; 
    padding: 1.5rem; 
    box-shadow: 0 4px 6px rgba(0,0,0,0.1); 
    margin-bottom: 2rem;
  }

  .scroll-area { 
    overflow-x: auto; 
    background: #ffffff !important;
  }

  table { 
    width: 100%; 
    border-collapse: collapse; 
    background: #ffffff !important;
    color: #1a202c !important;
  }

  th { 
    background-color: #edf2f7 !important; /* Светло-серый фон для заголовков */
    color: #2d3748 !important;
    text-align: left; 
    padding: 12px; 
    border: 1px solid #cbd5e0 !important;
    font-weight: bold;
  }

  td { 
    padding: 12px; 
    border: 1px solid #e2e8f0 !important; /* Четкие границы ячеек */
    color: #1a202c !important;
    vertical-align: middle;
  }

  /* Исправляем видимость бейджей */
  .badge { 
    display: inline-block;
    padding: 4px 10px; 
    border-radius: 6px; 
    font-size: 11px; 
    font-weight: 800; 
    text-transform: uppercase;
    text-align: center;
    min-width: 70px;
    border: 1px solid rgba(0,0,0,0.1);
  }

  .green { background-color: #c6f6d5 !important; color: #22543d !important; }
  .yellow { background-color: #feebc8 !important; color: #744210 !important; }
  .red { background-color: #fed7d7 !important; color: #822727 !important; }
  
  code { 
    font-family: monospace; 
    color: #2b6cb0 !important; 
    background: #ebf8ff !important;
    padding: 2px 5px;
    border-radius: 4px;
    border: 1px solid #bee3f8;
  }

  h3 { color: #2d3748 !important; margin-bottom: 1rem; }
</style>