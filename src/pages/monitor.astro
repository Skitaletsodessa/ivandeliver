---
import Layout from '../layouts/Layout.astro';
---

<Layout title="SNDS Monitor | ivandeliver.email">
  <main class="monitor-wrapper">
    <div class="header">
      <div class="title-area">
        <h1>SNDS Deliverability Hub</h1>
        <p>IP reputation, Complaints, and JMR monitoring.</p>
      </div>
      <div class="monitor-header-actions">
        <button id="logoutBtn" class="btn btn-outline">Logout</button>
      </div>
    </div>

    <div id="summary-stats" class="summary-grid">
    </div>

    <div class="card filter-bar">
      <div class="filter-row">
        <div class="filter-group">
          <label>Quick Range:</label>
          <div class="btn-group">
            <button class="btn quick-filter" data-days="7">7D</button>
            <button class="btn quick-filter" data-days="14">14D</button>
            <button class="btn quick-filter" data-days="30">30D</button>
          </div>
        </div>
        
        <div class="filter-group">
          <label>Custom Range:</label>
          <div class="input-row">
            <input type="date" id="dateFrom" class="input-field" />
            <span class="to-sep">to</span>
            <input type="date" id="dateTo" class="input-field" />
          </div>
        </div>

        <div class="filter-group actions">
          <button id="downloadCsv" class="btn btn-primary">Download CSV</button>
          <button id="resetDates" class="btn">Reset All</button>
        </div>
      </div>
    </div>

    <div class="card chart-container">
      <canvas id="sndsChart"></canvas>
    </div>

    <div class="card table-container">
      <div class="table-controls">
        <div class="search-box">
          <input type="text" id="tableSearch" placeholder="Search IP..." class="input-field" />
        </div>
        <div class="pagination-controls">
          <button id="prevPage" class="btn">←</button>
          <span id="pageInfo">Page 1</span>
          <button id="nextPage" class="btn">→</button>
        </div>
      </div>
      
      <div class="scroll-area">
        <table id="sndsTable">
          <thead>
            <tr>
              <th data-sort="date" class="sortable">Date ↕</th>
              <th data-sort="ip" class="sortable">IP Address ↕</th>
              <th data-sort="filter_result" class="sortable">Status ↕</th>
              <th data-sort="complaints" class="sortable">Compl. % ↕</th>
              <th data-sort="traps" class="sortable">Traps ↕</th>
              <th data-sort="jmr_p1_sender" class="sortable">JMR P1 Sender ↕</th>
            </tr>
          </thead>
          <tbody></tbody>
        </table>
      </div>
    </div>
  </main>
</Layout>

<script>
  import Chart from 'chart.js/auto';

  const API_URL = 'https://d1-template.skitalets-od.workers.dev/api/data';
  let rawData = [];
  let filteredData = [];
  let currentPage = 1;
  const pageSize = 100;
  let currentSort = { key: 'date', dir: 'desc' };
  let myChart = null;

  async function init() {
    try {
      const response = await fetch(API_URL);
      rawData = await response.json();
      setRange(7);
      renderSummary();
      setupEventListeners();
    } catch (err) {
      console.error("Data load error:", err);
    }
  }

  function renderSummary() {
    const container = document.getElementById('summary-stats');
    if (!container || rawData.length === 0) return;

    const latestDate = [...new Set(rawData.map(r => r.date))].sort().pop();
    const todayData = rawData.filter(r => r.date === latestDate);

    const redCount = todayData.filter(r => r.filter_result === 'RED').length;
    const trapSum = todayData.reduce((s, r) => s + (r.traps || 0), 0);
    const jmrCount = todayData.filter(r => r.jmr_p1_sender && r.jmr_p1_sender !== '0' && r.jmr_p1_sender !== '').length;

    container.innerHTML = `
      <div class="stat-card info">
        <span class="stat-label">Latest Data Date</span>
        <span class="stat-value">${latestDate}</span>
      </div>
      <div class="stat-card ${redCount > 0 ? 'danger' : 'success'}">
        <span class="stat-label">RED IPs Today</span>
        <span class="stat-value">${redCount}</span>
      </div>
      <div class="stat-card ${trapSum > 0 ? 'warning' : ''}">
        <span class="stat-label">Total Trap Hits</span>
        <span class="stat-value">${trapSum}</span>
      </div>
      <div class="stat-card ${jmrCount > 0 ? 'warning' : ''}">
        <span class="stat-label">JMR P1 Incidents</span>
        <span class="stat-value">${jmrCount}</span>
      </div>
    `;
  }

  function setRange(days) {
    const to = new Date().toISOString().split('T')[0];
    const fromDate = new Date();
    fromDate.setDate(fromDate.getDate() - days);
    const from = fromDate.toISOString().split('T')[0];
    (document.getElementById('dateFrom') as HTMLInputElement).value = from;
    (document.getElementById('dateTo') as HTMLInputElement).value = to;
    applyFilters();
  }

  function applyFilters() {
    const from = (document.getElementById('dateFrom') as HTMLInputElement)?.value || '';
    const to = (document.getElementById('dateTo') as HTMLInputElement)?.value || '';
    const search = (document.getElementById('tableSearch') as HTMLInputElement)?.value.toLowerCase() || '';

    filteredData = rawData.filter(r => {
      const dateMatch = (!from || r.date >= from) && (!to || r.date <= to);
      const searchMatch = r.ip.toLowerCase().includes(search) || 
                          r.filter_result.toLowerCase().includes(search) ||
                          (r.jmr_p1_sender && String(r.jmr_p1_sender).toLowerCase().includes(search));
      return dateMatch && searchMatch;
    });

    sortData(currentSort.key, currentSort.dir);
    currentPage = 1;
    renderTable();
    renderChart(filteredData);
  }

  function sortData(key, dir) {
    const modifier = dir === 'desc' ? 1 : -1;
    filteredData.sort((a, b) => {
      const hasJmr = (val) => (val && val !== '0' && val !== '') ? 1 : 0;
      if (key === 'date') {
        if (a.date !== b.date) return b.date.localeCompare(a.date) * modifier;
      } else if (key === 'jmr_p1_sender') {
        const jA = hasJmr(a.jmr_p1_sender);
        const jB = hasJmr(b.jmr_p1_sender);
        if (jA !== jB) return (jB - jA) * modifier;
      } else if (key === 'ip' || key === 'filter_result') {
        if (a[key] !== b[key]) return String(a[key]).localeCompare(String(b[key])) * modifier;
      } else {
        if (a[key] !== b[key]) return (b[key] - a[key]) * modifier;
      }
      if (a.date !== b.date) return b.date.localeCompare(a.date);
      const jA = hasJmr(a.jmr_p1_sender);
      const jB = hasJmr(b.jmr_p1_sender);
      if (jA !== jB) return jB - jA;
      if (a.traps !== b.traps) return b.traps - a.traps;
      return b.complaints - a.complaints;
    });
  }

  function renderTable() {
    const tbody = document.querySelector('#sndsTable tbody');
    if (!tbody) return;
    const start = (currentPage - 1) * pageSize;
    const pageData = filteredData.slice(start, start + pageSize);

    tbody.innerHTML = pageData.map(row => {
      const hasJmr = row.jmr_p1_sender && row.jmr_p1_sender !== '0' && row.jmr_p1_sender !== '';
      return `
        <tr class="${(row.traps > 0 || hasJmr) ? 'row-danger' : ''}">
          <td>${row.date}</td>
          <td><code>${row.ip}</code></td>
          <td style="text-align: center;"><span class="badge ${row.filter_result.toLowerCase()}">${row.filter_result}</span></td>
          <td style="text-align: center;">${row.complaints}%</td>
          <td style="text-align: center;">${row.traps}</td>
          <td style="text-align: center; font-size: 0.85rem; position: relative;">
            ${hasJmr ? `<span class="jmr-text" title="${row.jmr_p1_sender}">${row.jmr_p1_sender}</span>` : '0'}
          </td>
        </tr>
      `;
    }).join('');
    const pageInfo = document.getElementById('pageInfo');
    if (pageInfo) pageInfo.innerText = `Page ${currentPage} of ${Math.ceil(filteredData.length / pageSize) || 1}`;
  }

  // --- ОБНОВЛЕННАЯ ФУНКЦИЯ ГРАФИКА ---
  function renderChart(data) {
    const ctx = document.getElementById('sndsChart') as HTMLCanvasElement;
    if (!ctx || !data.length) return;
    const labels = [...new Set(data.map(item => item.date))].sort();
    
    // 1. СРЕДНИЙ ПРОЦЕНТ ЖАЛОБ
    const avgComplaints = labels.map(d => {
      const dayData = data.filter(i => i.date === d);
      return (dayData.reduce((s, c) => s + c.complaints, 0) / dayData.length).toFixed(3);
    });

    // 2. СУММА IP АДРЕСОВ
    const ipCounts = labels.map(d => data.filter(i => i.date === d).length);

    // 3. JMR ИНЦИДЕНТЫ
    const jmrHits = labels.map(d => data.filter(i => i.date === d).reduce((s, c) => {
      return s + (c.jmr_p1_sender && c.jmr_p1_sender !== '0' && c.jmr_p1_sender !== '' ? 1 : 0);
    }, 0));

    if (myChart) myChart.destroy();
    myChart = new Chart(ctx, {
      type: 'line',
      data: {
        labels: labels,
        datasets: [
          { 
            label: 'Avg Complaints %', 
            data: avgComplaints, 
            borderColor: '#3b82f6', 
            tension: 0.2, 
            yAxisID: 'yPerc' 
          },
          { 
            label: 'Total IP Count', 
            data: ipCounts, 
            borderColor: '#10b981', 
            backgroundColor: 'rgba(16, 185, 129, 0.05)', 
            fill: true, 
            tension: 0.2, 
            yAxisID: 'yCount' 
          },
          { 
            label: 'JMR Events', 
            data: jmrHits, 
            borderColor: '#ef4444', 
            tension: 0.2, 
            yAxisID: 'yCount' 
          }
        ]
      },
      options: { 
        responsive: true, 
        maintainAspectRatio: false,
        scales: {
          yPerc: {
            type: 'linear',
            position: 'left',
            title: { display: true, text: 'Avg Complaints %' }
          },
          yCount: {
            type: 'linear',
            position: 'right',
            grid: { drawOnChartArea: false },
            title: { display: true, text: 'Count (IP / JMR)' }
          }
        }
      }
    });
  }

  function setupEventListeners() {
    document.querySelectorAll('.quick-filter').forEach(btn => {
      (btn as HTMLElement).onclick = () => setRange(parseInt((btn as HTMLElement).dataset.days || '7'));
    });
    document.getElementById('dateFrom')?.addEventListener('change', applyFilters);
    document.getElementById('dateTo')?.addEventListener('change', applyFilters);
    document.getElementById('tableSearch')?.addEventListener('input', applyFilters);
    document.getElementById('downloadCsv')?.addEventListener('click', () => {
      const headers = ['Date', 'IP', 'Status', 'Complaints%', 'Traps', 'JMR_Data'];
      const csv = [headers.join(','), ...filteredData.map(r => [r.date, r.ip, r.filter_result, r.complaints, r.traps, r.jmr_p1_sender].join(','))].join('\n');
      const blob = new Blob([csv], { type: 'text/csv' });
      const url = window.URL.createObjectURL(blob);
      const a = document.createElement('a'); a.href = url; a.download = 'snds_report.csv'; a.click();
    });
    document.getElementById('resetDates')?.addEventListener('click', () => {
      (document.getElementById('dateFrom') as HTMLInputElement).value = '';
      (document.getElementById('dateTo') as HTMLInputElement).value = '';
      applyFilters();
    });
    document.querySelectorAll('th.sortable').forEach(th => {
      (th as HTMLElement).onclick = () => {
        const key = (th as HTMLElement).dataset.sort || 'date';
        currentSort.dir = (currentSort.key === key && currentSort.dir === 'desc') ? 'asc' : 'desc';
        currentSort.key = key;
        sortData(key, currentSort.dir);
        renderTable();
      };
    });
    document.getElementById('prevPage')?.addEventListener('click', () => { if (currentPage > 1) { currentPage--; renderTable(); } });
    document.getElementById('nextPage')?.addEventListener('click', () => { if (currentPage * pageSize < filteredData.length) { currentPage++; renderTable(); } });
    document.getElementById('logoutBtn')!.onclick = () => { if(confirm("Logout?")) window.location.href = window.location.origin + "/cdn-cgi/access/logout"; };
  }

  init();
</script>

<style is:global>
  .monitor-wrapper { padding: 2rem; max-width: 1200px; margin: 0 auto; color: #1a202c; font-family: system-ui, -apple-system, sans-serif; }
  .header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 2rem; }
  
  .summary-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1rem; margin-bottom: 2rem; }
  
  .stat-card { 
    background-color: #ffffff !important; 
    padding: 1.25rem; 
    border-radius: 12px; 
    border: 1px solid #cbd5e0; 
    display: flex; 
    flex-direction: column; 
    gap: 0.5rem; 
    box-shadow: 0 4px 6px rgba(0,0,0,0.1); 
  }
  
  .stat-label { 
    font-size: 0.75rem; 
    font-weight: 800; 
    text-transform: uppercase; 
    color: #2D3748 !important; 
    letter-spacing: 0.05em; 
  }
  
  .stat-value { 
    font-size: 1.6rem; 
    font-weight: 900; 
    color: #000000 !important; 
    line-height: 1.2;
  }
  
  .stat-card.info { border-left: 6px solid #3182ce !important; }
  .stat-card.success { border-left: 6px solid #38a169 !important; }
  .stat-card.danger { border-left: 6px solid #e53e3e !important; }
  .stat-card.danger .stat-value { color: #c53030 !important; }
  .stat-card.warning { border-left: 6px solid #d69e2e !important; }

  .card { background-color: #ffffff !important; border-radius: 12px; border: 1px solid #cbd5e0; padding: 1.5rem; margin-bottom: 1.5rem; }
  .filter-bar .filter-row { display: flex; flex-wrap: wrap; gap: 2rem; align-items: flex-end; }
  .filter-group label { font-size: 0.75rem; font-weight: bold; text-transform: uppercase; color: #4a5568 !important; }
  .input-field { padding: 8px 12px; border: 1px solid #cbd5e0; border-radius: 6px; font-size: 14px; background: #fff !important; color: #1a202c !important; }
  .btn { padding: 8px 14px; background: #fff !important; border: 1px solid #cbd5e0; border-radius: 6px; cursor: pointer; color: #1a202c !important; }
  .btn-primary { background: #3b82f6 !important; color: #fff !important; border: none; font-weight: bold; }
  .btn-outline { color: #e53e3e !important; border: 1px solid #e53e3e !important; font-weight: bold; }

  .chart-container { height: 350px; background: #fff !important; }
  table { width: 100%; border-collapse: collapse; background: #fff !important; }
  th { background: #f7fafc !important; color: #4a5568 !important; padding: 12px; border: 1px solid #cbd5e0; font-size: 0.8rem; text-transform: uppercase; cursor: pointer; }
  td { padding: 12px; border: 1px solid #e2e8f0; color: #1a202c !important; }
  .row-danger { background-color: #fff5f5 !important; color: #c53030 !important; font-weight: 600; }
  
  .badge { display: inline-block; padding: 4px 10px; border-radius: 6px; font-size: 11px; font-weight: 800; min-width: 70px; text-align: center; }
  .green { background: #c6f6d5 !important; color: #22543d !important; }
  .yellow { background: #feebc8 !important; color: #744210 !important; }
  .red { background: #fed7d7 !important; color: #822727 !important; }
  
  .jmr-text { display: block; max-width: 180px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; color: #2b6cb0; font-weight: 600; cursor: help; margin: 0 auto; }
</style>