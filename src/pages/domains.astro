---
import Layout from '../layouts/Layout.astro';
---

<Layout title="DNS Health Check | ivandeliver.email">
  <main class="domains-wrapper">
    <div class="header">
      <div class="title-area">
        <h1>DNS Health Monitor</h1>
        <p>Comprehensive monitoring for 344+ active client domains.</p>
      </div>
      <div class="actions">
        <input type="text" id="domainSearch" placeholder="Quick search domain..." class="input-field" />
        <a href="/monitor" class="btn">SNDS Monitor</a>
      </div>
    </div>

    <div id="dns-summary" class="summary-grid">
      </div>

    <div class="card table-container">
      <div class="scroll-area" id="tableScrollContainer">
        <table id="dnsTable">
          <thead>
            <tr>
              <th>Domain</th>
              <th class="center">SPF</th>
              <th class="center">DMARC</th>
              <th class="center">DKIM 1 (tec1)</th>
              <th class="center">DKIM 2 (tec2)</th>
              <th class="center">Bounce</th>
              <th>Last Checked</th>
            </tr>
          </thead>
          <tbody>
            <tr><td colspan="7" style="text-align:center;">Loading DNS records...</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </main>
</Layout>

<script>
  const API_URL = 'https://checkdns.skitalets-od.workers.dev/api/domains';
  let rawData = [];

  async function init() {
    try {
      const response = await fetch(API_URL);
      rawData = await response.json();
      
      processAndRender(rawData);

      document.getElementById('domainSearch')?.addEventListener('input', (e) => {
        const term = e.target.value.toLowerCase();
        const filtered = rawData.filter(d => d.domain.includes(term));
        processAndRender(filtered);
      });
    } catch (err) {
      console.error("DNS Load Error:", err);
    }
  }

  // Главная функция: сортировка + рендер
  function processAndRender(data) {
    const sorted = [...data].sort((a, b) => {
      // 1. Приоритет: SPF/DMARC Issues
      const aCrit = (a.spf_status !== 'OK' || a.dmarc_status !== 'OK') ? 1 : 0;
      const bCrit = (b.spf_status !== 'OK' || b.dmarc_status !== 'OK') ? 1 : 0;
      if (aCrit !== bCrit) return bCrit - aCrit;

      // 2. Приоритет: Other Issues (DKIM/Bounce)
      const aOther = (a.dkim1_status !== 'OK' || a.dkim2_status !== 'OK' || a.bounce_status !== 'OK') ? 1 : 0;
      const bOther = (b.dkim1_status !== 'OK' || b.dkim2_status !== 'OK' || b.bounce_status !== 'OK') ? 1 : 0;
      if (aOther !== bOther) return bOther - aOther;

      // 3. Алфавитный порядок для чистых доменов
      return a.domain.localeCompare(b.domain);
    });

    renderTable(sorted);
    renderSummary(rawData); // Сводку всегда считаем по всем данным
  }

  function renderSummary(data) {
    const container = document.getElementById('dns-summary');
    if (!container) return;

    const critical = data.filter(d => d.spf_status !== 'OK' || d.dmarc_status !== 'OK').length;
    const others = data.filter(d => 
      (d.spf_status === 'OK' && d.dmarc_status === 'OK') && 
      (d.dkim1_status !== 'OK' || d.dkim2_status !== 'OK' || d.bounce_status !== 'OK')
    ).length;

    container.innerHTML = `
      <div class="stat-card info">
        <span class="stat-label">Total Domains</span>
        <span class="stat-value">${data.length}</span>
      </div>
      <div class="stat-card ${critical > 0 ? 'danger' : 'success'}">
        <span class="stat-label">Critical Issues (SPF/DMARC)</span>
        <span class="stat-value">${critical}</span>
      </div>
      <div class="stat-card ${others > 0 ? 'warning' : ''}">
        <span class="stat-label">Config Issues (DKIM/Bounce)</span>
        <span class="stat-value">${others}</span>
      </div>
    `;
  }

  function renderTable(data) {
    const tbody = document.querySelector('#dnsTable tbody');
    if (!tbody) return;

    tbody.innerHTML = data.map(row => {
      return `
        <tr class="${(row.spf_status !== 'OK' || row.dmarc_status !== 'OK') ? 'row-critical' : ''}">
          <td><strong>${row.domain}</strong></td>
          <td class="center">${getStatusBadge(row.spf_status, row.spf_record)}</td>
          <td class="center">${getStatusBadge(row.dmarc_status, row.dmarc_record)}</td>
          <td class="center">
            <span class="status-icon" title="${row.dkim1_status === 'OK' ? 'CNAME Record Found' : 'CNAME Missing'}">
              ${row.dkim1_status === 'OK' ? '✅' : '❌'}
            </span>
          </td>
          <td class="center">
            <span class="status-icon" title="${row.dkim2_status === 'OK' ? 'CNAME Record Found' : 'CNAME Missing'}">
              ${row.dkim2_status === 'OK' ? '✅' : '❌'}
            </span>
          </td>
          <td class="center">
            <span class="status-icon" title="${row.bounce_status === 'OK' ? 'CNAME Record Found' : 'CNAME Missing'}">
              ${row.bounce_status === 'OK' ? '✅' : '❌'}
            </span>
          </td>
          <td class="date-col">${formatDate(row.last_checked)}</td>
        </tr>
      `;
    }).join('');
  }

  function getStatusBadge(status, record) {
    if (!status || status === 'null') return '<span class="badge badge-gray">WAITING</span>';
    
    let cls = 'badge-gray';
    if (status === 'OK') cls = 'badge-green';
    if (status === 'DUPLICATE') cls = 'badge-red';
    if (status === 'MISSING') cls = 'badge-yellow';

    // Очищаем запись от кавычек для тултипа
    const cleanRecord = record ? record.replace(/"/g, '&quot;') : 'No record found';
    return `<span class="badge ${cls}" title="${cleanRecord}">${status}</span>`;
  }

  function formatDate(dateStr) {
    if (!dateStr || dateStr.includes('1970')) return '—';
    const date = new Date(dateStr);
    return date.toLocaleString('cs-CZ', { day: '2-digit', month: '2-digit', hour: '2-digit', minute: '2-digit' });
  }

  init();
</script>

<style is:global>
  .domains-wrapper { padding: 2rem; max-width: 1400px; margin: 0 auto; color: #1a202c !important; font-family: system-ui, sans-serif; }
  .header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 2rem; }
  
  .summary-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1rem; margin-bottom: 2rem; }
  .stat-card { background-color: #ffffff !important; padding: 1.25rem; border-radius: 12px; border: 1px solid #cbd5e0; display: flex; flex-direction: column; gap: 0.5rem; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
  .stat-label { font-size: 0.75rem; font-weight: 800; text-transform: uppercase; color: #2D3748 !important; }
  .stat-value { font-size: 1.8rem; font-weight: 900; color: #000000 !important; }
  
  .stat-card.danger { border-left: 6px solid #e53e3e !important; }
  .stat-card.warning { border-left: 6px solid #d69e2e !important; }
  .stat-card.success { border-left: 6px solid #38a169 !important; }
  .stat-card.info { border-left: 6px solid #3182ce !important; }

  /* ТАБЛИЦА С ФИКСИРОВАННОЙ ШАПКОЙ */
  .table-container { 
    background: white; 
    border-radius: 12px; 
    border: 1px solid #cbd5e0; 
    overflow: hidden; 
    box-shadow: 0 4px 20px rgba(0,0,0,0.08); 
  }
  
  .scroll-area { 
    max-height: 75vh; 
    overflow-y: auto; 
  }

  table { width: 100%; border-collapse: separate; border-spacing: 0; }
  
  /* Фиксация шапки */
  thead th { 
    position: sticky; 
    top: 0; 
    z-index: 10; 
    background: #f8fafc !important; 
    color: #1a202c !important; 
    font-weight: 800; 
    text-transform: uppercase; 
    font-size: 0.75rem; 
    padding: 16px 12px; 
    border-bottom: 2px solid #cbd5e0;
    box-shadow: 0 2px 2px -1px rgba(0,0,0,0.1);
  }

  td { padding: 14px 12px; border-bottom: 1px solid #edf2f7; font-size: 0.95rem; color: #1a202c !important; }
  
  /* Подсветка критических строк */
  .row-critical { background-color: #fffafa; }
  .row-critical td { color: #822727 !important; }

  .center { text-align: center; }
  .date-col { font-size: 0.8rem; color: #64748b; white-space: nowrap; }

  .status-icon { cursor: help; font-size: 1.2rem; display: inline-block; transition: transform 0.1s; }
  .status-icon:hover { transform: scale(1.3); }

  .badge { padding: 6px 10px; border-radius: 6px; font-size: 0.75rem; font-weight: 800; cursor: help; border: 1px solid rgba(0,0,0,0.05); }
  .badge-green { background: #dcfce7; color: #166534; }
  .badge-yellow { background: #fef9c3; color: #854d0e; }
  .badge-red { background: #fee2e2; color: #991b1b; }
  .badge-gray { background: #f1f5f9; color: #475569; }

  .input-field { 
    padding: 12px 18px; 
    border: 2px solid #cbd5e0; 
    border-radius: 10px; 
    width: 350px; 
    font-size: 0.95rem; 
    color: #000 !important; 
    font-weight: 600; 
    transition: all 0.2s;
  }
  .input-field:focus { border-color: #3b82f6; box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1); outline: none; }
  
  .btn { padding: 12px 24px; background: #2563eb; color: #fff !important; text-decoration: none; border-radius: 10px; font-weight: 700; transition: background 0.2s; }
  .btn:hover { background: #1d4ed8; }
</style>