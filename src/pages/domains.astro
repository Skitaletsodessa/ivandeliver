---
import Layout from '../layouts/Layout.astro';
---

<Layout title="DNS Health Check | ivandeliver.email">
  <main class="domains-wrapper">
    <div class="content-header">
      <div class="title-area">
        <h1>DNS Health Monitor</h1>
        <p>Comprehensive monitoring, validation, and analysis for client domains.</p>
      </div>
    </div>

    <div class="card add-domain-card">
      <div class="add-grid">
        <div class="add-group">
          <label>New Domain</label>
          <input type="text" id="newDomainInput" placeholder="example.com" class="input-field" />
        </div>
        <div class="add-group">
          <label>Product</label>
          <select id="newProductSelect" class="input-field select-custom">
            <option value="TinyEmail">TinyEmail</option>
            <option value="TinyAlbert">TinyAlbert</option>
            <option value="TinyRelay">TinyRelay</option>
          </select>
        </div>
        <div class="add-group">
          <label>Account Type</label>
          <select id="newTypeSelect" class="input-field select-custom">
            <option value="Non-Major">Non-Major</option>
            <option value="Major">Major</option>
          </select>
        </div>
        <button id="addSubmitBtn" class="btn-add-domain" onclick="window.submitNewDomain()">
          Add & Verify
        </button>
      </div>
    </div>

    <div class="product-tabs">
      <button class="tab-btn active" onclick="window.setProductFilter('TinyEmail', event)">TinyEmail</button>
      <button class="tab-btn" onclick="window.setProductFilter('TinyAlbert', event)">TinyAlbert</button>
      <button class="tab-btn" onclick="window.setProductFilter('TinyRelay', event)">TinyRelay</button>
    </div>

    <div id="dns-summary" class="summary-grid"></div>

    <div class="table-actions-bar">
      <div class="left-actions">
        <input type="text" id="domainSearch" placeholder="Filter by domain..." class="input-field search-input" />
        <button id="btnMajorToggle" class="btn-major-filter" onclick="window.toggleMajor()">
          ⭐ Major Only
        </button>
      </div>
      <button class="btn-export" onclick="window.downloadCSV()">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
        Export CSV
      </button>
    </div>

    <div class="card table-outer-container">
      <div class="table-scroll" id="tableContainer">
        <table id="dnsTable">
          <thead>
            <tr>
              <th class="sortable" onclick="window.sortBy('domain')">Domain <span id="sort-domain" class="sort-icon"></span></th>
              <th class="center sortable" onclick="window.sortBy('virtual_spf')">SPF <span id="sort-virtual_spf" class="sort-icon"></span></th>
              <th class="center sortable" onclick="window.sortBy('virtual_dmarc')">DMARC <span id="sort-virtual_dmarc" class="sort-icon"></span></th>
              <th class="center sortable" onclick="window.sortBy('dkim1_status')">DKIM 1 <span id="sort-dkim1_status" class="sort-icon"></span></th>
              <th class="center sortable" onclick="window.sortBy('dkim2_status')">DKIM 2 <span id="sort-dkim2_status" class="sort-icon"></span></th>
              <th class="center sortable" onclick="window.sortBy('bounce_status')">Bounce <span id="sort-bounce_status" class="sort-icon"></span></th>
              <th class="center sortable" onclick="window.sortBy('virtual_warmup')">Warmup <span id="sort-virtual_warmup" class="sort-icon"></span></th>
              <th class="sortable" onclick="window.sortBy('last_checked')">Last Checked <span id="sort-last_checked" class="sort-icon"></span></th>
            </tr>
          </thead>
          <tbody id="tableBody">
            <tr><td colspan="8" style="text-align:center; padding: 40px; color: #1a202c;">Syncing data...</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </main>
</Layout>

<script>
  const API_URL = 'https://checkdns.skitalets-od.workers.dev/api/domains';
  const IMPORT_URL = 'https://checkdns.skitalets-od.workers.dev/api/import';
  const CHECK_URL = 'https://checkdns.skitalets-od.workers.dev/api/check-domain?domain=';
  
  let rawData = [];
  let currentFilteredData = []; 
  let currentFilter = 'all'; 
  let currentProduct = 'TinyEmail';
  let showOnlyMajor = false; 
  let expandedDomain = null;
  let sortCol = 'default';
  let sortAsc = true;

  // Логика добавления
  (window as any).submitNewDomain = async () => {
    const input = document.getElementById('newDomainInput') as HTMLInputElement;
    const prodSel = document.getElementById('newProductSelect') as HTMLSelectElement;
    const typeSel = document.getElementById('newTypeSelect') as HTMLSelectElement;
    const btn = document.getElementById('addSubmitBtn') as HTMLButtonElement;
    const domain = input.value.trim().toLowerCase();
    if (!domain || !domain.includes('.')) { alert("Invalid domain"); return; }
    btn.disabled = true;
    btn.innerText = 'Wait...';
    try {
      await fetch(IMPORT_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify([{ domain, product: prodSel.value, account_type: typeSel.value }])
      });
      await fetch(CHECK_URL + domain);
      input.value = '';
      await init(); 
    } catch (e) { alert("Error"); } finally {
      btn.disabled = false;
      btn.innerText = 'Add & Verify';
    }
  };

  // Валидация SPF/DMARC
  function validateSPF(recordStr) {
    let errors = new Set(); let warnings = new Set(); let lookups = 0;
    if (!recordStr) return { errors: ['Missing SPF'], warnings: [], lookups: 0 };
    const lower = recordStr.toLowerCase();
    if (!lower.includes('include:_spf.tinyemail.com')) errors.add('Missing TinyEmail include');
    return { errors: Array.from(errors), warnings: Array.from(warnings), lookups: 0 };
  }

  function validateDMARC(recordStr) {
    let errors = new Set();
    if (!recordStr) return { errors: ['Missing DMARC'], warnings: [] };
    if (!recordStr.toLowerCase().includes('p=')) errors.add('Missing p= policy');
    return { errors: Array.from(errors), warnings: [] };
  }

  function enrichData(data) {
    return data.map(d => {
      d.product = d.product || 'TinyEmail';
      d.account_type = d.account_type || 'Non-Major';
      d.isPending = d.spf_status === null;
      d.spfData = validateSPF(d.spf_record);
      d.dmarcData = validateDMARC(d.dmarc_record);
      d.virtual_spf = d.isPending ? 'PENDING' : (d.spfData.errors.length > 0 ? 'ERROR' : 'OK');
      d.virtual_dmarc = d.isPending ? 'PENDING' : (d.dmarcData.errors.length > 0 ? 'ERROR' : 'OK');
      d.virtual_warmup = (d.warmup_em_status?.includes('Match') && d.warmup_send_status?.includes('Match')) ? 'OK' : 'MISSING';
      d.isCritical = d.virtual_spf === 'ERROR' || d.virtual_dmarc === 'ERROR';
      d.isConfig = !d.isCritical && (d.dkim1_status !== 'OK' || d.dkim2_status !== 'OK' || d.bounce_status !== 'Present');
      return d;
    });
  }

  async function init() {
    const response = await fetch(API_URL);
    rawData = enrichData(await response.json());
    applyFiltersAndRender();
  }

  function renderSummary(productData) {
    const container = document.getElementById('dns-summary');
    if (!container) return;
    const crit = productData.filter(d => d.isCritical).length;
    const conf = productData.filter(d => d.isConfig).length;
    container.innerHTML = `
      <div class="stat-card info ${currentFilter === 'all' ? 'active' : ''}" onclick="window.setDnsFilter('all')">
        <span class="stat-label">Total Domains</span>
        <span class="stat-value">${productData.length}</span>
      </div>
      <div class="stat-card danger ${currentFilter === 'critical' ? 'active' : ''}" onclick="window.setDnsFilter('critical')">
        <span class="stat-label">Critical Issues</span>
        <span class="stat-value">${crit}</span>
      </div>
      <div class="stat-card warning ${currentFilter === 'config' ? 'active' : ''}" onclick="window.setDnsFilter('config')">
        <span class="stat-label">Config Issues</span>
        <span class="stat-value">${conf}</span>
      </div>
    `;
  }

  function applyFiltersAndRender() {
    const search = (document.getElementById('domainSearch') as HTMLInputElement)?.value.toLowerCase() || '';
    let data = rawData.filter(d => d.product === currentProduct);
    if (showOnlyMajor) data = data.filter(d => d.account_type === 'Major');
    renderSummary(data);
    let filtered = data.filter(d => d.domain.includes(search));
    if (currentFilter === 'critical') filtered = filtered.filter(d => d.isCritical);
    if (currentFilter === 'config') filtered = filtered.filter(d => d.isConfig);
    renderTable(filtered);
  }

  (window as any).setProductFilter = (p, e) => { currentProduct = p; document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active')); e.currentTarget.classList.add('active'); applyFiltersAndRender(); };
  (window as any).setDnsFilter = (f) => { currentFilter = f; applyFiltersAndRender(); };
  (window as any).toggleMajor = () => { showOnlyMajor = !showOnlyMajor; document.getElementById('btnMajorToggle')?.classList.toggle('active'); applyFiltersAndRender(); };
  (window as any).toggleRow = (d) => { expandedDomain = expandedDomain === d ? null : d; applyFiltersAndRender(); };
  (window as any).copyDomain = (d, b) => { navigator.clipboard.writeText(d); b.innerText = 'Copied!'; setTimeout(() => b.innerText = 'Copy', 2000); };
  (window as any).refreshDomain = async (d, e) => { e.stopPropagation(); await fetch(CHECK_URL + d); await init(); };

  function renderTable(data) {
    const tbody = document.getElementById('tableBody');
    if (!tbody) return;
    tbody.innerHTML = data.map(row => {
      const isExpanded = expandedDomain === row.domain;
      return `
        <tr class="domain-row ${row.isCritical ? 'row-alert' : ''} ${isExpanded ? 'active-row' : ''}" onclick="window.toggleRow('${row.domain}')">
          <td><strong>${row.domain}</strong> ${row.account_type === 'Major' ? '⭐' : ''}</td>
          <td class="center">${getStatusBadge(row.virtual_spf)}</td>
          <td class="center">${getStatusBadge(row.virtual_dmarc)}</td>
          <td class="center">${getSmallIcon(row.dkim1_status)}</td>
          <td class="center">${getSmallIcon(row.dkim2_status)}</td>
          <td class="center">${getSmallIcon(row.bounce_status)}</td>
          <td class="center">${row.virtual_warmup === 'OK' ? '✅' : '—'}</td>
          <td>${new Date(row.last_checked).toLocaleString()}</td>
        </tr>
        ${isExpanded ? `
          <tr class="details-row">
            <td colspan="8">
              <div class="details-content">
                <div class="domain-copy-bar">
                  <span class="large-domain">${row.domain}</span>
                  <button class="btn-copy" onclick="event.stopPropagation(); window.copyDomain('${row.domain}', this)">Copy Domain</button>
                </div>
                <div class="details-grid">
                  <div class="detail-item">
                    <label>SPF:</label>
                    <div class="record-text">${row.spf_record || 'None'}</div>
                  </div>
                  <div class="detail-item">
                    <label>DMARC:</label>
                    <div class="record-text">${row.dmarc_record || 'None'}</div>
                  </div>
                  <div class="detail-item">
                    <label>Technical stack:</label>
                    <div class="cname-list">
                      <div class="${row.dkim1_status === 'OK' ? 'ok' : 'missing'}">DKIM 1: ${row.dkim1_status}</div>
                      <div class="${row.dkim2_status === 'OK' ? 'ok' : 'missing'}">DKIM 2: ${row.dkim2_status}</div>
                      <div class="${row.bounce_status === 'Present' ? 'ok' : 'missing'}">Custom Return-Path: ${row.bounce_status}</div>
                      <div class="${row.virtual_warmup === 'OK' ? 'ok' : 'missing'}">Warmup: ${row.virtual_warmup}</div>
                    </div>
                  </div>
                  <div class="refresh-action">
                    <button class="btn-refresh" onclick="window.refreshDomain('${row.domain}', event)">Re-Check DNS</button>
                  </div>
                </div>
              </div>
            </td>
          </tr>` : ''}
      `;
    }).join('');
  }

  function getStatusBadge(s) {
    const cls = s === 'OK' ? 'badge-green' : (s === 'PENDING' ? 'badge-gray' : 'badge-red');
    return `<span class="badge ${cls}">${s}</span>`;
  }
  function getSmallIcon(s) { return s === 'OK' || s === 'Present' ? '✅' : '❌'; }

  init();
</script>

<style is:global>
  .domains-wrapper { padding: 2rem; max-width: 1400px; margin: 0 auto; color: #1a202c; }
  .content-header h1 { color: #ffffff !important; font-size: 2.2rem; font-weight: 800; }
  
  /* SUMMARY CARDS */
  .summary-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; margin-bottom: 2rem; }
  .stat-card { background: #ffffff !important; padding: 1.5rem; border-radius: 12px; border: 2px solid #e2e8f0; cursor: pointer; transition: 0.2s; }
  .stat-card.active { border-color: #3182ce !important; box-shadow: 0 0 0 2px #3182ce; }
  .stat-label { display: block; font-size: 0.8rem; font-weight: 800; text-transform: uppercase; color: #4a5568 !important; }
  .stat-value { font-size: 2.5rem; font-weight: 900; color: #1a202c !important; }
  .stat-card.danger { border-left: 8px solid #f56565; }
  .stat-card.warning { border-left: 8px solid #ed8936; }

  /* ACTION BAR */
  .table-actions-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; }
  .left-actions { display: flex; gap: 12px; }
  .search-input { width: 350px !important; }
  .btn-major-filter { background: #fff !important; color: #1a202c !important; border: 2px solid #cbd5e0 !important; font-weight: 700; padding: 10px 20px; border-radius: 10px; cursor: pointer; }
  .btn-major-filter.active { background: #fefcbf !important; border-color: #ecc94b !important; }
  .btn-export { background: #2d3748 !important; color: white !important; padding: 10px 20px; border-radius: 10px; border: none; font-weight: 700; cursor: pointer; display: flex; align-items: center; gap: 8px; }

  /* TABLE & DETAILS */
  .table-outer-container { background: #ffffff !important; border-radius: 12px; border: 1px solid #e2e8f0; overflow: hidden; }
  table { width: 100%; border-collapse: collapse; }
  th { background: #f7fafc !important; padding: 15px; text-align: left; font-size: 0.75rem; text-transform: uppercase; border-bottom: 2px solid #e2e8f0; }
  td { padding: 15px; border-bottom: 1px solid #edf2f7; }
  .center { text-align: center; }
  .active-row { background: #f0f7ff !important; }
  
  .details-content { padding: 2rem; background: #f8fafc; border-bottom: 2px solid #cbd5e0; }
  .details-grid { display: grid; grid-template-columns: 1fr 1fr 1fr 200px; gap: 2rem; }
  .record-text { background: #ffffff !important; padding: 1rem; border-radius: 8px; border: 1px solid #cbd5e0; font-family: monospace; font-size: 0.85rem; word-break: break-all; margin-top: 0.5rem; }
  .detail-item label { font-size: 0.7rem; font-weight: 800; text-transform: uppercase; color: #4a5568 !important; }
  
  /* REFRESH BUTTON */
  .refresh-action { align-self: start; }
  .btn-refresh { background: #10b981 !important; color: white !important; border: none; padding: 15px; border-radius: 10px; width: 100%; font-weight: 800; cursor: pointer; }
  .btn-refresh:hover { background: #059669 !important; }

  /* BADGES */
  .badge { padding: 4px 10px; border-radius: 6px; font-weight: 800; font-size: 0.7rem; display: inline-block; }
  .badge-green { background: #c6f6d5; color: #22543d; }
  .badge-red { background: #fed7d7; color: #822727; }
  .badge-gray { background: #edf2f7; color: #4a5568; }

  .cname-list div { font-size: 0.85rem; font-weight: 600; margin-bottom: 5px; padding-left: 20px; position: relative; }
  .cname-list .ok::before { content: '✅'; position: absolute; left: 0; }
  .cname-list .missing::before { content: '❌'; position: absolute; left: 0; }
</style>