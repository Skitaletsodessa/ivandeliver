---
import Layout from '../layouts/Layout.astro';
---

<Layout title="DNS Health Check | ivandeliver.email">
  <main class="domains-wrapper">
    <div class="content-header">
      <div class="title-area">
        <h1>DNS Health Monitor</h1>
        <p>Comprehensive monitoring, validation, and analysis for client domains.</p>
      </div>
    </div>

    <div class="card add-domain-card">
      <div class="add-grid">
        <div class="add-group">
          <label>New Domain</label>
          <input type="text" id="newDomainInput" placeholder="example.com" class="input-field" />
        </div>
        <div class="add-group">
          <label>Product</label>
          <select id="newProductSelect" class="input-field select-custom">
            <option value="TinyEmail">TinyEmail</option>
            <option value="TinyAlbert">TinyAlbert</option>
            <option value="TinyRelay">TinyRelay</option>
          </select>
        </div>
        <div class="add-group">
          <label>Account Type</label>
          <select id="newTypeSelect" class="input-field select-custom">
            <option value="Non-Major">Non-Major</option>
            <option value="Major">Major</option>
          </select>
        </div>
        <button id="addSubmitBtn" class="btn-add-domain" onclick="window.submitNewDomain()">
          Add & Verify
        </button>
      </div>
    </div>

    <div class="product-tabs">
      <button class="tab-btn active" onclick="window.setProductFilter('TinyEmail', event)">TinyEmail</button>
      <button class="tab-btn" onclick="window.setProductFilter('TinyAlbert', event)">TinyAlbert</button>
      <button class="tab-btn" onclick="window.setProductFilter('TinyRelay', event)">TinyRelay</button>
    </div>

    <div id="dns-summary" class="summary-grid"></div>

    <div class="table-actions-bar">
      <div class="left-actions">
        <input type="text" id="domainSearch" placeholder="Filter by domain..." class="input-field search-input" />
        <button id="btnMajorToggle" class="btn-major-filter" onclick="window.toggleMajor()">
          ⭐ Major Only
        </button>
      </div>
      <button class="btn-export" onclick="window.downloadCSV()">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
        Export CSV
      </button>
    </div>

    <div class="card table-outer-container">
      <div class="table-scroll" id="tableContainer">
        <table id="dnsTable">
          <thead>
            <tr>
              <th class="sortable" onclick="window.sortBy('domain')">Domain <span id="sort-domain" class="sort-icon"></span></th>
              <th class="center sortable" onclick="window.sortBy('virtual_spf')">SPF <span id="sort-virtual_spf" class="sort-icon"></span></th>
              <th class="center sortable" onclick="window.sortBy('virtual_dmarc')">DMARC <span id="sort-virtual_dmarc" class="sort-icon"></span></th>
              <th class="center sortable" onclick="window.sortBy('dkim1_status')">DKIM 1 <span id="sort-dkim1_status" class="sort-icon"></span></th>
              <th class="center sortable" onclick="window.sortBy('dkim2_status')">DKIM 2 <span id="sort-dkim2_status" class="sort-icon"></span></th>
              <th class="center sortable" onclick="window.sortBy('bounce_status')">Bounce <span id="sort-bounce_status" class="sort-icon"></span></th>
              <th class="center sortable" onclick="window.sortBy('virtual_warmup')">Warmup <span id="sort-virtual_warmup" class="sort-icon"></span></th>
              <th class="sortable" onclick="window.sortBy('last_checked')">Last Checked <span id="sort-last_checked" class="sort-icon"></span></th>
            </tr>
          </thead>
          <tbody id="tableBody">
            <tr><td colspan="8" style="text-align:center; padding: 40px; color: #1a202c;">Syncing data...</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </main>
</Layout>

<script>
  // Логика скриптов остается без изменений, так как она работала корректно
  const API_URL = 'https://checkdns.skitalets-od.workers.dev/api/domains';
  const IMPORT_URL = 'https://checkdns.skitalets-od.workers.dev/api/import';
  const CHECK_URL = 'https://checkdns.skitalets-od.workers.dev/api/check-domain?domain=';
  
  let rawData = [];
  let currentFilteredData = []; 
  let currentFilter = 'all'; 
  let currentProduct = 'TinyEmail';
  let showOnlyMajor = false; 
  let expandedDomain = null;
  let sortCol = 'default';
  let sortAsc = true;

  (window as any).submitNewDomain = async () => {
    const input = document.getElementById('newDomainInput') as HTMLInputElement;
    const prodSel = document.getElementById('newProductSelect') as HTMLSelectElement;
    const typeSel = document.getElementById('newTypeSelect') as HTMLSelectElement;
    const btn = document.getElementById('addSubmitBtn') as HTMLButtonElement;
    const domain = input.value.trim().toLowerCase();
    if (!domain || !domain.includes('.')) { alert("Please enter a valid domain"); return; }
    btn.disabled = true;
    btn.innerText = '⏳ Processing...';
    try {
      const resImport = await fetch(IMPORT_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify([{ domain, product: prodSel.value, account_type: typeSel.value }])
      });
      if (!resImport.ok) throw new Error("Import failed");
      await fetch(CHECK_URL + domain);
      input.value = '';
      await init(); 
    } catch (e) { alert("Error adding domain"); } finally {
      btn.disabled = false;
      btn.innerText = 'Add & Verify';
    }
  };

  function validateSPF(recordStr) {
    let errors = new Set();
    let warnings = new Set();
    let lookups = 0;
    if (!recordStr) return { errors: ['No SPF record found'], warnings: [], lookups: 0 };
    const records = recordStr.split(' | ');
    const lowerRecordStr = recordStr.toLowerCase();
    if (!lowerRecordStr.includes('include:_spf.tinyemail.com')) { errors.add('Missing required include: _spf.tinyemail.com'); }
    records.forEach(record => {
      const lowerRec = record.trim().toLowerCase();
      if (!lowerRec.startsWith('v=spf1')) errors.add('Must start exactly with "v=spf1"');
      const terms = lowerRec.split(/\s+/);
      let recordLookups = 0;
      terms.forEach(t => {
        if (t === 'a' || t.startsWith('a:') || t === 'mx' || t.startsWith('mx:') || t.startsWith('include:') || t === 'ptr' || t.startsWith('ptr:') || t.startsWith('exists:') || t.startsWith('redirect=')) { recordLookups++; }
      });
      lookups = Math.max(lookups, recordLookups);
    });
    if (lookups > 10) errors.add(`DNS Lookup Limit Exceeded: ${lookups}/10`);
    else if (lookups >= 8) warnings.add(`Approaching DNS Lookup Limit: ${lookups}/10`);
    return { errors: Array.from(errors), warnings: Array.from(warnings), lookups };
  }

  function validateDMARC(recordStr) {
    let errors = new Set();
    let warnings = new Set();
    if (!recordStr) return { errors: ['No DMARC record found'], warnings: [] };
    const records = recordStr.split(' | ');
    records.forEach(record => {
      const lowerRec = record.trim().toLowerCase();
      if (!lowerRec.startsWith('v=dmarc1')) errors.add('Must start exactly with "v=DMARC1"');
      if (!lowerRec.includes('p=')) errors.add('Missing policy tag (e.g., p=none, p=reject)');
    });
    return { errors: Array.from(errors), warnings: Array.from(warnings) };
  }

  function enrichData(data) {
    return data.map(d => {
      d.product = d.product || 'TinyEmail';
      d.account_type = d.account_type || 'Non-Major';
      d.bounce_status = (d.bounce_status === 'OK' || d.bounce_status === 'Present') ? 'Present' : (d.bounce_status === 'MISSING' || !d.bounce_status ? 'None' : d.bounce_status);
      d.warmup_em_status = d.warmup_em_status || 'None';
      d.warmup_send_status = d.warmup_send_status || 'None';
      d.virtual_warmup = (d.warmup_em_status === 'Present and Match' && d.warmup_send_status === 'Present and Match') ? 'OK' : 'MISSING';
      if (d.spf_status === null || d.spf_status === 'null') { d.isPending = true; d.virtual_spf = 'PENDING'; d.virtual_dmarc = 'PENDING'; return d; }
      d.isPending = false;
      d.spfData = validateSPF(d.spf_record);
      d.dmarcData = validateDMARC(d.dmarc_record);
      if (d.spf_status === 'OK') {
        if (d.spfData.errors.length > 0) d.virtual_spf = 'ERROR';
        else if (d.spfData.warnings.length > 0) d.virtual_spf = 'WARNING';
        else d.virtual_spf = 'OK';
      } else { d.virtual_spf = d.spf_status; }
      if (d.dmarc_status === 'OK') {
        if (d.dmarcData.errors.length > 0) d.virtual_dmarc = 'ERROR';
        else if (d.dmarcData.warnings.length > 0) d.virtual_dmarc = 'WARNING';
        else d.virtual_dmarc = 'OK';
      } else { d.virtual_dmarc = d.dmarc_status; }
      d.isCritical = d.virtual_spf !== 'OK' && d.virtual_spf !== 'WARNING' || d.virtual_dmarc !== 'OK' && d.virtual_dmarc !== 'WARNING';
      d.isConfig = !d.isCritical && (d.dkim1_status !== 'OK' || d.dkim2_status !== 'OK' || d.bounce_status !== 'Present');
      return d;
    });
  }

  async function init() {
    try {
      const response = await fetch(API_URL);
      const json = await response.json();
      rawData = enrichData(json);
      applyFiltersAndRender();
      const searchInput = document.getElementById('domainSearch');
      if (searchInput && !searchInput.dataset.listener) { searchInput.addEventListener('input', applyFiltersAndRender); searchInput.dataset.listener = "true"; }
    } catch (err) { console.error("DNS Fetch Error:", err); }
  }

  function updateSortIcons() {
    const cols = ['domain', 'virtual_spf', 'virtual_dmarc', 'dkim1_status', 'dkim2_status', 'bounce_status', 'virtual_warmup', 'last_checked'];
    cols.forEach(c => {
      const el = document.getElementById('sort-' + c);
      const th = el?.parentElement;
      if (el && th) {
        if (sortCol === c) { el.innerHTML = sortAsc ? '↑' : '↓'; el.style.opacity = '1'; th.classList.add('active-sort'); }
        else { el.innerHTML = '↕'; el.style.opacity = '0.3'; th.classList.remove('active-sort'); }
      }
    });
  }

  function renderSummary(productData = []) {
    const container = document.getElementById('dns-summary');
    if (!container) return;
    const criticalCount = productData.filter(d => d.isCritical && !d.isPending).length;
    const configCount = productData.filter(d => d.isConfig && !d.isPending).length;
    const pendingCount = productData.filter(d => d.isPending).length;
    container.innerHTML = `
      <div class="stat-card info ${currentFilter === 'all' ? 'active' : ''}" onclick="window.setDnsFilter('all')">
        <span class="stat-label">${showOnlyMajor ? 'Major ' : ''}${currentProduct} Domains</span>
        <span class="stat-value">${productData.length}</span>
      </div>
      <div class="stat-card danger ${currentFilter === 'critical' ? 'active' : ''}" onclick="window.setDnsFilter('critical')">
        <span class="stat-label">Critical Issues</span>
        <span class="stat-value">${criticalCount}</span>
      </div>
      <div class="stat-card warning ${currentFilter === 'config' ? 'active' : ''}" onclick="window.setDnsFilter('config')">
        <span class="stat-label">Config Issues</span>
        <span class="stat-value">${configCount}</span>
      </div>
      <div class="stat-card pending-card ${currentFilter === 'pending' ? 'active' : ''}" onclick="window.setDnsFilter('pending')">
        <span class="stat-label">Pending Check</span>
        <span class="stat-value">${pendingCount}</span>
      </div>
    `;
  }

  function applyFiltersAndRender() {
    const searchEl = document.getElementById('domainSearch') as HTMLInputElement;
    const searchTerm = searchEl ? searchEl.value.toLowerCase() : '';
    let productData = rawData.filter(d => d.product === currentProduct);
    if (showOnlyMajor) productData = productData.filter(d => d.account_type === 'Major');
    renderSummary(productData);
    let filtered = productData.filter(d => d.domain.toLowerCase().includes(searchTerm));
    if (currentFilter === 'critical') filtered = filtered.filter(d => d.isCritical && !d.isPending);
    else if (currentFilter === 'config') filtered = filtered.filter(d => d.isConfig && !d.isPending);
    else if (currentFilter === 'pending') filtered = filtered.filter(d => d.isPending);
    filtered.sort((a, b) => {
      if (sortCol === 'default') {
        const getWeight = (d) => {
          let w = d.isCritical ? 1000 : (d.isConfig ? 500 : (d.isPending ? -100 : 0));
          if (d.account_type === 'Major') w += 50; return w;
        };
        const diff = getWeight(b) - getWeight(a);
        return diff !== 0 ? diff : a.domain.localeCompare(b.domain);
      } else {
        let valA = a[sortCol] || ''; let valB = b[sortCol] || '';
        if (sortCol === 'last_checked') return sortAsc ? new Date(valA).getTime() - new Date(valB).getTime() : new Date(valB).getTime() - new Date(valA).getTime();
        return sortAsc ? valA.toString().localeCompare(valB.toString()) : valB.toString().localeCompare(valA.toString());
      }
    });
    currentFilteredData = filtered; updateSortIcons(); renderTable(filtered);
  }

  (window as any).sortBy = (col) => { if (sortCol === col) sortAsc = !sortAsc; else { sortCol = col; sortAsc = true; } applyFiltersAndRender(); };
  (window as any).setProductFilter = (prod, event) => { currentProduct = prod; document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active')); event.currentTarget.classList.add('active'); currentFilter = 'all'; sortCol = 'default'; applyFiltersAndRender(); };
  (window as any).toggleMajor = () => { showOnlyMajor = !showOnlyMajor; const btn = document.getElementById('btnMajorToggle'); if (showOnlyMajor) btn?.classList.add('active'); else btn?.classList.remove('active'); applyFiltersAndRender(); };
  (window as any).setDnsFilter = (f) => { currentFilter = f; applyFiltersAndRender(); };
  (window as any).toggleRow = (domain) => { expandedDomain = (expandedDomain === domain) ? null : domain; applyFiltersAndRender(); };
  (window as any).copyDomain = (domain, btn) => { navigator.clipboard.writeText(domain); const ot = btn.innerHTML; btn.innerHTML = '✅ Copied!'; btn.classList.add('copied'); setTimeout(() => { btn.innerHTML = ot; btn.classList.remove('copied'); }, 2000); };
  (window as any).refreshDomain = async (domain, event) => { event.stopPropagation(); const btn = event.currentTarget; btn.innerHTML = '⏳ Checking...'; btn.classList.add('loading'); try { await fetch(CHECK_URL + domain); const response = await fetch(API_URL); rawData = enrichData(await response.json()); applyFiltersAndRender(); } catch (err) { console.error(err); btn.innerHTML = '❌ Error'; btn.classList.remove('loading'); } };
  (window as any).downloadCSV = () => { if (currentFilteredData.length === 0) return; const headers = ['Domain', 'Product', 'Type', 'SPF', 'DMARC', 'DKIM1', 'DKIM2', 'Bounce', 'WarmupEM', 'WarmupSEND', 'LastChecked']; const rows = currentFilteredData.map(d => [d.domain, d.product, d.account_type, d.virtual_spf, d.virtual_dmarc, d.dkim1_status, d.dkim2_status, d.bounce_status, d.warmup_em_status, d.warmup_send_status, d.last_checked]); const csv = [headers.join(','), ...rows.map(r => r.join(','))].join('\n'); const blob = new Blob([csv], { type: 'text/csv' }); const url = URL.createObjectURL(blob); const link = document.createElement('a'); link.href = url; link.download = `dns_report_${new Date().toISOString().split('T')[0]}.csv`; link.click(); };

  function renderTable(data) {
    const tbody = document.getElementById('tableBody'); if (!tbody) return;
    if (data.length === 0) { tbody.innerHTML = `<tr><td colspan="8" style="text-align:center; padding: 20px; color: #1a202c;">No domains found.</td></tr>`; return; }
    let html = '';
    data.forEach(row => {
      const isExpanded = expandedDomain === row.domain;
      const majorBadge = row.account_type === 'Major' ? `<span class="major-badge" title="Major Account">⭐</span>` : '';
      let emClass = row.warmup_em_status === 'Present and Match' ? 'ok' : (row.warmup_em_status === 'Present Mismatch' ? 'error' : (row.isPending ? 'wait' : 'missing'));
      let sendClass = row.warmup_send_status === 'Present and Match' ? 'ok' : (row.warmup_send_status === 'Present Mismatch' ? 'error' : (row.isPending ? 'wait' : 'missing'));
      html += `
        <tr class="domain-row ${row.isCritical ? 'row-alert' : ''} ${isExpanded ? 'active-row' : ''}" onclick="window.toggleRow('${row.domain}')">
          <td class="domain-text"><strong>${row.domain}</strong> ${majorBadge}</td>
          <td class="center">${getStatusBadge(row.virtual_spf)}</td>
          <td class="center">${getStatusBadge(row.virtual_dmarc)}</td>
          <td class="center">${getSmallIcon(row.dkim1_status)}</td>
          <td class="center">${getSmallIcon(row.dkim2_status)}</td>
          <td class="center">${getSmallIcon(row.bounce_status)}</td>
          <td class="center" style="font-weight:bold; color: #4a5568;">${row.virtual_warmup === 'OK' ? '✅' : '—'}</td>
          <td class="date-col">${formatDate(row.last_checked)}</td>
        </tr>
      `;
      if (isExpanded) {
        html += `
          <tr class="details-row">
            <td colspan="8">
              <div class="details-content">
                <div class="domain-copy-bar">
                  <span class="large-domain">${row.domain}</span>
                  <button class="btn-copy" onclick="event.stopPropagation(); window.copyDomain('${row.domain}', this)">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
                    Copy Domain
                  </button>
                  <span class="info-tag product-tag">${row.product}</span>
                  <span class="info-tag type-tag ${row.account_type === 'Major' ? 'major' : ''}">${row.account_type} Account</span>
                </div>
                <div class="details-grid">
                  <div class="detail-item">
                    <label>SPF Records & Validation:</label>
                    <div class="records-container">${renderValidatedRecords(row.spf_record, row.spf_status, row.spfData, 'SPF', row.isPending)}</div>
                  </div>
                  <div class="detail-item">
                    <label>DMARC Records & Validation:</label>
                    <div class="records-container">${renderValidatedRecords(row.dmarc_record, row.dmarc_status, row.dmarcData, 'DMARC', row.isPending)}</div>
                  </div>
                  <div class="detail-item">
                    <label>DKIM & Warmup:</label>
                    <div class="cname-list">
                      <div class="${row.dkim1_status === 'OK' ? 'ok' : 'missing'}">tec1._domainkey: ${row.dkim1_status || '...'}</div>
                      <div class="${row.dkim2_status === 'OK' ? 'ok' : 'missing'}">tec2._domainkey: ${row.dkim2_status || '...'}</div>
                      <div class="${emClass}">em warmup: ${row.warmup_em_status}</div>
                      <div class="${sendClass}">send warmup: ${row.warmup_send_status}</div>
                    </div>
                  </div>
                  <div class="refresh-action">
                    <button class="btn-refresh" onclick="window.refreshDomain('${row.domain}', event)">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M21.5 2v6h-6M21.34 15.57a10 10 0 1 1-.92-10.44l5.08 5.08"/></svg>
                      Re-Check DNS
                    </button>
                  </div>
                </div>
              </div>
            </td>
          </tr>`;
      }
    });
    tbody.innerHTML = html;
  }

  function renderValidatedRecords(recordStr, rawStatus, valData, type, pending) {
    if (pending) return `<div class="record-text gray">⏳ Pending...</div>`;
    if (!recordStr) return `<div class="record-text missing">❌ NO RECORD FOUND</div>`;
    const records = recordStr.split(' | ');
    let html = records.map(rec => `<div class="record-wrapper"><div class="record-text">${rec}</div></div>`).join('');
    html += `<div class="validation-box">`;
    if (valData.errors) valData.errors.forEach(e => html += `<div class="val-msg val-err">❌ ${e}</div>`);
    if (valData.warnings) valData.warnings.forEach(w => html += `<div class="val-msg val-warn">⚠️ ${w}</div>`);
    if ((!valData.errors || valData.errors.length === 0) && (!valData.warnings || valData.warnings.length === 0)) html += `<div class="val-msg val-ok">✅ Valid Syntax & Config</div>`;
    html += `</div>`; return html;
  }

  function getStatusBadge(s) {
    if (s === 'PENDING') return `<span class="badge badge-gray">...</span>`;
    let cls = (s === 'ERROR' || s === 'DUPLICATE' || s === 'MISSING') ? 'badge-red' : (s === 'WARNING' ? 'badge-yellow' : 'badge-green');
    return `<span class="badge ${cls}">${s}</span>`;
  }

  function getSmallIcon(s) { if (s === 'OK' || s === 'Present' || s === 'Present and Match') return '✅'; if (!s || s === 'null' || s === 'PENDING') return '⏳'; return '❌'; }
  function formatDate(d) { if (!d || d.includes('1970')) return '—'; return new Date(d).toLocaleString('cs-CZ', { day: '2-digit', month: '2-digit', hour: '2-digit', minute: '2-digit' }); }

  init();
</script>

<style is:global>
  .domains-wrapper { padding: 2rem; max-width: 1400px; margin: 0 auto; font-family: system-ui, -apple-system, sans-serif; }
  .content-header { margin-bottom: 2rem; }
  .title-area h1 { font-size: 2.25rem; font-weight: 800; color: #ffffff !important; margin: 0; }
  .title-area p { color: #a0aec0 !important; font-size: 1.1rem; margin: 0.5rem 0 0 0; }

  .add-domain-card { margin-bottom: 2rem; padding: 1.5rem !important; background: #ffffff !important; border: 1px solid #cbd5e0; border-radius: 12px; }
  .add-grid { display: flex; gap: 15px; align-items: flex-end; flex-wrap: wrap; }
  .add-group { display: flex; flex-direction: column; gap: 6px; flex: 1; min-width: 180px; }
  .add-group label { font-size: 0.75rem; font-weight: 800; text-transform: uppercase; color: #4a5568 !important; margin-bottom: 4px; display: block; }
  .input-field { padding: 12px 18px; border: 2px solid #cbd5e0 !important; border-radius: 10px; font-weight: 600; background: #ffffff !important; color: #1a202c !important; font-size: 0.95rem; }
  .btn-add-domain { background: #10b981 !important; color: #fff !important; border: none; padding: 12px 24px; border-radius: 10px; font-weight: 700; cursor: pointer; transition: 0.2s; height: 48px; }

  /* ACTION BAR (Исправлено) */
  .table-actions-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; gap: 15px; }
  .left-actions { display: flex; align-items: center; gap: 12px; }
  .search-input { width: 350px !important; }
  .btn-major-filter { background: #ffffff !important; border: 2px solid #cbd5e0 !important; padding: 10px 18px; border-radius: 10px; font-weight: 700; color: #1a202c !important; cursor: pointer; display: flex; align-items: center; gap: 6px; transition: 0.2s; }
  .btn-major-filter.active { border-color: #ecc94b !important; background: #fffff0 !important; color: #975a16 !important; }
  .btn-export { display: flex; align-items: center; gap: 8px; padding: 12px 20px; border-radius: 10px; background: #2d3748 !important; color: #ffffff !important; font-weight: 700; cursor: pointer; border: none; }

  /* СТАТУСЫ (Плашки) */
  .badge { 
    display: inline-block !important; 
    padding: 6px 12px !important; 
    border-radius: 6px !important; 
    font-size: 0.75rem !important; 
    font-weight: 900 !important; 
    text-transform: uppercase !important; 
    min-width: 85px; 
