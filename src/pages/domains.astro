---
import Layout from '../layouts/Layout.astro';
---

<Layout title="DNS Health Check | ivandeliver.email">
  <main class="domains-wrapper">
    <div class="header">
      <div class="title-area">
        <h1>DNS Health Monitor</h1>
        <p>Real-time status of SPF, DMARC, and DKIM for client domains.</p>
      </div>
      <div class="actions-bar">
        <input type="text" id="domainSearch" placeholder="Search domain..." class="input-field" />
        <div class="nav-btns">
          <a href="/monitor" class="btn btn-secondary">SNDS Monitor</a>
        </div>
      </div>
    </div>

    <div id="dns-summary" class="summary-grid">
      </div>

    <div class="card table-outer-container">
      <div class="table-scroll" id="tableContainer">
        <table id="dnsTable">
          <thead>
            <tr>
              <th>Domain</th>
              <th class="center">SPF</th>
              <th class="center">DMARC</th>
              <th class="center">DKIM 1 (tec1)</th>
              <th class="center">DKIM 2 (tec2)</th>
              <th class="center">Bounce</th>
              <th>Last Checked</th>
            </tr>
          </thead>
          <tbody>
            <tr><td colspan="7" style="text-align:center; padding: 40px;">Initializing connection to checkdns...</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </main>
</Layout>

<script>
  const API_URL = 'https://checkdns.skitalets-od.workers.dev/api/domains';
  let rawData = [];

  async function init() {
    try {
      const response = await fetch(API_URL);
      if (!response.ok) throw new Error('API Response Error');
      
      rawData = await response.json();
      processAndRender(rawData);

      document.getElementById('domainSearch')?.addEventListener('input', (e) => {
        const term = e.target.value.toLowerCase();
        const filtered = rawData.filter(d => d.domain.toLowerCase().includes(term));
        processAndRender(filtered);
      });
    } catch (err) {
      console.error("DNS Fetch Error:", err);
      const tbody = document.querySelector('#dnsTable tbody');
      if (tbody) tbody.innerHTML = `<tr><td colspan="7" style="text-align:center; color: red;">Error loading data. Check console.</td></tr>`;
    }
  }

  function processAndRender(data) {
    const sorted = [...data].sort((a, b) => {
      // Логика приоритетов: 
      // 1. SPF/DMARC Issues (RED/YELLOW)
      // 2. DKIM/Bounce Issues
      // 3. OK (Alphabetical)
      
      const getWeight = (item) => {
        if (item.spf_status === 'DUPLICATE' || item.spf_status === 'MISSING') return 100;
        if (item.dmarc_status === 'DUPLICATE' || item.dmarc_status === 'MISSING') return 90;
        if (item.dkim1_status !== 'OK' || item.dkim2_status !== 'OK' || item.bounce_status !== 'OK') return 50;
        return 0;
      };

      const weightA = getWeight(a);
      const weightB = getWeight(b);

      if (weightA !== weightB) return weightB - weightA;
      return a.domain.localeCompare(b.domain);
    });

    renderTable(sorted);
    renderSummary(rawData);
  }

  function renderSummary(data) {
    const container = document.getElementById('dns-summary');
    if (!container) return;

    const critical = data.filter(d => d.spf_status && d.spf_status !== 'OK').length;
    const pending = data.filter(d => !d.last_checked || d.last_checked.includes('1970')).length;

    container.innerHTML = `
      <div class="stat-card info">
        <span class="stat-label">Total List</span>
        <span class="stat-value">${data.length}</span>
      </div>
      <div class="stat-card ${critical > 0 ? 'danger' : 'success'}">
        <span class="stat-label">SPF/DMARC Alerts</span>
        <span class="stat-value">${critical}</span>
      </div>
      <div class="stat-card warning">
        <span class="stat-label">Pending Check</span>
        <span class="stat-value">${pending}</span>
      </div>
    `;
  }

  function renderTable(data) {
    const tbody = document.querySelector('#dnsTable tbody');
    if (!tbody) return;

    if (data.length === 0) {
      tbody.innerHTML = `<tr><td colspan="7" style="text-align:center;">No domains found.</td></tr>`;
      return;
    }

    tbody.innerHTML = data.map(row => {
      const isCritical = row.spf_status !== 'OK' && row.spf_status !== null;
      return `
        <tr class="${isCritical ? 'row-alert' : ''}">
          <td><strong>${row.domain}</strong></td>
          <td class="center">${getStatusBadge(row.spf_status, row.spf_record)}</td>
          <td class="center">${getStatusBadge(row.dmarc_status, row.dmarc_record)}</td>
          <td class="center">${getIcon(row.dkim1_status, 'tec1._domainkey')}</td>
          <td class="center">${getIcon(row.dkim2_status, 'tec2._domainkey')}</td>
          <td class="center">${getIcon(row.bounce_status, 'bounce.')}</td>
          <td class="date-col">${formatDate(row.last_checked)}</td>
        </tr>
      `;
    }).join('');
  }

  function getStatusBadge(status, record) {
    if (status === null || status === 'null') return `<span class="badge badge-gray">PENDING</span>`;
    
    let cls = 'badge-gray';
    if (status === 'OK') cls = 'badge-green';
    if (status === 'DUPLICATE') cls = 'badge-red';
    if (status === 'MISSING') cls = 'badge-yellow';

    const cleanRecord = record ? record.replace(/"/g, '&quot;') : 'Record not found in DNS';
    return `<span class="badge ${cls}" title="${cleanRecord}">${status}</span>`;
  }

  function getIcon(status, type) {
    if (status === 'OK') return `<span class="status-icon green" title="${type} found and valid">✅</span>`;
    if (status === null || status === 'null') return `<span class="status-icon gray" title="Waiting for check...">⏳</span>`;
    return `<span class="status-icon red" title="${type} MISSING">❌</span>`;
  }

  function formatDate(dateStr) {
    if (!dateStr || dateStr.includes('1970')) return '—';
    const date = new Date(dateStr);
    return date.toLocaleString('cs-CZ', { day: '2-digit', month: '2-digit', hour: '2-digit', minute: '2-digit' });
  }

  init();
</script>

<style is:global>
  .domains-wrapper { padding: 2rem; max-width: 1400px; margin: 0 auto; color: #1a202c !important; font-family: system-ui, -apple-system, sans-serif; }
  
  .header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 2rem; gap: 2rem; }
  .title-area h1 { font-size: 2rem; font-weight: 800; color: #ffffff !important; margin: 0; }
  .title-area p { color: #a0aec0 !important; margin: 0.5rem 0 0 0; }

  .actions-bar { display: flex; gap: 1rem; align-items: center; }
  
  .summary-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; margin-bottom: 2rem; }
  .stat-card { background-color: #ffffff !important; padding: 1.25rem; border-radius: 12px; border: 1px solid #cbd5e0; display: flex; flex-direction: column; gap: 0.5rem; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
  
  .stat-label { font-size: 0.75rem; font-weight: 800; text-transform: uppercase; color: #4a5568 !important; letter-spacing: 0.05em; }
  .stat-value { font-size: 1.8rem; font-weight: 900; color: #000000 !important; }
  
  .stat-card.danger { border-left: 6px solid #e53e3e !important; }
  .stat-card.warning { border-left: 6px solid #ed8936 !important; }
  .stat-card.success { border-left: 6px solid #38a169 !important; }
  .stat-card.info { border-left: 6px solid #3182ce !important; }

  /* TABLE STYLES */
  .table-outer-container { background: #ffffff !important; border-radius: 12px; border: 1px solid #cbd5e0; overflow: hidden; }
  .table-scroll { max-height: 70vh; overflow-y: auto; position: relative; }

  table { width: 100%; border-collapse: separate; border-spacing: 0; }
  
  /* STICKY HEADER */
  thead th { 
    position: sticky; 
    top: 0; 
    z-index: 10; 
    background-color: #f7fafc !important; 
    color: #2d3748 !important; 
    font-weight: 800; 
    text-transform: uppercase; 
    font-size: 0.75rem; 
    padding: 16px 12px; 
    border-bottom: 2px solid #cbd5e0;
    text-align: left;
  }

  td { padding: 14px 12px; border-bottom: 1px solid #edf2f7; font-size: 0.95rem; color: #1a202c !important; }
  tr:hover { background-color: #f8fafc; }
  .row-alert { background-color: #fff5f5; }

  .center { text-align: center; }
  .date-col { font-size: 0.8rem; color: #718096 !important; font-weight: 500; }

  /* UI ELEMENTS */
  .badge { padding: 6px 10px; border-radius: 6px; font-size: 0.7rem; font-weight: 900; cursor: help; display: inline-block; }
  .badge-green { background: #c6f6d5; color: #22543d; }
  .badge-yellow { background: #feebc8; color: #744210; }
  .badge-red { background: #fed7d7; color: #822727; }
  .badge-gray { background: #edf2f7; color: #4a5568; }

  .status-icon { font-size: 1.2rem; cursor: help; }

  .input-field { 
    padding: 12px 18px; 
    border: 2px solid #cbd5e0; 
    border-radius: 10px; 
    width: 300px; 
    background: #fff !important; 
    color: #000 !important; 
    font-weight: 600; 
  }
  .input-field:focus { outline: none; border-color: #3182ce; box-shadow: 0 0 0 3px rgba(49, 130, 206, 0.2); }

  .btn { 
    padding: 12px 24px; 
    border-radius: 10px; 
    font-weight: 800; 
    text-decoration: none; 
    display: inline-block;
    transition: all 0.2s;
  }
  .btn-secondary { background: #3182ce; color: #ffffff !important; }
  .btn-secondary:hover { background: #2c5282; transform: translateY(-1px); }
</style>