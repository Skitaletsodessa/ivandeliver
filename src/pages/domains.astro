---
import Layout from '../layouts/Layout.astro';
---

<Layout title="DNS Health Check | ivandeliver.email">
  <main class="domains-wrapper">
    <div class="content-header">
      <div class="title-area">
        <h1>DNS Health Monitor</h1>
        <p>Comprehensive monitoring, validation, and analysis for client domains.</p>
      </div>
    </div>

    <div id="dns-summary" class="summary-grid"></div>

    <div class="table-actions-bar">
      <input type="text" id="domainSearch" placeholder="Filter by domain..." class="input-field" />
    </div>

    <div class="card table-outer-container">
      <div class="table-scroll" id="tableContainer">
        <table id="dnsTable">
          <thead>
            <tr>
              <th>Domain</th>
              <th class="center">SPF</th>
              <th class="center">DMARC</th>
              <th class="center">DKIM 1</th>
              <th class="center">DKIM 2</th>
              <th class="center">Bounce</th>
              <th>Last Checked</th>
            </tr>
          </thead>
          <tbody id="tableBody">
            <tr><td colspan="7" style="text-align:center; padding: 40px; color: #1a202c;">Syncing data...</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </main>
</Layout>

<script>
  const API_URL = 'https://checkdns.skitalets-od.workers.dev/api/domains';
  const CHECK_URL = 'https://checkdns.skitalets-od.workers.dev/api/check-domain?domain=';
  let rawData = [];
  let currentFilter = 'all'; 
  let expandedDomain = null;

  // --- ОБНОВЛЕННЫЕ ВАЛИДАТОРЫ ---
  function validateSPF(recordStr) {
    let errors = new Set(); // Используем Set, чтобы ошибки не дублировались
    let warnings = new Set();
    let lookups = 0;

    if (!recordStr) return { errors: ['No SPF record found'], warnings: [], lookups };

    const records = recordStr.split(' | ');
    const lowerRecordStr = recordStr.toLowerCase();
    
    // Ищем наш include по всей строке, а не в каждой записи отдельно
    if (!lowerRecordStr.includes('include:_spf.tinyemail.com')) {
      errors.add('Missing required include: _spf.tinyemail.com');
    }

    records.forEach(record => {
      const lowerRec = record.trim().toLowerCase();
      
      // Базовый синтаксис
      if (!lowerRec.startsWith('v=spf1')) errors.add('Must start exactly with "v=spf1"');
      if (lowerRec.includes('include=')) errors.add('Typo detected: use "include:" instead of "include="');

      // Подсчет DNS Lookups (a, mx, ptr, include, exists, redirect)
      const terms = lowerRec.split(/\s+/);
      let recordLookups = 0;
      terms.forEach(t => {
        if (t === 'a' || t.startsWith('a:') || 
            t === 'mx' || t.startsWith('mx:') || 
            t.startsWith('include:') || 
            t === 'ptr' || t.startsWith('ptr:') || 
            t.startsWith('exists:') || 
            t.startsWith('redirect=')) {
          recordLookups++;
        }
      });
      lookups = Math.max(lookups, recordLookups); // Берем максимум из дубликатов
    });

    if (lookups > 10) errors.add(`DNS Lookup Limit Exceeded: ${lookups}/10`);
    else if (lookups >= 8) warnings.add(`Approaching DNS Lookup Limit: ${lookups}/10`);

    return { errors: Array.from(errors), warnings: Array.from(warnings), lookups };
  }

  function validateDMARC(recordStr) {
    let errors = new Set();
    let warnings = new Set();
    if (!recordStr) return { errors: ['No DMARC record found'], warnings: [] };

    const records = recordStr.split(' | ');
    records.forEach(record => {
      const lowerRec = record.trim().toLowerCase();
      if (!lowerRec.startsWith('v=dmarc1')) errors.add('Must start exactly with "v=DMARC1"');
      if (!lowerRec.includes('p=')) errors.add('Missing policy tag (e.g., p=none, p=reject)');
      if (lowerRec.includes('p=none') && !lowerRec.includes('rua=')) {
        warnings.add('Policy is "none" but no "rua=" (reporting) is set. Record is inactive.');
      }
    });

    return { errors: Array.from(errors), warnings: Array.from(warnings) };
  }

  function enrichData(data) {
    return data.map(d => {
      if (d.spf_status === null || d.spf_status === 'null') {
        d.isPending = true;
        d.virtual_spf = 'PENDING';
        d.virtual_dmarc = 'PENDING';
        return d;
      }
      
      d.isPending = false;
      d.spfData = validateSPF(d.spf_record);
      d.dmarcData = validateDMARC(d.dmarc_record);

      if (d.spf_status === 'OK') {
        if (d.spfData.errors.length > 0) d.virtual_spf = 'ERROR';
        else if (d.spfData.warnings.length > 0) d.virtual_spf = 'WARNING';
        else d.virtual_spf = 'OK';
      } else {
        d.virtual_spf = d.spf_status;
      }

      if (d.dmarc_status === 'OK') {
        if (d.dmarcData.errors.length > 0) d.virtual_dmarc = 'ERROR';
        else if (d.dmarcData.warnings.length > 0) d.virtual_dmarc = 'WARNING';
        else d.virtual_dmarc = 'OK';
      } else {
        d.virtual_dmarc = d.dmarc_status;
      }

      d.isCritical = d.virtual_spf !== 'OK' && d.virtual_spf !== 'WARNING' || d.virtual_dmarc !== 'OK' && d.virtual_dmarc !== 'WARNING';
      d.isConfig = !d.isCritical && (d.dkim1_status !== 'OK' || d.dkim2_status !== 'OK' || d.bounce_status !== 'OK');

      return d;
    });
  }

  async function init() {
    try {
      const response = await fetch(API_URL);
      const json = await response.json();
      rawData = enrichData(json);
      applyFiltersAndRender();
      document.getElementById('domainSearch')?.addEventListener('input', applyFiltersAndRender);
    } catch (err) { console.error("DNS Fetch Error:", err); }
  }

  function applyFiltersAndRender() {
    const searchTerm = (document.getElementById('domainSearch') as HTMLInputElement)?.value.toLowerCase() || '';
    let filtered = rawData.filter(d => d.domain.toLowerCase().includes(searchTerm));

    if (currentFilter === 'critical') filtered = filtered.filter(d => d.isCritical && !d.isPending);
    else if (currentFilter === 'config') filtered = filtered.filter(d => d.isConfig && !d.isPending);
    else if (currentFilter === 'pending') filtered = filtered.filter(d => d.isPending);

    filtered.sort((a, b) => {
      const getWeight = (d) => d.isCritical ? 100 : (d.isConfig ? 50 : (d.isPending ? -10 : 0));
      const diff = getWeight(b) - getWeight(a);
      return diff !== 0 ? diff : a.domain.localeCompare(b.domain);
    });

    renderTable(filtered);
    renderSummary();
  }

  function renderSummary() {
    const container = document.getElementById('dns-summary');
    if (!container) return;
    const criticalCount = rawData.filter(d => d.isCritical && !d.isPending).length;
    const configCount = rawData.filter(d => d.isConfig && !d.isPending).length;
    const pendingCount = rawData.filter(d => d.isPending).length;

    container.innerHTML = `
      <div class="stat-card info ${currentFilter === 'all' ? 'active' : ''}" onclick="window.setDnsFilter('all')">
        <span class="stat-label">Total Domains</span>
        <span class="stat-value">${rawData.length}</span>
      </div>
      <div class="stat-card danger ${currentFilter === 'critical' ? 'active' : ''}" onclick="window.setDnsFilter('critical')">
        <span class="stat-label">Critical Issues</span>
        <span class="stat-value">${criticalCount}</span>
      </div>
      <div class="stat-card warning ${currentFilter === 'config' ? 'active' : ''}" onclick="window.setDnsFilter('config')">
        <span class="stat-label">Config Issues</span>
        <span class="stat-value">${configCount}</span>
      </div>
      <div class="stat-card pending-card ${currentFilter === 'pending' ? 'active' : ''}" onclick="window.setDnsFilter('pending')">
        <span class="stat-label">Pending Check</span>
        <span class="stat-value">${pendingCount}</span>
      </div>
    `;
  }

  (window as any).setDnsFilter = (f) => { currentFilter = f; applyFiltersAndRender(); };
  (window as any).toggleRow = (domain) => { expandedDomain = (expandedDomain === domain) ? null : domain; applyFiltersAndRender(); };

  (window as any).copyDomain = (domain, btn) => {
    navigator.clipboard.writeText(domain);
    const originalText = btn.innerHTML;
    btn.innerHTML = '✅ Copied!';
    btn.classList.add('copied');
    setTimeout(() => {
      btn.innerHTML = originalText;
      btn.classList.remove('copied');
    }, 2000);
  };

  (window as any).refreshDomain = async (domain, event) => {
    event.stopPropagation();
    const btn = event.currentTarget;
    btn.innerHTML = '⏳ Checking...';
    btn.classList.add('loading');

    try {
      await fetch(CHECK_URL + domain);
      const response = await fetch(API_URL);
      rawData = enrichData(await response.json());
      applyFiltersAndRender();
    } catch (err) {
      console.error(err);
      btn.innerHTML = '❌ Error';
      btn.classList.remove('loading');
    }
  };

  function renderTable(data) {
    const tbody = document.getElementById('tableBody');
    if (!tbody) return;
    if (data.length === 0) {
      tbody.innerHTML = `<tr><td colspan="7" style="text-align:center; padding: 20px; color: #1a202c;">No domains found.</td></tr>`;
      return;
    }
    let html = '';
    data.forEach(row => {
      const isExpanded = expandedDomain === row.domain;
      html += `
        <tr class="domain-row ${row.isCritical ? 'row-alert' : ''} ${isExpanded ? 'active-row' : ''}" onclick="window.toggleRow('${row.domain}')">
          <td class="domain-text"><strong>${row.domain}</strong></td>
          <td class="center">${getStatusBadge(row.virtual_spf)}</td>
          <td class="center">${getStatusBadge(row.virtual_dmarc)}</td>
          <td class="center">${getSmallIcon(row.dkim1_status)}</td>
          <td class="center">${getSmallIcon(row.dkim2_status)}</td>
          <td class="center">${getSmallIcon(row.bounce_status)}</td>
          <td class="date-col">${formatDate(row.last_checked)}</td>
        </tr>
      `;
      if (isExpanded) {
        html += `
          <tr class="details-row">
            <td colspan="7">
              <div class="details-content">
                <div class="domain-copy-bar">
                  <span class="large-domain">${row.domain}</span>
                  <button class="btn-copy" onclick="event.stopPropagation(); window.copyDomain('${row.domain}', this)">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
                    Copy Domain
                  </button>
                </div>
                <div class="details-grid">
                  <div class="detail-item ${row.virtual_spf === 'ERROR' || row.virtual_spf === 'DUPLICATE' ? 'error-block' : ''}">
                    <label>SPF Records & Validation:</label>
                    <div class="records-container">${renderValidatedRecords(row.spf_record, row.spf_status, row.spfData, 'SPF', row.isPending)}</div>
                  </div>
                  <div class="detail-item ${row.virtual_dmarc === 'ERROR' || row.virtual_dmarc === 'DUPLICATE' ? 'error-block' : ''}">
                    <label>DMARC Records & Validation:</label>
                    <div class="records-container">${renderValidatedRecords(row.dmarc_record, row.dmarc_status, row.dmarcData, 'DMARC', row.isPending)}</div>
                  </div>
                  <div class="detail-item">
                    <label>CNAME Configuration:</label>
                    <div class="cname-list">
                      <div class="${row.dkim1_status === 'OK' ? 'ok'