---
import Layout from '../layouts/Layout.astro';
---

<Layout title="DNS Health Check | ivandeliver.email">
  <main class="domains-wrapper">
    <div class="header">
      <div class="title-area">
        <h1>DNS Health Monitor</h1>
        <p>Click rows to see all duplicated or missing records.</p>
      </div>
      <div class="actions-bar">
        <input type="text" id="domainSearch" placeholder="Filter by domain..." class="input-field" />
        <div class="nav-btns">
          <a href="/monitor" class="btn btn-secondary">SNDS Monitor</a>
        </div>
      </div>
    </div>

    <div id="dns-summary" class="summary-grid"></div>

    <div class="card table-outer-container">
      <div class="table-scroll" id="tableContainer">
        <table id="dnsTable">
          <thead>
            <tr>
              <th>Domain</th>
              <th class="center">SPF</th>
              <th class="center">DMARC</th>
              <th class="center">DKIM 1</th>
              <th class="center">DKIM 2</th>
              <th class="center">Bounce</th>
              <th>Last Checked</th>
            </tr>
          </thead>
          <tbody id="tableBody">
            <tr><td colspan="7" style="text-align:center; padding: 40px;">Syncing...</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </main>
</Layout>

<script>
  const API_URL = 'https://checkdns.skitalets-od.workers.dev/api/domains';
  let rawData = [];
  let currentFilter = 'all'; 
  let expandedDomain = null;

  const isPending = (d) => d.spf_status === null || d.spf_status === 'null';
  const isCritical = (d) => !isPending(d) && (d.spf_status !== 'OK' || d.dmarc_status !== 'OK');
  const isConfig = (d) => !isPending(d) && !isCritical(d) && (d.dkim1_status !== 'OK' || d.dkim2_status !== 'OK' || d.bounce_status !== 'OK');

  async function init() {
    try {
      const response = await fetch(API_URL);
      rawData = await response.json();
      applyFiltersAndRender();
      document.getElementById('domainSearch')?.addEventListener('input', applyFiltersAndRender);
    } catch (err) { console.error(err); }
  }

  function applyFiltersAndRender() {
    const searchTerm = (document.getElementById('domainSearch') as HTMLInputElement)?.value.toLowerCase() || '';
    let filtered = rawData.filter(d => d.domain.toLowerCase().includes(searchTerm));

    if (currentFilter === 'critical') filtered = filtered.filter(isCritical);
    else if (currentFilter === 'config') filtered = filtered.filter(isConfig);
    else if (currentFilter === 'pending') filtered = filtered.filter(isPending);

    filtered.sort((a, b) => {
      const getWeight = (d) => isCritical(d) ? 100 : (isConfig(d) ? 50 : (isPending(d) ? -10 : 0));
      const diff = getWeight(b) - getWeight(a);
      return diff !== 0 ? diff : a.domain.localeCompare(b.domain);
    });

    renderTable(filtered);
    renderSummary();
  }

  function renderSummary() {
    const container = document.getElementById('dns-summary');
    if (!container) return;
    const criticalCount = rawData.filter(isCritical).length;
    const configCount = rawData.filter(isConfig).length;
    const pendingCount = rawData.filter(isPending).length;

    container.innerHTML = `
      <div class="stat-card info ${currentFilter === 'all' ? 'active' : ''}" onclick="window.setDnsFilter('all')">
        <span class="stat-label">Total Domains</span>
        <span class="stat-value">${rawData.length}</span>
      </div>
      <div class="stat-card danger ${currentFilter === 'critical' ? 'active' : ''}" onclick="window.setDnsFilter('critical')">
        <span class="stat-label">Critical (SPF/DMARC)</span>
        <span class="stat-value">${criticalCount}</span>
      </div>
      <div class="stat-card warning ${currentFilter === 'config' ? 'active' : ''}" onclick="window.setDnsFilter('config')">
        <span class="stat-label">Config (DKIM/Bounce)</span>
        <span class="stat-value">${configCount}</span>
      </div>
      <div class="stat-card pending-card ${currentFilter === 'pending' ? 'active' : ''}" onclick="window.setDnsFilter('pending')">
        <span class="stat-label">Pending Check</span>
        <span class="stat-value">${pendingCount}</span>
      </div>
    `;
  }

  (window as any).setDnsFilter = (f) => { currentFilter = f; applyFiltersAndRender(); };
  (window as any).toggleRow = (domain) => { expandedDomain = (expandedDomain === domain) ? null : domain; applyFiltersAndRender(); };

  function renderTable(data) {
    const tbody = document.getElementById('tableBody');
    if (!tbody) return;
    let html = '';
    data.forEach(row => {
      const isExpanded = expandedDomain === row.domain;
      html += `
        <tr class="domain-row ${isCritical(row) ? 'row-alert' : ''} ${isExpanded ? 'active-row' : ''}" onclick="window.toggleRow('${row.domain}')">
          <td><strong>${row.domain}</strong></td>
          <td class="center">${getStatusBadge(row.spf_status)}</td>
          <td class="center">${getStatusBadge(row.dmarc_status)}</td>
          <td class="center">${getSmallIcon(row.dkim1_status)}</td>
          <td class="center">${getSmallIcon(row.dkim2_status)}</td>
          <td class="center">${getSmallIcon(row.bounce_status)}</td>
          <td class="date-col">${formatDate(row.last_checked)}</td>
        </tr>
      `;

      if (isExpanded) {
        html += `
          <tr class="details-row">
            <td colspan="7">
              <div class="details-content">
                <div class="details-grid">
                  <div class="detail-item ${row.spf_status !== 'OK' && !isPending(row) ? 'error' : ''}">
                    <label>SPF Records:</label>
                    <div class="records-container">
                      ${renderRecords(row.spf_record, row.spf_status, 'SPF')}
                    </div>
                  </div>
                  <div class="detail-item ${row.dmarc_status !== 'OK' && !isPending(row) ? 'error' : ''}">
                    <label>DMARC Records:</label>
                    <div class="records-container">
                      ${renderRecords(row.dmarc_record, row.dmarc_status, 'DMARC')}
                    </div>
                  </div>
                  <div class="detail-item">
                    <label>CNAME Configuration:</label>
                    <div class="cname-list">
                      <div class="${row.dkim1_status === 'OK' ? 'ok' : 'missing'}">tec1._domainkey: ${row.dkim1_status || 'PENDING'}</div>
                      <div class="${row.dkim2_status === 'OK' ? 'ok' : 'missing'}">tec2._domainkey: ${row.dkim2_status || 'PENDING'}</div>
                      <div class="${row.bounce_status === 'OK' ? 'ok' : 'missing'}">bounce: ${row.bounce_status || 'PENDING'}</div>
                    </div>
                  </div>
                </div>
              </div>
            </td>
          </tr>
        `;
      }
    });
    tbody.innerHTML = html;
  }

  // НОВАЯ ФУНКЦИЯ ДЛЯ ОТОБРАЖЕНИЯ СПИСКА ЗАПИСЕЙ
  function renderRecords(recordStr, status, type) {
    if (!recordStr || recordStr === '') return `<div class="record-text missing">❌ NO ${type} RECORD FOUND</div>`;
    
    // Если есть дубликаты, они разделены через |
    const records = recordStr.split(' | ');
    
    return records.map(rec => `
      <div class="record-wrapper ${status === 'DUPLICATE' ? 'is-duplicate' : ''}">
        <div class="record-text">${rec}</div>
        ${status === 'DUPLICATE' ? `<span class="dup-warn">⚠️ DUPLICATE! REMOVE THIS</span>` : ''}
      </div>
    `).join('');
  }

  function getStatusBadge(s) {
    if (s === null || s === 'null') return `<span class="badge badge-gray">...</span>`;
    let cls = s === 'OK' ? 'badge-green' : (s === 'DUPLICATE' ? 'badge-red' : 'badge-yellow');
    return `<span class="badge ${cls}">${s}</span>`;
  }

  function getSmallIcon(s) {
    if (s === 'OK') return '✅';
    return s === null || s === 'null' ? '⏳' : '❌';
  }

  function formatDate(d) {
    if (!d || d.includes('1970')) return '—';
    return new Date(d).toLocaleString('cs-CZ', { day: '2-digit', month: '2-digit', hour: '2-digit', minute: '2-digit' });
  }

  init();
</script>

<style is:global>
  /* Сохраняем все твои стили из предыдущей версии */
  .domains-wrapper { padding: 2rem; max-width: 1400px; margin: 0 auto; color: #1a202c !important; font-family: system-ui, sans-serif; }
  .header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 2rem; }
  .title-area h1 { font-size: 2rem; font-weight: 800; color: #ffffff !important; margin: 0; }
  .title-area p { color: #a0aec0 !important; }

  .summary-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1rem; margin-bottom: 2rem; }
  .stat-card { background: #fff !important; padding: 1.25rem; border-radius: 12px; border: 1px solid #cbd5e0; cursor: pointer; transition: 0.2s; user-select: none; }
  .stat-card.active { border: 3px solid #3182ce !important; background: #f0f7ff !important; }
  .stat-label { font-size: 0.75rem; font-weight: 800; text-transform: uppercase; color: #4a5568 !important; }
  .stat-value { font-size: 1.8rem; font-weight: 900; color: #000 !important; }
  
  .stat-card.danger { border-left: 6px solid #e53e3e !important; }
  .stat-card.warning { border-left: 6px solid #ed8936 !important; }
  .stat-card.pending-card { border-left: 6px solid #a0aec0 !important; }
  .stat-card.info { border-left: 6px solid #3182ce !important; }

  .table-outer-container { background: #fff !important; border-radius: 12px; border: 1px solid #cbd5e0; overflow: hidden; }
  .table-scroll { max-height: 65vh; overflow-y: auto; }
  table { width: 100%; border-collapse: separate; border-spacing: 0; }
  thead th { position: sticky; top: 0; z-index: 10; background: #f7fafc !important; color: #2d3748 !important; font-weight: 800; text-transform: uppercase; font-size: 0.75rem; padding: 16px 12px; border-bottom: 2px solid #cbd5e0; text-align: left; }
  
  .domain-row { cursor: pointer; }
  .domain-row:hover { background-color: #f7fafc; }
  .domain-row.active-row { background-color: #edf2f7 !important; }
  .row-alert { background-color: #fff5f5; }

  td { padding: 14px 12px; border-bottom: 1px solid #edf2f7; font-size: 0.95rem; color: #1a202c !important; }
  .center { text-align: center; }
  .date-col { font-size: 0.8rem; color: #718096 !important; }

  /* НОВЫЕ СТИЛИ ДЛЯ СПИСКА ЗАПИСЕЙ */
  .details-row td { padding: 0 !important; background-color: #f8fafc; border-bottom: 2px solid #cbd5e0; }
  .details-content { padding: 24px; animation: slideDown 0.2s ease-out; }
  .details-grid { display: grid; grid-template-columns: 1fr 1fr 280px; gap: 24px; }
  
  .detail-item label { display: block; font-size: 0.7rem; font-weight: 800; text-transform: uppercase; color: #4a5568; margin-bottom: 10px; }
  
  .records-container { display: flex; flex-direction: column; gap: 10px; }
  .record-wrapper { position: relative; }
  .record-text { background: #fff; padding: 12px; border-radius: 8px; border: 1px solid #cbd5e0; font-family: monospace; font-size: 0.85rem; word-break: break-all; color: #2d3748; line-height: 1.4; }
  .record-text.missing { color: #e53e3e; font-weight: bold; background: #fff5f5; }

  .is-duplicate .record-text { border-color: #feb2b2; border-left: 4px solid #e53e3e; }
  .dup-warn { display: inline-block; font-size: 10px; font-weight: 900; color: #e53e3e; margin-top: 4px; text-transform: uppercase; }

  .cname-list div { font-size: 0.85rem; font-weight: 600; margin-bottom: 6px; padding-left: 20px; position: relative; }
  .cname-list .ok::before { content: '✅'; position: absolute; left: 0; }
  .cname-list .missing { color: #e53e3e; }
  .cname-list .missing::before { content: '❌'; position: absolute; left: 0; }

  @keyframes slideDown { from { opacity: 0; transform: translateY(-5px); } to { opacity: 1; transform: translateY(0); } }

  .badge { padding: 4px 10px; border-radius: 6px; font-size: 0.7rem; font-weight: 900; }
  .badge-green { background: #c6f6d5; color: #22543d; }
  .badge-red { background: #fed7d7; color: #822727; }
  .badge-yellow { background: #feebc8; color: #744210; }
  .badge-gray { background: #edf2f7; color: #4a5568; }
  
  .input-field { padding: 12px 18px; border: 2px solid #cbd5e0; border-radius: 10px; width: 300px; font-weight: 600; color: #000 !important; background: #fff; }
  .btn { padding: 12px 24px; border-radius: 10px; font-weight: 800; text-decoration: none; display: inline-block; background: #3182ce; color: #fff !important; }
</style>