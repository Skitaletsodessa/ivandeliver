---
import Layout from '../layouts/Layout.astro';
---

<Layout title="IP Inventory | ivandeliver.email">
  <main class="domains-wrapper">
    <nav class="tool-nav">
      <a href="/deliverability" class="nav-link back-link">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
        Hub
      </a>
      <div class="nav-divider"></div>
      <a href="/domains" class="nav-link">DNS Monitor</a>
      <a href="/monitor" class="nav-link">SNDS</a>
      <a href="/postmaster" class="nav-link">GPT</a>
      <a href="/ip-inventory" class="nav-link active">IP Inventory</a>
    </nav>
    <div class="content-header">
      <div class="title-area">
        <h1>Global IP Inventory</h1>
        <p>Unified dashboard mapping Virtual MTAs to Microsoft SNDS status and Google Postmaster reputation.</p>
      </div>
      <div class="header-actions">
        <button class="btn-primary" onclick="window.syncData(this)">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.5 2v6h-6M21.34 15.57a10 10 0 1 1-.92-10.44l5.08 5.08"/></svg>
          Refresh Data
        </button>
      </div>
    </div>

    <div id="inventory-summary"></div>

    <div class="view-tabs">
      <button class="tab-btn active" id="btnViewIps" onclick="window.setView('ips')">IP Addresses</button>
      <button class="tab-btn" id="btnViewSendPools" onclick="window.setView('send-pools')">Send Pools</button>
      <button class="tab-btn" id="btnViewIpPools" onclick="window.setView('ip-pools')">IP Pools</button>
      <button class="tab-btn" id="btnViewThrottles" onclick="window.setView('throttles')">Throttles</button>
    </div>

    <div id="ipsView">
      <div class="table-actions-bar">
        <div class="left-actions" style="display: flex; gap: 15px; align-items: center;">
          <input type="text" id="ipSearch" placeholder="Search Name, IP or Hostname..." class="input-field search-input" />
          
          <div class="multi-select-container" id="poolFilterContainer" style="position: relative; width: 300px;">
            <div class="input-field select-custom" onclick="window.togglePoolDropdown(event)" style="display: flex; justify-content: space-between; align-items: center; user-select: none; cursor: pointer;">
              <span id="poolSelectLabel" style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-weight: 700; color: #2d3748;">🌐 All Pools</span>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
            </div>
            <div id="poolDropdownBody" style="display: none; position: absolute; top: 100%; left: 0; width: 100%; background: #fff; border: 2px solid #cbd5e0; border-radius: 8px; margin-top: 4px; z-index: 100; box-shadow: 0 10px 25px -5px rgba(0,0,0,0.15); overflow: hidden;">
              <div style="padding: 12px; border-bottom: 1px solid #edf2f7; background: #f8fafc;">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px;">
                    <span style="font-size: 0.75rem; font-weight: 800; color: #a0aec0; text-transform: uppercase;">Filter by Pools</span>
                    <button class="btn-micro" onclick="window.clearPoolSelection()">Clear All</button>
                </div>
                <input type="text" id="poolDropdownSearch" placeholder="Find pool..." class="input-field" style="width: 100%; padding: 8px 12px; box-sizing: border-box; font-size: 0.85rem;" oninput="window.filterPoolsList()" />
              </div>
              <div id="poolOptionsList" style="max-height: 300px; overflow-y: auto; padding: 4px 0;"></div>
            </div>
          </div>
        </div>

        <button class="btn-export" onclick="window.downloadCSV()">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
          Export CSV
        </button>
      </div>

      <div class="card table-outer-container">
        <div class="table-scroll">
          <table>
            <thead>
              <tr>
                <th class="sortable" onclick="window.sortBy('ip')">IP Address</th>
                <th class="sortable" onclick="window.sortBy('name')">MTA Name</th>
                <th class="sortable" onclick="window.sortBy('hostname')">Hostname (PTR)</th>
                <th class="center sortable" onclick="window.sortBy('throttling_template')">Throttling Template</th>
                <th>Assigned Pools</th>
                <th class="center sortable" onclick="window.sortBy('snds_filter')">SNDS Status</th>
                <th class="center sortable" onclick="window.sortBy('complaints')">Complaints</th>
                <th class="center sortable" onclick="window.sortBy('traps')">Traps</th>
                <th class="center sortable" onclick="window.sortBy('google_rep')">Google Rep</th>
              </tr>
            </thead>
            <tbody id="tableBody"><tr><td colspan="9" class="center">Loading data...</td></tr></tbody>
          </table>
        </div>
      </div>
    </div>

    <div id="sendPoolsView" style="display: none;">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
        <div style="display: flex; gap: 10px;">
          <button class="btn-micro sp-filter active" id="spf-ALL" onclick="window.setSpFilter('ALL')">All Send Pools</button>
          <button class="btn-micro sp-filter" id="spf-SHARED" onclick="window.setSpFilter('SHARED')">Shared Pools</button>
          <button class="btn-micro sp-filter" id="spf-DEDICATED" onclick="window.setSpFilter('DEDICATED')">Dedicated Pools</button>
          <button class="btn-micro sp-filter" id="spf-STRATEGIC" onclick="window.setSpFilter('STRATEGIC')">Strategic Pools</button>
        </div>
        <label style="display: flex; align-items: center; gap: 8px; font-size: 0.85rem; font-weight: 700; color: #4a5568; cursor: pointer;">
          <input type="checkbox" id="hideIpPoolsToggle" checked onchange="window.toggleHidePureIpPools(this)" style="cursor: pointer;" />
          Hide pure IP Pools (no nested rules)
        </label>
      </div>
      <div class="card table-outer-container">
        <div class="table-scroll">
          <table>
            <thead>
              <tr>
                <th>Send Pool (Routing Rule)</th>
                <th>Domain Overrides</th>
                <th>Default Route (Nested Pools)</th>
                <th class="center">Action</th>
              </tr>
            </thead>
            <tbody id="sendPoolsTableBody"></tbody>
          </table>
        </div>
      </div>
    </div>

    <div id="ipPoolsView" style="display: none;">
      <div class="table-actions-bar">
         <input type="text" id="ipPoolsSearchInput" placeholder="Search Pool Name or IP..." class="input-field search-input" oninput="window.renderIpPoolsView()" />
      </div>
      <div class="card table-outer-container">
        <div class="table-scroll">
          <table>
            <thead>
              <tr>
                <th>IP Pool Name</th>
                <th class="center">IP Count</th>
                <th>Assigned IPs (MTAs)</th>
                <th class="center">Action</th>
              </tr>
            </thead>
            <tbody id="ipPoolsTableBody"></tbody>
          </table>
        </div>
      </div>
    </div>

    <div id="throttlesView" style="display: none;">
      <div class="card table-outer-container" style="padding: 60px 20px; text-align: center;">
         <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#a0aec0" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom: 15px;"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
         <h2 style="color: #2d3748; margin-bottom: 10px;">Throttles Management</h2>
         <p style="color: #718096; max-width: 500px; margin: 0 auto;">Manage max_messages_per_hour, max_concurrent_connections, and Throttling Templates directly from this interface.</p>
      </div>
    </div>

    <dialog id="detailsModal" class="modal" style="max-width: 650px;">
      <div class="modal-content">
        <div class="modal-header">
          <h2 id="modalTitle">MTA Details</h2>
          <button onclick="window.closeModal('detailsModal')" class="close-btn">&times;</button>
        </div>
        <div class="modal-body" id="modalBodyContent"></div>
      </div>
    </dialog>

    <dialog id="sendPoolModal" class="modal" style="max-width: 800px;">
      <div class="modal-content">
        <div class="modal-header">
          <h2 id="sendPoolModalTitle">Send Pool Details</h2>
          <button onclick="window.closeModal('sendPoolModal')" class="close-btn">&times;</button>
        </div>
        <div class="modal-body" id="sendPoolModalBodyContent" style="padding: 1.5rem; background: #edf2f7;"></div>
      </div>
    </dialog>

    <dialog id="ipPoolModal" class="modal" style="max-width: 1000px;">
      <div class="modal-content">
        <div class="modal-header">
          <h2 id="ipPoolModalTitle">IP Pool Details</h2>
          <button onclick="window.closeModal('ipPoolModal')" class="close-btn">&times;</button>
        </div>
        <div class="modal-body" id="ipPoolModalBodyContent" style="max-height: 65vh; overflow-y: auto; padding: 1.5rem;"></div>
      </div>
    </dialog>

  </main>
</Layout>

<script>
  const INVENTORY_URL = 'https://d1-template.skitalets-od.workers.dev/api/inventory';
  const SNDS_URL = 'https://d1-template.skitalets-od.workers.dev/api/data';
  const POSTMASTER_URL = 'https://postmaster-sync.skitalets-od.workers.dev/api/domains';
  
  let enrichedData = [];
  let enrichedRules = []; 
  let currentFilteredData = [];
  let sortCol = 'ip';
  let sortAsc = true;
  let activePools = [];
  let spActiveFilter = 'ALL';
  let hidePureIpPools = true;
  
  let activeFilters = { free: false, gpt: new Set(), snds: new Set() };
  let filterLogicMatch = 'AND'; 

  async function init() {
    try {
      const [invRes, sndsRes, pmRes] = await Promise.all([
        fetch(INVENTORY_URL, { cache: 'no-store' }),
        fetch(SNDS_URL, { cache: 'no-store' }),
        fetch(POSTMASTER_URL, { cache: 'no-store' })
      ]);

      const inventoryPayload = await invRes.json();
      const rawIps = Array.isArray(inventoryPayload) ? inventoryPayload : (inventoryPayload.ips || []);
      const rawRules = Array.isArray(inventoryPayload) ? [] : (inventoryPayload.rules || []);

      const sndsData = await sndsRes.json();
      const pmData = await pmRes.json();

      const googleIpMap = {};
      pmData.forEach(domainRow => {
        if(domainRow.ip_rep_detailed && domainRow.ip_rep_detailed !== '[]') {
          try {
            const reps = JSON.parse(domainRow.ip_rep_detailed);
            reps.forEach(r => {
              if(r.sampleIps) {
                r.sampleIps.forEach(ip => {
                  if(!googleIpMap[ip] || r.reputation === 'BAD' || r.reputation === 'LOW') googleIpMap[ip] = r.reputation;
                });
              }
            });
          } catch(e) {}
        }
      });

      const allPools = new Set();
      enrichedData = rawIps.map(item => {
        let poolsArr = [];
        try { poolsArr = JSON.parse(item.pools || '[]'); } catch(e) {}
        poolsArr = poolsArr.filter(p => p && p !== 'null');
        poolsArr.forEach(p => allPools.add(p));

        const sndsRecord = sndsData.find(s => s.ip === item.ip_address) || {};

        return {
          name: item.name || '',
          ip: item.ip_address || '',
          hostname: item.hostname || '—',
          pools: poolsArr,
          throttling_template: item.throttling_template || '—',
          snds_filter: sndsRecord.filter_result || 'UNKNOWN',
          complaints: sndsRecord.complaints || 0,
          traps: sndsRecord.traps || 0,
          jmr: sndsRecord.jmr_p1_sender || '',
          google_rep: googleIpMap[item.ip_address] || 'UNKNOWN'
        };
      });

      enrichedRules = rawRules.map(r => {
          let raw = {};
          try { raw = JSON.parse(r.raw_json || '{}'); } catch(e) {}
          
          const parseRoute = (deliverThrough) => {
              if (!deliverThrough) return { rules: [], mtas: [] };
              return {
                  rules: deliverThrough.filter(x => x.routing_rule).map(x => ({name: x.routing_rule.name, portion: x.portion_of_mail})),
                  mtas: deliverThrough.filter(x => x.virtual_mta).map(x => ({name: x.virtual_mta.name, portion: x.portion_of_mail}))
              };
          };

          let dt = raw.default?.deliver_through || [];
          let overrides = raw.domain_overrides || [];

          return {
              id: r.id,
              name: r.name,
              randomization_type: raw.default?.randomization_type || 'random',
              default_route: parseRoute(dt),
              domain_overrides: overrides.map(o => ({
                  domain: (o.domains && Array.isArray(o.domains)) ? o.domains.join(', ') : 'Unknown Domain',
                  route: parseRoute(o.deliver_through)
              }))
          };
      });

      populatePoolDropdowns(Array.from(allPools).sort());
      applyFiltersAndRender();
      (window as any).renderSendPoolsView();

      window.addEventListener('hashchange', (window as any).handleHashRouter);
      (window as any).handleHashRouter();

      document.addEventListener('click', (e) => {
        const container = document.getElementById('poolFilterContainer');
        if (container && !container.contains(e.target as Node)) {
          document.getElementById('poolDropdownBody').style.display = 'none';
        }
      });

      const searchInput = document.getElementById('ipSearch');
      if (searchInput) searchInput.addEventListener('input', applyFiltersAndRender);

    } catch (err) {
      console.error("Data Merge Error:", err);
      document.getElementById('tableBody').innerHTML = `<tr><td colspan="9" class="center error-text">Error loading data. Did you update the d1-template worker?</td></tr>`;
    }
  }

  (window as any).handleHashRouter = () => {
      const hash = window.location.hash.substring(1);
      if (!hash) return;
      
      const params = new URLSearchParams(hash);
      if (params.has('mta')) {
          (window as any).setView('ips');
          (window as any).openDetailsModal(params.get('mta'));
      } else if (params.has('ippool')) {
          (window as any).setView('ip-pools');
          (window as any).openIpPoolModal(params.get('ippool'));
      } else if (params.has('sendpool')) {
          (window as any).setView('send-pools');
          (window as any).openSendPoolModal(params.get('sendpool'));
      } else if (params.has('throttle')) {
          (window as any).setView('throttles');
          alert(`Configuration panel for template: "${params.get('throttle')}"\n(UI Implementation pending in next update)`);
      }
  };

  (window as any).closeModal = (id) => {
      document.getElementById(id).close();
      history.replaceState(null, null, ' ');
  };

  (window as any).toggleStatFilter = (category, value) => {
    if (category === 'clear') {
        activeFilters.free = false; activeFilters.gpt.clear(); activeFilters.snds.clear();
    } else if (category === 'free') { activeFilters.free = !activeFilters.free;
    } else if (category === 'gpt') { activeFilters.gpt.has(value) ? activeFilters.gpt.delete(value) : activeFilters.gpt.add(value);
    } else if (category === 'snds') { activeFilters.snds.has(value) ? activeFilters.snds.delete(value) : activeFilters.snds.add(value); }
    (window as any).setView('ips');
    applyFiltersAndRender();
  };

  (window as any).setFilterLogic = (logic) => { filterLogicMatch = logic; applyFiltersAndRender(); };

  function populatePoolDropdowns(pools) {
    const list = document.getElementById('poolOptionsList');
    if (!list) return;
    list.innerHTML = pools.map(pool => `
        <label class="pool-option-label" style="display: flex; align-items: center; padding: 8px 15px; cursor: pointer;">
            <input type="checkbox" class="pool-checkbox" value="${pool}" onchange="window.togglePoolSelection(this)" style="margin-right: 12px; cursor: pointer;" ${activePools.includes(pool) ? 'checked' : ''} />
            <span style="font-size: 0.9rem; color: #2d3748;">${pool}</span>
        </label>
    `).join('');
  }

  (window as any).togglePoolDropdown = () => { const b = document.getElementById('poolDropdownBody'); b.style.display = b.style.display === 'none' ? 'block' : 'none'; };
  (window as any).filterPoolsList = () => {
    const term = (document.getElementById('poolDropdownSearch') as HTMLInputElement).value.toLowerCase();
    document.querySelectorAll('.pool-option-label').forEach(label => {
      (label as HTMLElement).style.display = label.textContent.toLowerCase().includes(term) ? 'flex' : 'none';
    });
  };
  (window as any).togglePoolSelection = (cb) => {
    const val = cb.value;
    if (cb.checked) { if (!activePools.includes(val)) activePools.push(val); } else { activePools = activePools.filter(p => p !== val); }
    updatePoolLabel(); applyFiltersAndRender();
  };
  (window as any).clearPoolSelection = () => { activePools = []; document.querySelectorAll('.pool-checkbox').forEach(cb => (cb as HTMLInputElement).checked = false); updatePoolLabel(); applyFiltersAndRender(); };

  function updatePoolLabel() {
    const label = document.getElementById('poolSelectLabel');
    if (activePools.length === 0) { label.innerHTML = '🌐 All Pools'; label.style.color = '#2d3748'; } 
    else if (activePools.length === 1) { label.innerHTML = `🌐 ${activePools[0]}`; label.style.color = '#3182ce'; } 
    else { label.innerHTML = `🌐 ${activePools.length} Pools Selected`; label.style.color = '#3182ce'; }
  }

  function applyFiltersAndRender() {
    const searchTerm = (document.getElementById('ipSearch') as HTMLInputElement)?.value.toLowerCase() || '';
    let baseFiltered = enrichedData.filter(d => {
      const matchSearch = (d.name||'').toLowerCase().includes(searchTerm) || (d.ip||'').toLowerCase().includes(searchTerm) || (d.hostname||'').toLowerCase().includes(searchTerm);
      const matchPool = activePools.length === 0 ? true : activePools.some(selectedPool => d.pools.includes(selectedPool));
      return matchSearch && matchPool;
    });

    renderSummary(baseFiltered);

    let tableFiltered = baseFiltered.filter(d => {
        if (!activeFilters.free && activeFilters.gpt.size === 0 && activeFilters.snds.size === 0) return true;
        let matches = [];
        if (activeFilters.free) matches.push(d.pools.length === 0);
        if (activeFilters.gpt.size > 0) matches.push(activeFilters.gpt.has(d.google_rep));
        if (activeFilters.snds.size > 0) matches.push(activeFilters.snds.has(d.snds_filter));
        return filterLogicMatch === 'AND' ? matches.every(m => m) : matches.some(m => m);
    });

    tableFiltered.sort((a, b) => {
      if (sortCol === 'ip') return sortAsc ? ipToNumber(a.ip) - ipToNumber(b.ip) : ipToNumber(b.ip) - ipToNumber(a.ip);
      let strA = String(a[sortCol] || '').toLowerCase(); let strB = String(b[sortCol] || '').toLowerCase();
      return sortAsc ? strA.localeCompare(strB) : strB.localeCompare(strA);
    });

    currentFilteredData = tableFiltered;
    renderTable(tableFiltered);
    (window as any).renderIpPoolsView();
  }

  function ipToNumber(ip) { if (!ip) return 0; return ip.split('.').reduce((acc, octet) => (acc << 8) + parseInt(octet, 10), 0) >>> 0; }

  function renderSummary(data) {
    const container = document.getElementById('inventory-summary');
    if (!container) return;
    const getCount = (field, val) => new Set(data.filter(d => d[field] === val).map(d => d.ip)).size;
    const chk = (cat, val) => {
        if (cat === 'clear' && !activeFilters.free && activeFilters.gpt.size === 0 && activeFilters.snds.size === 0) return 'active-filter';
        if (cat === 'free' && activeFilters.free) return 'active-filter';
        if (cat === 'gpt' && activeFilters.gpt.has(val)) return 'active-filter';
        if (cat === 'snds' && activeFilters.snds.has(val)) return 'active-filter';
        return '';
    };

    container.innerHTML = `
      <div class="summary-row-1">
          <div class="stat-card info ${chk('clear')}" onclick="window.toggleStatFilter('clear')">
              <span class="stat-label">Total Physical IPs</span><span class="stat-value">${new Set(data.map(d => d.ip)).size}</span>
          </div>
          <div class="stat-card warning ${chk('free')}" onclick="window.toggleStatFilter('free')">
              <span class="stat-label">Free IPs (No Pools)</span><span class="stat-value">${new Set(data.filter(d => d.pools.length === 0).map(d => d.ip)).size}</span>
          </div>
          <div class="stat-card info" onclick="window.setView('ip-pools')" style="background: #f8fafc !important;">
              <span class="stat-label">Total IP Pools</span><span class="stat-value">${new Set(data.flatMap(d => d.pools)).size} <span style="font-size:1rem; color:#a0aec0;">↗</span></span>
          </div>
          <div class="stat-card info" onclick="window.setView('throttles')" style="background: #f8fafc !important;">
              <span class="stat-label">Total Throttles</span><span class="stat-value">${new Set(data.map(d => d.throttling_template).filter(t => t && t !== '—')).size} <span style="font-size:1rem; color:#a0aec0;">↗</span></span>
          </div>
      </div>
      <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 0.75rem; margin-top: 1.5rem;">
          <span style="font-size: 0.85rem; font-weight: 800; color: #4a5568; text-transform: uppercase;">Reputation Filters</span>
          <div style="display: flex; align-items: center; gap: 4px; background: #e2e8f0; padding: 4px; border-radius: 8px;">
              <span style="font-size: 0.7rem; font-weight: 800; color: #718096; padding-left: 6px; text-transform: uppercase; margin-right: 4px;">Match:</span>
              <button class="toggle-btn ${filterLogicMatch === 'AND' ? 'active' : ''}" onclick="window.setFilterLogic('AND')">AND</button>
              <button class="toggle-btn ${filterLogicMatch === 'OR' ? 'active' : ''}" onclick="window.setFilterLogic('OR')">OR</button>
          </div>
      </div>
      <div class="summary-row-2">
          <div class="stat-card small-card ${chk('gpt', 'HIGH')}" onclick="window.toggleStatFilter('gpt', 'HIGH')" style="border-left: 4px solid #48bb78 !important;"><span class="stat-label">GPT High</span><span class="stat-value">${getCount('google_rep', 'HIGH')}</span></div>
          <div class="stat-card small-card ${chk('gpt', 'MEDIUM')}" onclick="window.toggleStatFilter('gpt', 'MEDIUM')" style="border-left: 4px solid #ecc94b !important;"><span class="stat-label">GPT Medium</span><span class="stat-value">${getCount('google_rep', 'MEDIUM')}</span></div>
          <div class="stat-card small-card ${chk('gpt', 'LOW')}" onclick="window.toggleStatFilter('gpt', 'LOW')" style="border-left: 4px solid #ed8936 !important;"><span class="stat-label">GPT Low</span><span class="stat-value">${getCount('google_rep', 'LOW')}</span></div>
          <div class="stat-card small-card ${chk('gpt', 'BAD')}" onclick="window.toggleStatFilter('gpt', 'BAD')" style="border-left: 4px solid #e53e3e !important;"><span class="stat-label">GPT Bad</span><span class="stat-value">${getCount('google_rep', 'BAD')}</span></div>
          <div class="stat-card small-card ${chk('snds', 'GREEN')}" onclick="window.toggleStatFilter('snds', 'GREEN')" style="border-left: 4px solid #48bb78 !important;"><span class="stat-label">SNDS Green</span><span class="stat-value">${getCount('snds_filter', 'GREEN')}</span></div>
          <div class="stat-card small-card ${chk('snds', 'YELLOW')}" onclick="window.toggleStatFilter('snds', 'YELLOW')" style="border-left: 4px solid #ecc94b !important;"><span class="stat-label">SNDS Yellow</span><span class="stat-value">${getCount('snds_filter', 'YELLOW')}</span></div>
