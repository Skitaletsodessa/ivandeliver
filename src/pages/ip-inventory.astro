  (window as any).setSpFilter = (val) => { 
      spActiveFilter = val; 
      document.querySelectorAll('.sp-filter').forEach(btn => btn.classList.remove('active'));
      document.getElementById(`spf-${val}`).classList.add('active');
      
      if (val !== 'ALL') {
         hidePureIpPools = false;
         (document.getElementById('hideIpPoolsToggle') as HTMLInputElement).checked = false;
      }
      
      (window as any).renderSendPoolsView(); 
