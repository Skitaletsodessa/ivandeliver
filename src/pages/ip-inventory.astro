---
import Layout from '../layouts/Layout.astro';
---

<Layout title="IP Inventory | ivandeliver.email">
  <main class="domains-wrapper">
  <nav class="tool-nav">
      <a href="/deliverability" class="nav-link back-link">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
        Hub
      </a>
      <div class="nav-divider"></div>
      <a href="/domains" class="nav-link">DNS Monitor</a>
      <a href="/monitor" class="nav-link">SNDS</a>
      <a href="/postmaster" class="nav-link">GPT</a>
      <a href="/ip-inventory" class="nav-link active">IP Inventory</a> </nav>
    <div class="content-header">
      <div class="title-area">
        <h1>Global IP Inventory</h1>
        <p>Unified dashboard mapping IP pools to Microsoft SNDS status and Google Postmaster reputation.</p>
      </div>
      <div class="header-actions">
        <button class="btn-primary" onclick="window.syncData(this)">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.5 2v6h-6M21.34 15.57a10 10 0 1 1-.92-10.44l5.08 5.08"/></svg>
          Refresh Data
        </button>
      </div>
    </div>

    <div class="summary-grid" id="inventory-summary">
      </div>

    <div class="view-tabs">
      <button class="tab-btn active" id="btnViewIps" onclick="window.setView('ips')">IP Addresses</button>
      <button class="tab-btn" id="btnViewPools" onclick="window.setView('pools')">Pools Management</button>
    </div>

    <div id="ipsView">
      <div class="table-actions-bar">
        <div class="left-actions" style="display: flex; gap: 15px; align-items: center;">
          <input type="text" id="ipSearch" placeholder="Search IP, Host or Pool..." class="input-field search-input" />
          
          <select id="poolFilter" class="input-field select-custom" style="width: 250px;">
            <option value="ALL">🌐 All Pools</option>
          </select>
        </div>
        
        <button class="btn-export" onclick="window.downloadCSV()">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
          Export CSV
        </button>
      </div>

      <div class="card table-outer-container">
        <div class="table-scroll">
          <table>
            <thead>
              <tr>
			    <th class="sortable" onclick="window.sortBy('name')">MTA Name</th>
                <th class="sortable" onclick="window.sortBy('ip')">IP Address</th>
                <th class="sortable" onclick="window.sortBy('hostname')">Hostname (PTR)</th>
				<th class="center sortable" onclick="window.sortBy('throttling_template')">Throttling Template</th>
                <th>Assigned Pools</th>
                <th class="center sortable" onclick="window.sortBy('snds_filter')">SNDS Status</th>
                <th class="center sortable" onclick="window.sortBy('complaints')">Complaints</th>
                <th class="center sortable" onclick="window.sortBy('traps')">Traps</th>
                <th class="center sortable" onclick="window.sortBy('google_rep')">Google Rep</th>
              </tr>
            </thead>
            <tbody id="tableBody">
              <tr><td colspan="7" class="center" style="padding: 40px; color: #a0aec0;">Fetching data from SNDS and Postmaster...</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <div id="poolsView" style="display: none;">
      <div class="card table-outer-container">
        <div class="table-scroll">
          <table>
            <thead>
              <tr>
                <th>Pool Name</th>
                <th class="center">IP Count</th>
                <th>Assigned IP Addresses</th>
                <th class="center">Action</th>
              </tr>
            </thead>
            <tbody id="poolsTableBody">
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <dialog id="editIpModal" class="modal">
      <div class="modal-content">
        <div class="modal-header">
          <h2 id="editModalTitle">Edit IP Configuration</h2>
          <button onclick="document.getElementById('editIpModal').close()" class="close-btn">&times;</button>
        </div>
        <div class="modal-body">
          <form id="editIpForm" onsubmit="window.saveIpChanges(event)">
            <input type="hidden" id="editIpAddress" />
            
            <div class="form-group">
              <label>Hostname (PTR)</label>
              <input type="text" id="editHostname" class="input-field" style="width: 100%; box-sizing: border-box;" />
            </div>

           <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-top: 15px;">
              <div class="form-group">
                <label>Pool 1 <span style="color: #a0aec0; font-weight: normal; text-transform: none;">(Auto-synced)</span></label>
                <input type="text" id="editPool1" list="poolList" class="input-field" style="width: 100%; box-sizing: border-box; background: #edf2f7 !important; cursor: not-allowed; color: #718096 !important;" disabled title="Pools are managed automatically via GreenArrow" />
              </div>
              <div class="form-group">
                <label>Pool 2 <span style="color: #a0aec0; font-weight: normal; text-transform: none;">(Auto-synced)</span></label>
                <input type="text" id="editPool2" list="poolList" class="input-field" style="width: 100%; box-sizing: border-box; background: #edf2f7 !important; cursor: not-allowed; color: #718096 !important;" disabled title="Pools are managed automatically via GreenArrow" />
              </div>
              <div class="form-group">
                <label>Pool 3 <span style="color: #a0aec0; font-weight: normal; text-transform: none;">(Auto-synced)</span></label>
                <input type="text" id="editPool3" list="poolList" class="input-field" style="width: 100%; box-sizing: border-box; background: #edf2f7 !important; cursor: not-allowed; color: #718096 !important;" disabled title="Pools are managed automatically via GreenArrow" />
              </div>
              <div class="form-group">
                <label>Pool 4 <span style="color: #a0aec0; font-weight: normal; text-transform: none;">(Auto-synced)</span></label>
                <input type="text" id="editPool4" list="poolList" class="input-field" style="width: 100%; box-sizing: border-box; background: #edf2f7 !important; cursor: not-allowed; color: #718096 !important;" disabled title="Pools are managed automatically via GreenArrow" />
              </div>
            </div>

            <datalist id="poolList"></datalist>

            <button type="submit" class="btn-primary btn-block" style="margin-top: 20px; padding: 14px;">
              Save Configuration
            </button>
          </form>
        </div>
      </div>
    </dialog>

  </main>
</Layout>

<script>
  const INVENTORY_URL = 'https://d1-template.skitalets-od.workers.dev/api/inventory';
  const IMPORT_URL = 'https://d1-template.skitalets-od.workers.dev/api/import-ips';
  const SNDS_URL = 'https://d1-template.skitalets-od.workers.dev/api/data';
  const POSTMASTER_URL = 'https://postmaster-sync.skitalets-od.workers.dev/api/domains';
  const GA_PULL_URL = 'https://ga-manager.skitalets-od.workers.dev/api/pull-mta';
  
  let enrichedData = [];
  let currentFilteredData = [];
  
  let sortCol = 'ip';
  let sortAsc = true;
  let activePool = 'ALL';
  let activeStatFilter = 'ALL';

  async function init() {
    try {
      const [invRes, sndsRes, pmRes] = await Promise.all([
        fetch(INVENTORY_URL),
        fetch(SNDS_URL),
        fetch(POSTMASTER_URL)
      ]);

      const inventory = await invRes.json();
      const sndsData = await sndsRes.json();
      const pmData = await pmRes.json();

      const googleIpMap = {};
      pmData.forEach(domainRow => {
        if(domainRow.ip_rep_detailed && domainRow.ip_rep_detailed !== '[]') {
          try {
            const reps = JSON.parse(domainRow.ip_rep_detailed);
            reps.forEach(r => {
              if(r.sampleIps) {
                r.sampleIps.forEach(ip => {
                  if(!googleIpMap[ip] || r.reputation === 'BAD' || r.reputation === 'LOW') {
                    googleIpMap[ip] = r.reputation;
                  }
                });
              }
            });
          } catch(e) {}
        }
      });

      const allPools = new Set();

      enrichedData = inventory.map(item => {
        let poolsArr = [];
        try { poolsArr = JSON.parse(item.pools || '[]'); } catch(e) {}
        poolsArr.forEach(p => allPools.add(p));

        const sndsRecord = sndsData.find(s => s.ip === item.ip_address) || {};

        return {
          name: item.name,
          ip: item.ip_address, 
          hostname: item.hostname || '—',
          pools: poolsArr,
          throttling_template: item.throttling_template || '—',
          snds_filter: sndsRecord.filter_result || 'UNKNOWN',
          complaints: sndsRecord.complaints || 0,
          traps: sndsRecord.traps || 0,
          jmr: sndsRecord.jmr_p1_sender || '',
          google_rep: googleIpMap[item.ip_address] || 'UNKNOWN',
          snds_date: sndsRecord.date || null
        };
      });

      populatePoolDropdowns(Array.from(allPools).sort());
      applyFiltersAndRender();
      
      document.getElementById('ipSearch')?.addEventListener('input', applyFiltersAndRender);
      document.getElementById('poolFilter')?.addEventListener('change', (e) => {
        activePool = (e.target as HTMLSelectElement).value;
        applyFiltersAndRender();
      });

    } catch (err) {
      console.error("Data Merge Error:", err);
      document.getElementById('tableBody').innerHTML = `<tr><td colspan="7" class="center error-text" style="color:#e53e3e;">Error compiling inventory data. Check console.</td></tr>`;
    }
  }

  function populatePoolDropdowns(pools) {
    const select = document.getElementById('poolFilter');
    const dataList = document.getElementById('poolList');
    if (!select || !dataList) return;
    
    select.innerHTML = '<option value="ALL">🌐 All Pools</option>';
    dataList.innerHTML = '';

    pools.forEach(pool => {
      select.innerHTML += `<option value="${pool}">${pool}</option>`;
      dataList.innerHTML += `<option value="${pool}">`;
    });
  }

  function applyFiltersAndRender() {
    const searchTerm = (document.getElementById('ipSearch') as HTMLInputElement)?.value.toLowerCase() || '';
    
    let searchFiltered = enrichedData.filter(d => {
      const matchSearch = d.ip.toLowerCase().includes(searchTerm) || 
                          d.name.toLowerCase().includes(searchTerm) ||
                          d.hostname.toLowerCase().includes(searchTerm) ||
                          d.pools.some(p => p.toLowerCase().includes(searchTerm));
                          
      const matchPool = activePool === 'ALL' ? true : d.pools.includes(activePool);
      return matchSearch && matchPool;
    });

    renderSummary(searchFiltered);

    let tableFiltered = searchFiltered.filter(d => {
      if (activeStatFilter === 'ALL') return true;
      if (activeStatFilter === 'RED') return d.snds_filter === 'RED';
      if (activeStatFilter === 'TRAPS') return d.traps > 0;
      if (activeStatFilter === 'GOOGLE_BAD') return d.google_rep === 'BAD' || d.google_rep === 'LOW';
      return true;
    });

    tableFiltered.sort((a, b) => {
      let valA = a[sortCol];
      let valB = b[sortCol];

      if (typeof valA === 'number' && typeof valB === 'number') {
        return sortAsc ? valA - valB : valB - valA;
      }
      
      if (sortCol === 'ip') {
        const numA = ipToNumber(a.ip);
        const numB = ipToNumber(b.ip);
        return sortAsc ? numA - numB : numB - numA;
      }

      let strA = String(valA).toLowerCase();
      let strB = String(valB).toLowerCase();
      if (strA < strB) return sortAsc ? -1 : 1;
      if (strA > strB) return sortAsc ? 1 : -1;
      return 0;
    });

    currentFilteredData = tableFiltered;
    renderTable(tableFiltered);
    renderPoolsView(searchFiltered);
  }

  function ipToNumber(ip) {
    if (!ip) return 0;
    return ip.split('.').reduce((acc, octet) => (acc << 8) + parseInt(octet, 10), 0) >>> 0;
  }

  function renderSummary(data) {
    const container = document.getElementById('inventory-summary');
    if (!container) return;
    
    const total = data.length;
    const sndsRed = data.filter(d => d.snds_filter === 'RED').length;
    const trapCount = data.filter(d => d.traps > 0).length;
    const googleBad = data.filter(d => d.google_rep === 'BAD' || d.google_rep === 'LOW').length;

    const getActiveCls = (filter) => activeStatFilter === filter ? 'active-filter' : '';

    container.innerHTML = `
      <div class="stat-card info ${getActiveCls('ALL')}" onclick="window.setStatFilter('ALL')">
        <span class="stat-label">Total MTAs</span>
        <span class="stat-value">${total}</span>
      </div>
      <div class="stat-card ${sndsRed > 0 ? 'danger' : 'success'} ${getActiveCls('RED')}" onclick="window.setStatFilter('RED')">
        <span class="stat-label">SNDS: Red Status</span>
        <span class="stat-value">${sndsRed}</span>
      </div>
      <div class="stat-card ${trapCount > 0 ? 'warning' : 'success'} ${getActiveCls('TRAPS')}" onclick="window.setStatFilter('TRAPS')">
        <span class="stat-label">Hitting Traps</span>
        <span class="stat-value">${trapCount}</span>
      </div>
      <div class="stat-card ${googleBad > 0 ? 'danger-light' : 'success'} ${getActiveCls('GOOGLE_BAD')}" onclick="window.setStatFilter('GOOGLE_BAD')">
        <span class="stat-label">Google: Bad/Low</span>
        <span class="stat-value">${googleBad}</span>
      </div>
    `;
  }

  function renderTable(data) {
    const tbody = document.getElementById('tableBody');
    if (!tbody) return;
    
    if (data.length === 0) {
      tbody.innerHTML = `<tr><td colspan="9" class="center" style="padding: 20px;">No IP addresses match your filters.</td></tr>`;
      return;
    }

    let html = '';
    data.forEach(row => {
      const poolBadges = row.pools.length > 0 
        ? row.pools.map(p => `<span class="pool-tag">${p}</span>`).join(' ')
        : `<span class="text-gray">—</span>`;

      const isCritical = row.snds_filter === 'RED' || row.google_rep === 'BAD' || row.traps > 0;

      html += `
       <tr class="domain-row ${isCritical ? 'row-alert' : ''}" title="Managed via GreenArrow">
          <td class="domain-text"><strong>${row.name}</strong></td>
          <td style="font-family: monospace; font-size: 0.9rem;">${row.ip}</td>
          <td style="font-family: monospace; font-size: 0.85rem; color: #4a5568;">${row.hostname}</td>
          <td class="center"><span class="badge badge-gray" style="font-size: 0.8rem;">${row.throttling_template}</span></td>
          <td><div class="pools-container">${poolBadges}</div></td>
          <td class="center">${formatSNDS(row.snds_filter)}</td>
          <td class="center" style="${row.complaints > 0.3 ? 'color:#e53e3e; font-weight:bold;' : ''}">${row.complaints}%</td>
          <td class="center" style="${row.traps > 0 ? 'color:#e53e3e; font-weight:bold;' : ''}">${row.traps > 0 ? '🚨 ' + row.traps : '0'}</td>
          <td class="center">${formatGoogleRep(row.google_rep)}</td>
        </tr>
      `;
    });
    tbody.innerHTML = html;
  }

  function renderPoolsView(data) {
    const poolMap = {};
    
    data.forEach(d => {
      d.pools.forEach(p => {
        if(!poolMap[p]) poolMap[p] = [];
        poolMap[p].push(d.name + ` (${d.ip})`);
      });
    });

    const tbody = document.getElementById('poolsTableBody');
    if (!tbody) return;

    let html = '';
    Object.keys(poolMap).sort().forEach(poolName => {
      const ips = poolMap[poolName];
      html += `
        <tr class="domain-row">
          <td><strong style="font-size: 1.1rem; color: #2d3748;">${poolName}</strong></td>
          <td class="center"><span class="badge badge-gray" style="font-size: 0.9rem;">${ips.length} MTAs</span></td>
          <td style="font-family: monospace; font-size: 0.85rem; color: #4a5568; line-height: 1.5;">${ips.join(', ')}</td>
          <td class="center">
            <button class="btn-export" style="padding: 6px 12px; font-size: 0.8rem; background: #3182ce;" onclick="window.jumpToPool('${poolName}')">
              Manage IPs
            </button>
          </td>
        </tr>
      `;
    });
    
    if (html === '') html = `<tr><td colspan="4" class="center" style="padding: 20px;">No pools found.</td></tr>`;
    tbody.innerHTML = html;
  }

  function formatSNDS(status) {
    if (!status || status === 'UNKNOWN') return `<span class="badge badge-gray">UNKNOWN</span>`;
    let cls = 'badge-green';
    if (status === 'YELLOW') cls = 'badge-yellow';
    if (status === 'RED') cls = 'badge-red';
    return `<span class="badge ${cls}">${status}</span>`;
  }

  function formatGoogleRep(rep) {
    if (!rep || rep === 'UNKNOWN') return `<span class="badge badge-gray">UNKNOWN</span>`;
    let cls = 'badge-gray';
    if (rep === 'HIGH') cls = 'badge-green';
    if (rep === 'MEDIUM') cls = 'badge-yellow';
    if (rep === 'LOW' || rep === 'BAD') cls = 'badge-red';
    return `<span class="badge ${cls}">${rep}</span>`;
  }

  (window as any).sortBy = (col) => {
    if (sortCol === col) sortAsc = !sortAsc;
    else { sortCol = col; sortAsc = true; }
    applyFiltersAndRender();
  };

  (window as any).setStatFilter = (filter) => {
    activeStatFilter = filter;
    applyFiltersAndRender();
  };

  (window as any).setView = (viewName) => {
    document.getElementById('ipsView').style.display = viewName === 'ips' ? 'block' : 'none';
    document.getElementById('poolsView').style.display = viewName === 'pools' ? 'block' : 'none';
    
    document.getElementById('btnViewIps').classList.toggle('active', viewName === 'ips');
    document.getElementById('btnViewPools').classList.toggle('active', viewName === 'pools');
  };

  (window as any).jumpToPool = (poolName) => {
    activePool = poolName;
    (document.getElementById('poolFilter') as HTMLSelectElement).value = poolName;
    activeStatFilter = 'ALL';
    (window as any).setView('ips');
    applyFiltersAndRender();
  };

  (window as any).openEditModal = (ip) => {
    // Временно отключено, так как теперь всем управляет GreenArrow
    alert("Configurations are now automatically synced from GreenArrow and cannot be edited manually.");
  };

  (window as any).syncData = async (btn) => {
    const originalText = btn.innerHTML;
    btn.disabled = true;

    try {
      btn.innerHTML = '⏳ 1/4: Fetching GA Lists...';
      
      const listRes = await fetch('https://ga-manager.skitalets-od.workers.dev/api/ga-list');
      const lists = await listRes.json();
      const ruleIds = lists.rules.map(r => r.id);
      const ipIds = lists.ips.map(r => r.id);

      const detailedRules = [];
      const chunkSize = 20;
      for (let i = 0; i < ruleIds.length; i += chunkSize) {
        btn.innerHTML = `⏳ 2/4: Syncing Pools (${Math.min(i + chunkSize, ruleIds.length)}/${ruleIds.length})...`;
        const chunk = ruleIds.slice(i, i + chunkSize);
        const res = await fetch('https://ga-manager.skitalets-od.workers.dev/api/ga-details', {
          method: 'POST', body: JSON.stringify({ type: 'routing_rules', ids: chunk })
        });
        detailedRules.push(...(await res.json()));
      }

      const mtaNameToPools = {};
      detailedRules.forEach(res => {
        if(!res || !res.success) return;
        const rule = res.data?.routing_rule;
        if (!rule) return;
        const poolName = rule.name;
        
        const deliverThrough = rule.default?.deliver_through || [];
        deliverThrough.forEach(dt => {
          const mtaName = dt.virtual_mta?.name;
          if (mtaName) {
            if (!mtaNameToPools[mtaName]) mtaNameToPools[mtaName] = [];
            if (!mtaNameToPools[mtaName].includes(poolName)) mtaNameToPools[mtaName].push(poolName);
          }
        });
      });

      const updatePayload = [];

      for (let i = 0; i < ipIds.length; i += chunkSize) {
        btn.innerHTML = `⏳ 3/4: Syncing MTAs (${Math.min(i + chunkSize, ipIds.length)}/${ipIds.length})...`;
        const chunk = ipIds.slice(i, i + chunkSize);
        const res = await fetch('https://ga-manager.skitalets-od.workers.dev/api/ga-details', {
          method: 'POST', body: JSON.stringify({ type: 'ip_addresses', ids: chunk })
        });
        const data = await res.json();

        data.forEach(res => {
          if(!res || !res.success) return;
          const ipData = res.data?.ip_address;
          if (!ipData || !ipData.ip || !ipData.name) return;

          const mtaName = ipData.name;
          const pools = mtaNameToPools[mtaName] || [];

          updatePayload.push({
            name: mtaName,
            ip_address: ipData.ip,
            hostname: ipData.hostname || '—',
            pools: JSON.stringify(pools),
            throttling_template: ipData.throttling_template?.name || ''
          });
        });
      }

      btn.innerHTML = `⏳ 4/4: Saving to Database...`;
      await fetch('https://ga-manager.skitalets-od.workers.dev/api/update-inventory', {
        method: 'POST', body: JSON.stringify(updatePayload)
      });

      btn.innerHTML = '⏳ Refreshing Dashboard...';
      await init();

    } catch (err) {
      console.error("Sync Error:", err);
      alert("Failed to sync data. Check console.");
    } finally {
      btn.innerHTML = originalText;
      btn.disabled = false;
    }
  };

  (window as any).downloadCSV = () => {
    if (currentFilteredData.length === 0) {
      alert("No data available to export.");
      return;
    }
    
    const headers = ['MTA Name', 'IP Address', 'Hostname', 'Throttling Template', 'Pools', 'SNDS Status', 'Complaints %', 'Traps', 'JMR Incident', 'Google Rep', 'Last SNDS Update'];
    const rows = currentFilteredData.map(d => [
      d.name,
      d.ip,
      d.hostname,
      d.throttling_template,
      `"${d.pools.join(', ')}"`,
      d.snds_filter,
      d.complaints,
      d.traps,
      d.jmr,
      d.google_rep,
      d.snds_date || 'N/A'
    ]);
    
    const csvContent = [headers.join(','), ...rows.map(row => row.join(','))].join('\n');
    const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
    const url = URL.createObjectURL(blob);
    const link = document.createElement('a');
    link.setAttribute('href', url);
    link.setAttribute('download', `mta_inventory_${activePool.replace(/[^a-z0-9]/gi, '_')}_${new Date().toISOString().split('T')[0]}.csv`);
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
  };

  init();
</script>

<style is:global>
  .domains-wrapper { padding: 2rem; max-width: 1400px; margin: 0 auto; font-family: system-ui, -apple-system, sans-serif; }
  .content-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 2rem; }
  .title-area h1 { font-size: 2.25rem; font-weight: 800; color: #ffffff !important; margin: 0; }
  .title-area p { color: #a0aec0 !important; font-size: 1.1rem; margin: 0.5rem 0 0 0; }
  
  .header-actions { display: flex; gap: 15px; }
  .btn-primary { display: flex; align-items: center; justify-content: center; gap: 8px; background: #3182ce; color: #fff; padding: 12px 24px; border-radius: 8px; font-weight: 700; border: none; cursor: pointer; transition: 0.2s; }
  .btn-primary:hover { background: #2b6cb0; }
  .btn-primary:disabled { opacity: 0.5; cursor: not-allowed; }
