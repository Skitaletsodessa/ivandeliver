  (window as any).renderIpPoolsView = () => {
    const term = (document.getElementById('ipPoolsSearchInput') as HTMLInputElement)?.value.toLowerCase() || '';
    
    const poolMap = {};
    enrichedData.forEach(d => { d.pools.forEach(p => { if(!poolMap[p]) poolMap[p] = []; poolMap[p].push(d); }); });
    
    const tbody = document.getElementById('ipPoolsTableBody');
    if (!tbody) return;

    const filteredPoolKeys = Object.keys(poolMap).sort().filter(poolName => {
        if (poolName.toLowerCase().includes(term)) return true;
        return poolMap[poolName].some(m => m.ip.includes(term) || m.name.toLowerCase().includes(term));
    });

    tbody.innerHTML = filteredPoolKeys.map(poolName => {
      const mtas = poolMap[poolName];
      let hasBad = false, hasMedium = false, hasHigh = false;
      mtas.forEach(m => {
        if (m.google_rep === 'BAD' || m.google_rep === 'LOW') hasBad = true;
        else if (m.google_rep === 'MEDIUM') hasMedium = true;
        else if (m.google_rep === 'HIGH') hasHigh = true;
      });

      let badgeCls = 'badge-gray';
      if (hasBad) badgeCls = 'badge-red'; else if (hasMedium) badgeCls = 'badge-yellow'; else if (hasHigh) badgeCls = 'badge-green';

      const mtaNames = mtas.map(m => `<a href="#mta=${encodeURIComponent(m.name)}" onclick="event.stopPropagation()" class="table-link" style="color: #4a5568; font-weight: normal;">${m.name}</a>`);
      let mtaDisplay = mtaNames.slice(0, 5).join(', ');
      if (mtaNames.length > 5) mtaDisplay += ` <span style="color: #a0aec0; font-style: italic;">(+${mtaNames.length - 5} more)</span>`;

      return `
