---
import Layout from '../layouts/Layout.astro';
---

<Layout title="IP Inventory | ivandeliver.email">
  <main class="domains-wrapper">
    <nav class="tool-nav">
      <a href="/deliverability" class="nav-link back-link">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
        Hub
      </a>
      <div class="nav-divider"></div>
      <a href="/domains" class="nav-link">DNS Monitor</a>
      <a href="/monitor" class="nav-link">SNDS</a>
      <a href="/postmaster" class="nav-link">GPT</a>
      <a href="/ip-inventory" class="nav-link active">IP Inventory</a>
    </nav>

    <div class="content-header">
      <div class="title-area">
        <h1>Global IP Inventory</h1>
        <p>Unified management of IP pools, SNDS health, and Google reputation.</p>
      </div>
      <div class="header-actions">
        <button class="btn-primary" onclick="window.syncData(this)">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21.5 2v6h-6M21.34 15.57a10 10 0 1 1-.92-10.44l5.08 5.08"/></svg>
          Refresh Data
        </button>
      </div>
    </div>

    <div class="summary-grid" id="inventory-summary"></div>

    <div class="view-tabs">
      <button class="tab-btn active" id="btnViewIps" onclick="window.setView('ips')">IP Addresses</button>
      <button class="tab-btn" id="btnViewPools" onclick="window.setView('pools')">Pools Management</button>
    </div>

    <div id="ipsView">
      <div class="table-actions-bar">
        <div class="left-actions">
          <input type="text" id="ipSearch" placeholder="Search IP, Host or Pool..." class="input-field search-input" />
          <select id="poolFilter" class="input-field select-custom">
            <option value="ALL">🌐 All Pools</option>
          </select>
        </div>
        <button class="btn-export" onclick="window.downloadCSV()">Export CSV</button>
      </div>

      <div class="card table-outer-container">
        <div class="table-scroll">
          <table>
            <thead>
              <tr>
                <th class="sortable" onclick="window.sortBy('ip')">IP Address</th>
                <th class="sortable" onclick="window.sortBy('hostname')">Hostname (PTR)</th>
                <th>Assigned Pools</th>
                <th class="center sortable" onclick="window.sortBy('snds_filter')">SNDS</th>
                <th class="center sortable" onclick="window.sortBy('complaints')">Compl.</th>
                <th class="center sortable" onclick="window.sortBy('traps')">Traps</th>
                <th class="center sortable" onclick="window.sortBy('google_rep')">Google Rep</th>
              </tr>
            </thead>
            <tbody id="tableBody"></tbody>
          </table>
        </div>
      </div>
    </div>

    <div id="poolsView" style="display: none;">
      <div class="card table-outer-container">
        <table>
          <thead>
            <tr>
              <th>Pool Name</th>
              <th class="center">IP Count</th>
              <th>IP Addresses in Pool</th>
              <th class="center">Actions</th>
            </tr>
          </thead>
          <tbody id="poolsTableBody"></tbody>
        </table>
      </div>
    </div>

    <dialog id="editIpModal" class="modal">
      <div class="modal-content" style="max-width: 500px;">
        <div class="modal-header">
          <h2 id="editIpTitle">Edit IP Configuration</h2>
          <button onclick="document.getElementById('editIpModal').close()" class="close-btn">&times;</button>
        </div>
        <div class="modal-body">
          <form id="editIpForm" onsubmit="window.saveIpChanges(event)">
            <input type="hidden" id="editIpOriginal" />
            <div class="form-group">
              <label>Hostname (PTR)</label>
              <input type="text" id="editHostname" class="input-field" style="width:100%" />
            </div>
            <div class="form-group">
              <label>Pool 1</label>
              <input type="text" id="editPool1" class="input-field" list="poolList" style="width:100%" />
            </div>
            <div class="form-group">
              <label>Pool 2</label>
              <input type="text" id="editPool2" class="input-field" list="poolList" style="width:100%" />
            </div>
            <div class="form-group">
              <label>Pool 3</label>
              <input type="text" id="editPool3" class="input-field" list="poolList" style="width:100%" />
            </div>
            <div class="form-group">
              <label>Pool 4</label>
              <input type="text" id="editPool4" class="input-field" list="poolList" style="width:100%" />
            </div>
            <datalist id="poolList"></datalist>
            <div style="margin-top: 20px; display: flex; gap: 10px;">
              <button type="submit" class="btn-primary" style="flex:1">Save Changes</button>
            </div>
          </form>
        </div>
      </div>
    </dialog>

  </main>
</Layout>

<script>
  const INV_API = 'https://d1-template.skitalets-od.workers.dev/api/inventory';
  const IMPORT_API = 'https://d1-template.skitalets-od.workers.dev/api/import-ips';
  const SNDS_API = 'https://d1-template.skitalets-od.workers.dev/api/data';
  const PM_API = 'https://postmaster-sync.skitalets-od.workers.dev/api/domains';
  
  let rawInventory = [];
  let enrichedData = [];
  let currentSort = { col: 'ip', asc: true };
  let activePool = 'ALL';
  let activeStatFilter = 'ALL';
  let currentView = 'ips';

  async function init() {
    try {
      const [invRes, sndsRes, pmRes] = await Promise.all([fetch(INV_API), fetch(SND_API), fetch(PM_API)]);
      rawInventory = await invRes.json();
      const sndsData = await sndsRes.json();
      const pmData = await pmRes.json();

      const googleIpMap = {};
      pmData.forEach(domainRow => {
        if(domainRow.ip_rep_detailed) {
          try {
            const reps = JSON.parse(domainRow.ip_rep_detailed);
            reps.forEach(r => {
              if(r.sampleIps) r.sampleIps.forEach(ip => {
                if(!googleIpMap[ip] || r.reputation === 'BAD') googleIpMap[ip] = r.reputation;
              });
            });
          } catch(e) {}
        }
      });

      enrichedData = rawInventory.map(item => {
        const snds = sndsData.find(s => s.ip === item.ip) || {};
        return {
          ...item,
          pools: [item.pool1, item.pool2, item.pool3, item.pool4].filter(p => p && p.trim() !== ''),
          snds_filter: snds.filter_result || 'UNKNOWN',
          complaints: snds.complaints || 0,
          traps: snds.traps || 0,
          google_rep: googleIpMap[item.ip] || 'UNKNOWN'
        };
      });

      updateDatalist();
      applyFiltersAndRender();
    } catch (err) { console.error(err); }
  }

  function applyFiltersAndRender() {
    const search = (document.getElementById('ipSearch') as HTMLInputElement)?.value.toLowerCase() || '';
    
    let filtered = enrichedData.filter(d => {
      const matchSearch = d.ip.toLowerCase().includes(search) || 
                          d.hostname.toLowerCase().includes(search) ||
                          d.pools.some(p => p.toLowerCase().includes(search));
      
      const matchPool = activePool === 'ALL' ? true : d.pools.includes(activePool);
      
      let matchStat = true;
      if (activeStatFilter === 'RED') matchStat = d.snds_filter === 'RED';
      if (activeStatFilter === 'TRAPS') matchStat = d.traps > 0;
      if (activeStatFilter === 'GOOGLE_BAD') matchStat = d.google_rep === 'BAD' || d.google_rep === 'LOW';

      return matchSearch && matchPool && matchStat;
    });

    // Sort Logic
    filtered.sort((a, b) => {
      let valA = a[currentSort.col];
      let valB = b[currentSort.col];
      const mod = currentSort.asc ? 1 : -1;
      if (currentSort.col === 'ip') return (ipToNumber(a.ip) - ipToNumber(b.ip)) * mod;
      return String(valA).localeCompare(String(valB)) * mod;
    });

    renderSummary();
    renderTable(filtered);
    renderPoolsView();
  }

  function renderSummary() {
    const container = document.getElementById('inventory-summary');
    const red = enrichedData.filter(d => d.snds_filter === 'RED').length;
    const traps = enrichedData.filter(d => d.traps > 0).length;
    const gBad = enrichedData.filter(d => d.google_rep === 'BAD' || d.google_rep === 'LOW').length;

    container.innerHTML = `
      <div class="stat-card info ${activeStatFilter === 'ALL' ? 'active' : ''}" onclick="window.setStatFilter('ALL')">
        <span class="stat-label">Total IPs</span>
        <span class="stat-value">${enrichedData.length}</span>
      </div>
      <div class="stat-card danger ${activeStatFilter === 'RED' ? 'active' : ''}" onclick="window.setStatFilter('RED')">
        <span class="stat-label">SNDS: Red</span>
        <span class="stat-value">${red}</span>
      </div>
      <div class="stat-card warning ${activeStatFilter === 'TRAPS' ? 'active' : ''}" onclick="window.setStatFilter('TRAPS')">
        <span class="stat-label">Trap Hits</span>
        <span class="stat-value">${traps}</span>
      </div>
      <div class="stat-card danger-light ${activeStatFilter === 'GOOGLE_BAD' ? 'active' : ''}" onclick="window.setStatFilter('GOOGLE_BAD')">
        <span class="stat-label">Google: Bad</span>
        <span class="stat-value">${gBad}</span>
      </div>
    `;
  }

  (window as any).setStatFilter = (f) => { activeStatFilter = f; applyFiltersAndRender(); };
  (window as any).setView = (v) => {
    currentView = v;
    document.getElementById('ipsView').style.display = v === 'ips' ? 'block' : 'none';
    document.getElementById('poolsView').style.display = v === 'pools' ? 'block' : 'none';
    document.getElementById('btnViewIps').classList.toggle('active', v === 'ips');
    document.getElementById('btnViewPools').classList.toggle('active', v === 'pools');
  };

  function renderTable(data) {
    const tbody = document.getElementById('tableBody');
    tbody.innerHTML = data.map(row => `
      <tr class="domain-row" onclick="window.editIp('${row.ip}')" style="cursor:pointer">
        <td><strong>${row.ip}</strong></td>
        <td class="text-gray">${row.hostname}</td>
        <td>${row.pools.map(p => `<span class="pool-tag">${p}</span>`).join(' ')}</td>
        <td class="center"><span class="badge ${row.snds_filter.toLowerCase()}">${row.snds_filter}</span></td>
        <td class="center">${row.complaints}%</td>
        <td class="center">${row.traps > 0 ? '🚨 '+row.traps : '0'}</td>
        <td class="center"><span class="badge ${row.google_rep.toLowerCase()}">${row.google_rep}</span></td>
      </tr>
    `).join('');
  }

  function renderPoolsView() {
    const poolMap = {};
    enrichedData.forEach(d => {
      d.pools.forEach(p => {
        if(!poolMap[p]) poolMap[p] = [];
        poolMap[p].push(d.ip);
      });
    });

    const tbody = document.getElementById('poolsTableBody');
    tbody.innerHTML = Object.entries(poolMap).sort().map(([name, ips]) => `
      <tr>
        <td><strong>${name}</strong></td>
        <td class="center"><span class="count-badge">${ips.length}</span></td>
        <td style="font-size: 0.8rem; line-height:1.4">${ips.join(', ')}</td>
        <td class="center">
          <button class="btn-copy" onclick="window.filterByPool('${name}')">View Pool</button>
        </td>
      </tr>
    `).join('');
  }

  (window as any).editIp = (ip) => {
    const d = enrichedData.find(x => x.ip === ip);
    (document.getElementById('editIpOriginal') as HTMLInputElement).value = ip;
    (document.getElementById('editHostname') as HTMLInputElement).value = d.hostname;
    (document.getElementById('editPool1') as HTMLInputElement).value = d.pool1 || '';
    (document.getElementById('editPool2') as HTMLInputElement).value = d.pool2 || '';
    (document.getElementById('editPool3') as HTMLInputElement).value = d.pool3 || '';
    (document.getElementById('editPool4') as HTMLInputElement).value = d.pool4 || '';
    (document.getElementById('editIpModal') as HTMLDialogElement).showModal();
  };

  (window as any).saveIpChanges = async (e) => {
    e.preventDefault();
    const ip = (document.getElementById('editIpOriginal') as HTMLInputElement).value;
    const payload = {
      ip: ip,
      hostname: (document.getElementById('editHostname') as HTMLInputElement).value,
      pool1: (document.getElementById('editPool1') as HTMLInputElement).value,
      pool2: (document.getElementById('editPool2') as HTMLInputElement).value,
      pool3: (document.getElementById('editPool3') as HTMLInputElement).value,
      pool4: (document.getElementById('editPool4') as HTMLInputElement).value
    };

    try {
      await fetch(IMPORT_API, {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify([payload])
      });
      (document.getElementById('editIpModal') as HTMLDialogElement).close();
      init();
    } catch(err) { alert("Save failed"); }
  };

  function updateDatalist() {
    const pools = new Set();
    enrichedData.forEach(d => d.pools.forEach(p => pools.add(p)));
    const list = document.getElementById('poolList');
    list.innerHTML = Array.from(pools).map(p => `<option value="${p}">`).join('');
    
    const filter = document.getElementById('poolFilter');
    filter.innerHTML = '<option value="ALL">🌐 All Pools</option>' + 
      Array.from(pools).sort().map(p => `<option value="${p}">${p}</option>`).join('');
  }

  function ipToNumber(ip) { return ip.split('.').reduce((acc, octet) => (acc << 8) + parseInt(octet, 10), 0) >>> 0; }
  (window as any).sortBy = (c) => { currentSort.asc = (currentSort.col === c) ? !currentSort.asc : true; currentSort.col = c; applyFiltersAndRender(); };
  (window as any).filterByPool = (p) => { activePool = p; (document.getElementById('poolFilter') as HTMLSelectElement).value = p; window.setView('ips'); applyFiltersAndRender(); };

  init();
</script>

<style is:global>
  /* [cite: 535-550] Styles from provided snippets */
  .domains-wrapper { padding: 2rem; max-width: 1400px; margin: 0 auto; font-family: system-ui, -apple-system, sans-serif; }
  .tool-nav { display: inline-flex; align-items: center; background: #0f172a; padding: 6px; border-radius: 100px; margin-bottom: 2rem; border: 1px solid #334155; }
  
  .view-tabs { display: flex; gap: 10px; margin-bottom: 2rem; border-bottom: 2px solid #2d3748; padding-bottom: 10px; }
  .tab-btn { background: none; border: none; color: #a0aec0; font-size: 1rem; font-weight: 700; padding: 10px 20px; cursor: pointer; border-radius: 8px; transition: 0.2s; }
  .tab-btn.active { background: #3182ce; color: #fff; }

  .stat-card { cursor: pointer; transition: 0.2s; border: 2px solid transparent !important; }
  .stat-card:hover { transform: translateY(-3px); }
  .stat-card.active { border-color: #3182ce !important; background: #f0f7ff !important; }

  .pool-tag { background: #e2e8f0; color: #2d3748; padding: 2px 8px; border-radius: 4px; font-size: 0.75rem; font-weight: 700; border: 1px solid #cbd5e0; margin-right: 4px; }
  .count-badge { background: #3182ce; color: #fff; padding: 2px 8px; border-radius: 10px; font-size: 0.8rem; }
  
  .form-group { margin-bottom: 15px; }
  .form-group label { display: block; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; color: #4a5568; margin-bottom: 5px; }
  
  /* [cite: 564-580] Modal and Table Styles */
  .modal { border: none; border-radius: 12px; padding: 0; background: #fff; box-shadow: 0 20px 60px rgba(0,0,0,0.3); }
  .modal-header { padding: 1.5rem; border-bottom: 1px solid #e2e8f0; display: flex; justify-content: space-between; align-items: center; }
  .modal-body { padding: 1.5rem; }
  
  .badge { padding: 4px 8px; border-radius: 4px; font-size: 0.7rem; font-weight: 900; text-transform: uppercase; }
  .badge.red { background: #fed7d7; color: #822727; }
  .badge.green { background: #c6f6d5; color: #22543d; }
  .badge.yellow { background: #feebc8; color: #744210; }
  .badge.unknown { background: #edf2f7; color: #4a5568; }
</style>