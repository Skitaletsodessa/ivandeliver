  function renderTable(data) {
    const tbody = document.getElementById('tableBody');
    if (!tbody) return;
    if (data.length === 0) { tbody.innerHTML = `<tr><td colspan="9" class="center" style="padding: 40px; font-weight: bold; color: #a0aec0;">No IPs match current filters.</td></tr>`; return; }

    const grouped = {};
    data.forEach(row => { if (!grouped[row.ip]) grouped[row.ip] = []; grouped[row.ip].push(row); });
    
    let html = '';
    [...new Set(data.map(d => d.ip))].forEach(ip => {
      const rows = grouped[ip];
      const isCritical = rows[0].snds_filter === 'RED' || rows[0].google_rep === 'BAD' || rows[0].traps > 0;
      const bgClass = isCritical ? 'row-alert' : '';

      html += `<tr class="domain-row ${bgClass}" style="border-top: 2px solid #cbd5e0;" onclick="window.location.hash='mta=${encodeURIComponent(rows[0].name)}'">`;
      html += `<td rowspan="${rows.length}" style="font-family: monospace; font-size: 1.05rem; font-weight: bold; background: ${isCritical ? '#fff5f5' : '#f8fafc'}; border-right: 1px solid #e2e8f0; vertical-align: top; padding-top: 15px;">${ip}</td>`;
      html += renderMtaColumns(rows[0]);
      html += `<td class="center" rowspan="${rows.length}" style="vertical-align: top; padding-top: 15px; border-left: 1px solid #e2e8f0;">${formatSNDS(rows[0].snds_filter)}</td>`;
      html += `<td class="center" rowspan="${rows.length}" style="vertical-align: top; padding-top: 15px; ${rows[0].complaints > 0.3 ? 'color:#e53e3e; font-weight:bold;' : ''}">${rows[0].complaints}%</td>`;
      html += `<td class="center" rowspan="${rows.length}" style="vertical-align: top; padding-top: 15px; ${rows[0].traps > 0 ? 'color:#e53e3e; font-weight:bold;' : ''}">${rows[0].traps > 0 ? '🚨 ' + rows[0].traps : '0'}</td>`;
      html += `<td class="center" rowspan="${rows.length}" style="vertical-align: top; padding-top: 15px;">${formatGoogleRep(rows[0].google_rep)}</td>`;
      html += `</tr>`;

      for (let i = 1; i < rows.length; i++) {
        html += `<tr class="domain-row ${bgClass}" onclick="window.location.hash='mta=${encodeURIComponent(rows[i].name)}'">`;
        html += renderMtaColumns(rows[i]);
        html += `</tr>`;
      }
    });
    tbody.innerHTML = html;
  }

  function renderMtaColumns(row) {
    const poolBadges = row.pools.length > 0 ? row.pools.map(p => `<a href="#ippool=${encodeURIComponent(p)}" onclick="event.stopPropagation()" class="pool-tag">${p}</a>`).join(' ') : `<span class="text-gray" style="font-style:italic;">No pools</span>`;
    return `
      <td class="domain-text"><a href="#mta=${encodeURIComponent(row.name)}" onclick="event.stopPropagation()" class="table-link">${row.name}</a></td>
      <td style="color: #4a5568;">${row.hostname}</td>
      <td class="center"><a href="#throttle=${encodeURIComponent(row.throttling_template)}" onclick="event.stopPropagation()" class="badge badge-gray link-badge">${row.throttling_template}</a></td>
      <td><div class="pools-container">${poolBadges}</div></td>
    `;
