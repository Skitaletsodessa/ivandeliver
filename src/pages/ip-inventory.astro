---
import Layout from '../layouts/Layout.astro';
---

<Layout title="IP Inventory | ivandeliver.email">
  <main class="domains-wrapper">
    <nav class="tool-nav">
      <a href="/deliverability" class="nav-link back-link">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
        Hub
      </a>
      <div class="nav-divider"></div>
      <a href="/domains" class="nav-link">DNS Monitor</a>
      <a href="/monitor" class="nav-link">SNDS</a>
      <a href="/postmaster" class="nav-link">GPT</a>
      <a href="/ip-inventory" class="nav-link active">IP Inventory</a>
    </nav>
    <div class="content-header">
      <div class="title-area">
        <h1>Global IP Inventory</h1>
        <p>Unified dashboard mapping Virtual MTAs to Microsoft SNDS status and Google Postmaster reputation.</p>
      </div>
      <div class="header-actions">
        <button class="btn-primary" onclick="window.syncData(this)">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.5 2v6h-6M21.34 15.57a10 10 0 1 1-.92-10.44l5.08 5.08"/></svg>
          Refresh Data
        </button>
      </div>
    </div>

    <div class="summary-grid" id="inventory-summary"></div>

    <div class="view-tabs">
      <button class="tab-btn active" id="btnViewIps" onclick="window.setView('ips')">IP Addresses</button>
      <button class="tab-btn" id="btnViewPools" onclick="window.setView('pools')">Send Pools</button>
    </div>

    <div id="ipsView">
      <div class="table-actions-bar">
        <div class="left-actions" style="display: flex; gap: 15px; align-items: center;">
          <input type="text" id="ipSearch" placeholder="Search Name, IP or Pool..." class="input-field search-input" />
          <select id="poolFilter" class="input-field select-custom" style="width: 250px;">
            <option value="ALL">🌐 All Pools</option>
          </select>
        </div>
        <button class="btn-export" onclick="window.downloadCSV()">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
          Export CSV
        </button>
      </div>

      <div class="card table-outer-container">
        <div class="table-scroll">
          <table>
            <thead>
              <tr>
                <th class="sortable" onclick="window.sortBy('ip')">IP Address</th>
                <th class="sortable" onclick="window.sortBy('name')">MTA Name</th>
                <th class="sortable" onclick="window.sortBy('hostname')">Hostname (PTR)</th>
                <th class="center sortable" onclick="window.sortBy('throttling_template')">Throttling Template</th>
                <th>Assigned Pools</th>
                <th class="center sortable" onclick="window.sortBy('snds_filter')">SNDS Status</th>
                <th class="center sortable" onclick="window.sortBy('complaints')">Complaints</th>
                <th class="center sortable" onclick="window.sortBy('traps')">Traps</th>
                <th class="center sortable" onclick="window.sortBy('google_rep')">Google Rep</th>
              </tr>
            </thead>
            <tbody id="tableBody">
              <tr><td colspan="9" class="center" style="padding: 40px; color: #a0aec0;">Loading data...</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <div id="poolsView" style="display: none;">
      <div class="card table-outer-container">
        <div class="table-scroll">
          <table>
            <thead>
              <tr>
                <th>Pool Name</th>
                <th class="center">IP Count</th>
                <th>Assigned IPs (MTAs)</th>
                <th class="center">Action</th>
              </tr>
            </thead>
            <tbody id="poolsTableBody"></tbody>
          </table>
        </div>
      </div>
    </div>

    <dialog id="detailsModal" class="modal" style="max-width: 650px;">
      <div class="modal-content">
        <div class="modal-header">
          <h2 id="modalTitle">MTA Details</h2>
          <button onclick="document.getElementById('detailsModal').close()" class="close-btn">&times;</button>
        </div>
        <div class="modal-body" id="modalBodyContent"></div>
        <div class="modal-footer" style="background: #f8fafc; padding: 1.5rem; border-top: 1px solid #e2e8f0; border-radius: 0 0 12px 12px;">
            <div style="display: flex; justify-content: space-between; align-items: center;">
                <div>
                    <h4 style="margin: 0; color: #1e293b; font-size: 1.05rem;">Live Statistics API</h4>
                    <p style="margin: 4px 0 0 0; color: #64748b; font-size: 0.85rem;">Fetch real-time delivery metrics from GreenArrow for this MTA.</p>
                </div>
                <button class="btn-primary" disabled style="opacity: 0.6; cursor: not-allowed;" title="API Integration Coming Soon">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 8px;"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline></svg>
                    Load Stats
                </button>
            </div>
            <div id="statsContainer" style="display: none; margin-top: 15px; padding: 15px; background: #fff; border: 1px dashed #cbd5e0; border-radius: 8px;"></div>
        </div>
      </div>
    </dialog>

    <dialog id="poolModal" class="modal" style="max-width: 900px;">
      <div class="modal-content">
        <div class="modal-header">
          <h2 id="poolModalTitle">Pool Details</h2>
          <button onclick="document.getElementById('poolModal').close()" class="close-btn">&times;</button>
        </div>
        <div class="modal-body" id="poolModalBodyContent" style="max-height: 65vh; overflow-y: auto; padding: 1.5rem;">
           </div>
      </div>
    </dialog>

  </main>
</Layout>

<script>
  const INVENTORY_URL = 'https://d1-template.skitalets-od.workers.dev/api/inventory';
  const SNDS_URL = 'https://d1-template.skitalets-od.workers.dev/api/data';
  const POSTMASTER_URL = 'https://postmaster-sync.skitalets-od.workers.dev/api/domains';
  
  let enrichedData = [];
  let currentFilteredData = [];
  let sortCol = 'ip';
  let sortAsc = true;
  let activePool = 'ALL';
  let activeStatFilter = 'ALL';

  async function init() {
    try {
      const [invRes, sndsRes, pmRes] = await Promise.all([
        fetch(INVENTORY_URL, { cache: 'no-store' }),
        fetch(SNDS_URL, { cache: 'no-store' }),
        fetch(POSTMASTER_URL, { cache: 'no-store' })
      ]);

      const inventory = await invRes.json();
      const sndsData = await sndsRes.json();
      const pmData = await pmRes.json();

      const googleIpMap = {};
      pmData.forEach(domainRow => {
        if(domainRow.ip_rep_detailed && domainRow.ip_rep_detailed !== '[]') {
          try {
            const reps = JSON.parse(domainRow.ip_rep_detailed);
            reps.forEach(r => {
              if(r.sampleIps) {
                r.sampleIps.forEach(ip => {
                  if(!googleIpMap[ip] || r.reputation === 'BAD' || r.reputation === 'LOW') googleIpMap[ip] = r.reputation;
                });
              }
            });
          } catch(e) {}
        }
      });

      const allPools = new Set();
      enrichedData = inventory.map(item => {
        let poolsArr = [];
        try { poolsArr = JSON.parse(item.pools || '[]'); } catch(e) {}
        poolsArr = poolsArr.filter(p => p && p !== 'null');
        poolsArr.forEach(p => allPools.add(p));

        const sndsRecord = sndsData.find(s => s.ip === item.ip_address) || {};

        return {
          name: item.name || '',
          ip: item.ip_address || '',
          hostname: item.hostname || '—',
          pools: poolsArr,
          throttling_template: item.throttling_template || '—',
          snds_filter: sndsRecord.filter_result || 'UNKNOWN',
          complaints: sndsRecord.complaints || 0,
          traps: sndsRecord.traps || 0,
          jmr: sndsRecord.jmr_p1_sender || '',
          google_rep: googleIpMap[item.ip_address] || 'UNKNOWN'
        };
      });

      populatePoolDropdowns(Array.from(allPools).sort());
      applyFiltersAndRender();

      const searchInput = document.getElementById('ipSearch');
      if (searchInput) searchInput.addEventListener('input', applyFiltersAndRender);
      
      const poolFilter = document.getElementById('poolFilter');
      if (poolFilter) {
        poolFilter.addEventListener('change', (e) => {
          activePool = (e.target as HTMLSelectElement).value;
          applyFiltersAndRender();
        });
      }

    } catch (err) {
      console.error("Data Merge Error:", err);
      document.getElementById('tableBody').innerHTML = `<tr><td colspan="9" class="center error-text">Error loading data.</td></tr>`;
    }
  }

  function populatePoolDropdowns(pools) {
    const select = document.getElementById('poolFilter');
    if (!select) return;
    select.innerHTML = '<option value="ALL">🌐 All Pools</option>';
    pools.forEach(pool => { select.innerHTML += `<option value="${pool}">${pool}</option>`; });
  }

  function applyFiltersAndRender() {
    const searchTerm = (document.getElementById('ipSearch') as HTMLInputElement)?.value.toLowerCase() || '';
    
    let searchFiltered = enrichedData.filter(d => {
      const safeName = (d.name || '').toLowerCase();
      const safeIp = (d.ip || '').toLowerCase();
      const safeHost = (d.hostname || '').toLowerCase();

      const matchSearch = safeName.includes(searchTerm) || 
                          safeIp.includes(searchTerm) || 
                          safeHost.includes(searchTerm) ||
                          d.pools.some(p => (p || '').toLowerCase().includes(searchTerm));
                          
      const matchPool = activePool === 'ALL' ? true : d.pools.includes(activePool);
      return matchSearch && matchPool;
    });

    renderSummary(searchFiltered);

    let tableFiltered = searchFiltered.filter(d => {
      if (activeStatFilter === 'ALL') return true;
      if (activeStatFilter === 'RED') return d.snds_filter === 'RED';
      if (activeStatFilter === 'TRAPS') return d.traps > 0;
      if (activeStatFilter === 'GOOGLE_BAD') return d.google_rep === 'BAD' || d.google_rep === 'LOW';
      return true;
    });

    tableFiltered.sort((a, b) => {
      let valA = a[sortCol]; let valB = b[sortCol];
      if (sortCol === 'ip') {
        const numA = ipToNumber(a.ip); const numB = ipToNumber(b.ip);
        if (numA !== numB) return sortAsc ? numA - numB : numB - numA;
        return a.name.localeCompare(b.name);
      }
      let strA = String(valA || '').toLowerCase(); let strB = String(valB || '').toLowerCase();
      return sortAsc ? strA.localeCompare(strB) : strB.localeCompare(strA);
    });

    currentFilteredData = tableFiltered;
    renderTable(tableFiltered);
    renderPoolsView(searchFiltered);
  }

  function ipToNumber(ip) {
    if (!ip) return 0;
    return ip.split('.').reduce((acc, octet) => (acc << 8) + parseInt(octet, 10), 0) >>> 0;
  }

  function renderSummary(data) {
    const container = document.getElementById('inventory-summary');
    if (!container) return;
    
    const uniqueIps = new Set(data.map(d => d.ip)).size;
    const sndsRed = new Set(data.filter(d => d.snds_filter === 'RED').map(d => d.ip)).size;
    const trapCount = new Set(data.filter(d => d.traps > 0).map(d => d.ip)).size;
    const googleBad = new Set(data.filter(d => d.google_rep === 'BAD' || d.google_rep === 'LOW').map(d => d.ip)).size;
    
    const getActiveCls = (filter) => activeStatFilter === filter ? 'active-filter' : '';

    container.innerHTML = `
      <div class="stat-card info ${getActiveCls('ALL')}" onclick="window.setStatFilter('ALL')">
        <span class="stat-label">Total Physical IPs</span>
        <span class="stat-value">${uniqueIps}</span>
      </div>
      <div class="stat-card ${sndsRed > 0 ? 'danger' : 'success'} ${getActiveCls('RED')}" onclick="window.setStatFilter('RED')">
        <span class="stat-label">SNDS: Red Status</span>
        <span class="stat-value">${sndsRed}</span>
      </div>
      <div class="stat-card ${trapCount > 0 ? 'warning' : 'success'} ${getActiveCls('TRAPS')}" onclick="window.setStatFilter('TRAPS')">
        <span class="stat-label">Hitting Traps</span>
        <span class="stat-value">${trapCount}</span>
      </div>
      <div class="stat-card ${googleBad > 0 ? 'danger-light' : 'success'} ${getActiveCls('GOOGLE_BAD')}" onclick="window.setStatFilter('GOOGLE_BAD')">
        <span class="stat-label">Google: Bad/Low</span>
        <span class="stat-value">${googleBad}</span>
      </div>
    `;
  }

  function renderTable(data) {
    const tbody = document.getElementById('tableBody');
    if (!tbody) return;
    if (data.length === 0) {
      tbody.innerHTML = `<tr><td colspan="9" class="center" style="padding: 20px;">No matching records found.</td></tr>`;
      return;
    }

    const grouped = {};
    data.forEach(row => {
      if (!grouped[row.ip]) grouped[row.ip] = [];
      grouped[row.ip].push(row);
    });

    let html = '';
    const orderedIps = [...new Set(data.map(d => d.ip))];

    orderedIps.forEach(ip => {
      const rows = grouped[ip];
      const rowSpan = rows.length;
      const firstRow = rows[0];
      const isCritical = firstRow.snds_filter === 'RED' || firstRow.google_rep === 'BAD' || firstRow.traps > 0;
      const bgClass = isCritical ? 'row-alert' : '';

      html += `<tr class="domain-row ${bgClass}" style="border-top: 2px solid #cbd5e0;" onclick="window.openDetailsModal('${firstRow.name}')">`;
      html += `<td rowspan="${rowSpan}" style="font-family: monospace; font-size: 1.05rem; font-weight: bold; background: ${isCritical ? '#fff5f5' : '#f8fafc'}; border-right: 1px solid #e2e8f0; vertical-align: top; padding-top: 15px;">${ip}</td>`;
      
      html += renderMtaColumns(firstRow);

      html += `<td class="center" rowspan="${rowSpan}" style="vertical-align: top; padding-top: 15px; border-left: 1px solid #e2e8f0;">${formatSNDS(firstRow.snds_filter)}</td>`;
      html += `<td class="center" rowspan="${rowSpan}" style="vertical-align: top; padding-top: 15px; ${firstRow.complaints > 0.3 ? 'color:#e53e3e; font-weight:bold;' : ''}">${firstRow.complaints}%</td>`;
      html += `<td class="center" rowspan="${rowSpan}" style="vertical-align: top; padding-top: 15px; ${firstRow.traps > 0 ? 'color:#e53e3e; font-weight:bold;' : ''}">${firstRow.traps > 0 ? '🚨 ' + firstRow.traps : '0'}</td>`;
      html += `<td class="center" rowspan="${rowSpan}" style="vertical-align: top; padding-top: 15px;">${formatGoogleRep(firstRow.google_rep)}</td>`;
      html += `</tr>`;

      for (let i = 1; i < rowSpan; i++) {
        html += `<tr class="domain-row ${bgClass}" onclick="window.openDetailsModal('${rows[i].name}')">`;
        html += renderMtaColumns(rows[i]);
        html += `</tr>`;
      }
    });

    tbody.innerHTML = html;
  }

  function renderMtaColumns(row) {
    const poolBadges = row.pools.length > 0 
      ? row.pools.map(p => `<span class="pool-tag">${p}</span>`).join(' ')
      : `<span class="text-gray">—</span>`;
    
    return `
      <td class="domain-text"><strong>${row.name}</strong></td>
      <td style="color: #4a5568;">${row.hostname}</td>
      <td class="center"><span class="badge badge-gray">${row.throttling_template}</span></td>
      <td><div class="pools-container">${poolBadges}</div></td>
    `;
  }

  // ОБНОВЛЕННАЯ ФУНКЦИЯ ДЛЯ ВКЛАДКИ SEND POOLS
  function renderPoolsView(data) {
    const poolMap = {};
    data.forEach(d => { 
      d.pools.forEach(p => { 
        if(!poolMap[p]) poolMap[p] = []; 
        // Сохраняем весь объект IP/MTA для анализа репутации
        poolMap[p].push(d); 
      }); 
    });
    
    const tbody = document.getElementById('poolsTableBody');
    if (!tbody) return;

    tbody.innerHTML = Object.keys(poolMap).sort().map(poolName => {
      const mtas = poolMap[poolName];
      const ipCount = mtas.length;

      // Анализируем общую репутацию пула (GPT)
      let hasBad = false;
      let hasMedium = false;
      let hasHigh = false;

      mtas.forEach(m => {
        if (m.google_rep === 'BAD' || m.google_rep === 'LOW') hasBad = true;
        else if (m.google_rep === 'MEDIUM') hasMedium = true;
        else if (m.google_rep === 'HIGH') hasHigh = true;
      });

      let badgeCls = 'badge-gray';
      if (hasBad) badgeCls = 'badge-red';
      else if (hasMedium) badgeCls = 'badge-yellow';
      else if (hasHigh) badgeCls = 'badge-green';

      // Формируем список MTA для колонки (обрезаем если больше 5)
      const mtaNames = mtas.map(m => m.name);
      let mtaDisplay = mtaNames.slice(0, 5).join(', ');
      if (mtaNames.length > 5) {
        mtaDisplay += ` <span style="color: #a0aec0; font-style: italic;">(+${mtaNames.length - 5} more)</span>`;
      }

      return `
        <tr class="domain-row" onclick="window.openPoolModal('${poolName}')">
          <td><strong style="color: #2d3748; font-size: 1.05rem;">${poolName}</strong></td>
          <td class="center"><span class="badge ${badgeCls}" style="font-size: 0.85rem; padding: 6px 12px;">${ipCount} IPs</span></td>
          <td style="font-size: 0.9rem; color: #4a5568;">${mtaDisplay}</td>
          <td class="center"><button class="btn-export" style="padding: 6px 12px; background: #3182ce;" onclick="event.stopPropagation(); window.openPoolModal('${poolName}')">Manage</button></td>
        </tr>
      `;
    }).join('') || `<tr><td colspan="4" class="center">No pools found.</td></tr>`;
  }

  function formatSNDS(s) {
    let cls = 'badge-gray'; if(s === 'GREEN') cls = 'badge-green'; if(s === 'YELLOW') cls = 'badge-yellow'; if(s === 'RED') cls = 'badge-red';
    return `<span class="badge ${cls}">${s}</span>`;
  }

  function formatGoogleRep(r) {
    let cls = 'badge-gray'; if(r === 'HIGH') cls = 'badge-green'; if(r === 'MEDIUM') cls = 'badge-yellow'; if(r === 'BAD' || r === 'LOW') cls = 'badge-red';
    return `<span class="badge ${cls}">${r}</span>`;
  }

  // ОТКРЫТИЕ ДЕТАЛЕЙ ОДНОГО MTA
  (window as any).openDetailsModal = (mtaName) => {
    const data = enrichedData.find(d => d.name === mtaName);
    if (!data) return;

    document.getElementById('modalTitle').innerText = `MTA: ${data.name}`;
    
    const poolBadges = data.pools.length > 0 
      ? data.pools.map(p => `<span class="pool-tag">${p}</span>`).join(' ')
      : `<span class="text-gray" style="font-style: italic;">No pools assigned</span>`;

    const bodyHtml = `
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 20px;">
          <div style="background: #f8fafc; padding: 1rem; border-radius: 8px; border: 1px solid #e2e8f0;">
              <div style="font-size: 0.75rem; font-weight: 800; color: #64748b; text-transform: uppercase; margin-bottom: 6px;">IP Address</div>
              <div style="font-family: monospace; font-size: 1.1rem; color: #0f172a; font-weight: 600;">${data.ip}</div>
          </div>
          <div style="background: #f8fafc; padding: 1rem; border-radius: 8px; border: 1px solid #e2e8f0;">
              <div style="font-size: 0.75rem; font-weight: 800; color: #64748b; text-transform: uppercase; margin-bottom: 6px;">Hostname (PTR)</div>
              <div style="font-size: 1rem; color: #0f172a; font-weight: 500;">${data.hostname}</div>
          </div>
      </div>
      
      <div style="margin-bottom: 20px;">
          <div style="font-size: 0.75rem; font-weight: 800; color: #64748b; text-transform: uppercase; margin-bottom: 8px;">Throttling Template</div>
          <div><span class="badge badge-gray" style="font-size: 0.9rem; padding: 6px 12px;">${data.throttling_template}</span></div>
      </div>

      <div style="margin-bottom: 20px;">
          <div style="font-size: 0.75rem; font-weight: 800; color: #64748b; text-transform: uppercase; margin-bottom: 8px;">Assigned Pools</div>
          <div class="pools-container" style="padding: 15px; background: #f8fafc; border-radius: 8px; border: 1px solid #e2e8f0; min-height: 50px;">
              ${poolBadges}
          </div>
      </div>
    `;
    
    document.getElementById('modalBodyContent').innerHTML = bodyHtml;
    (document.getElementById('detailsModal') as HTMLDialogElement).showModal();
  };

  // НОВАЯ ФУНКЦИЯ ДЛЯ ОТКРЫТИЯ МОДАЛКИ С ДЕТАЛЯМИ ПУЛА
  (window as any).openPoolModal = (poolName) => {
    // Находим все IP, привязанные к этому пулу
    const poolData = enrichedData.filter(d => d.pools.includes(poolName));
    if (!poolData || poolData.length === 0) return;

    document.getElementById('poolModalTitle').innerText = `Send Pool: ${poolName}`;

    // Сортируем по IP для красивого отображения
    poolData.sort((a, b) => ipToNumber(a.ip) - ipToNumber(b.ip));

    let rowsHtml = poolData.map(row => {
      const isCritical = row.snds_filter === 'RED' || row.google_rep === 'BAD' || row.traps > 0;
      return `
        <tr style="border-bottom: 1px solid #e2e8f0; transition: background 0.1s; ${isCritical ? 'background: #fff5f5;' : ''}" onmouseover="this.style.background='#edf2f7'" onmouseout="this.style.background='${isCritical ? '#fff5f5' : 'transparent'}'">
          <td style="padding: 12px; font-weight: bold; color: #2d3748;">${row.name}</td>
          <td style="padding: 12px; font-family: monospace; font-size: 0.95rem;">${row.ip}</td>
          <td class="center" style="padding: 12px;">${formatSNDS(row.snds_filter)}</td>
          <td class="center" style="padding: 12px; ${row.complaints > 0.3 ? 'color:#e53e3e; font-weight:bold;' : ''}">${row.complaints}%</td>
          <td class="center" style="padding: 12px; ${row.traps > 0 ? 'color:#e53e3e; font-weight:bold;' : ''}">${row.traps > 0 ? '🚨 ' + row.traps : '0'}</td>
          <td class="center" style="padding: 12px;">${formatGoogleRep(row.google_rep)}</td>
        </tr>
      `;
    }).join('');

    const html = `
      <div style="background: #f8fafc; padding: 15px 20px; border-radius: 8px; margin-bottom: 20px; display: flex; justify-content: space-between; align-items: center; border: 1px solid #e2e8f0;">
          <div>
              <span style="font-size: 0.8rem; font-weight: 800; color: #64748b; text-transform: uppercase;">Total Included IPs</span>
              <div style="font-size: 1.5rem; font-weight: 800; color: #0f172a;">${poolData.length}</div>
          </div>
          <button class="btn-export" style="padding: 8px 16px; font-size: 0.85rem; background: #4a5568;" onclick="document.getElementById('poolModal').close(); window.jumpToPool('${poolName}')">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 6px;"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"></polygon></svg>
              Filter in Main View
          </button>
      </div>
      
      <table style="width: 100%; border-collapse: collapse; font-size: 0.95rem;">
        <thead>
          <tr style="background: #edf2f7; text-align: left; border-bottom: 2px solid #cbd5e0;">
            <th style="padding: 12px; font-weight: 800; color: #4a5568; text-transform: uppercase; font-size: 0.75rem;">MTA Name</th>
            <th style="padding: 12px; font-weight: 800; color: #4a5568; text-transform: uppercase; font-size: 0.75rem;">IP Address</th>
            <th class="center" style="padding: 12px; font-weight: 800; color: #4a5568; text-transform: uppercase; font-size: 0.75rem;">SNDS</th>
            <th class="center" style="padding: 12px; font-weight: 800; color: #4a5568; text-transform: uppercase; font-size: 0.75rem;">Complaints</th>
            <th class="center" style="padding: 12px; font-weight: 800; color: #4a5568; text-transform: uppercase; font-size: 0.75rem;">Traps</th>
            <th class="center" style="padding: 12px; font-weight: 800; color: #4a5568; text-transform: uppercase; font-size: 0.75rem;">Google Rep</th>
          </tr>
        </thead>
        <tbody>
          ${rowsHtml}
        </tbody>
      </table>
    `;

    document.getElementById('poolModalBodyContent').innerHTML = html;
    (document.getElementById('poolModal') as HTMLDialogElement).showModal();
  };

  (window as any).syncData = async (btn) => {
    const originalText = btn.innerHTML; btn.disabled = true;
    try {
      btn.innerHTML = '⏳ 1/3: Fetching Global Directory...';
      const listRes = await fetch('https://ga-manager.skitalets-od.workers.dev/api/ga-list');
      const lists = await listRes.json();
      
      const ipMtas = lists.mtas.filter(m => m.type === 'ip_address' || !m.type);
      const ruleMtas = lists.rules || []; 
      
      const ipIds = ipMtas.map(r => r.id);
      const ruleIds = ruleMtas.map(r => r.id);

      const chunkSize = 15;

      for (let i = 0; i < ipIds.length; i += chunkSize) {
        btn.innerHTML = `⏳ 2/3: Syncing MTAs (${Math.min(i+chunkSize, ipIds.length)}/${ipIds.length})...`;
        const chunk = ipIds.slice(i, i+chunkSize);
        
        const detailsRes = await fetch('https://ga-manager.skitalets-od.workers.dev/api/ga-details', { method: 'POST', body: JSON.stringify({ type: 'ip_addresses', ids: chunk }) });
        const detailsData = await detailsRes.json();

        const usedByRes = await fetch('https://ga-manager.skitalets-od.workers.dev/api/ga-details', { method: 'POST', body: JSON.stringify({ type: 'used_by', ids: chunk }) });
        const usedByData = await usedByRes.json();

        let batchPayload = { ips: [], rules: [], relations: [], processed_mta_ids: chunk };

        for (let j = 0; j < chunk.length; j++) {
          const mtaId = chunk[j];
          const detail = detailsData[j];
          const usedBy = usedByData[j];

          if (detail && detail.success && detail.data && detail.data.ip_address) {
            const ipData = detail.data.ip_address;
            batchPayload.ips.push({
              id: ipData.id,
              name: ipData.name,
              ip: ipData.ip || null,
              hostname: ipData.hostname || null,
              delivery_paused: ipData.delivery_paused ? 1 : 0,
              throttling_template_id: ipData.throttling_template?.id || null,
              throttling_template_name: ipData.throttling_template?.name || null,
              raw_json: JSON.stringify(ipData)
            });
          }

          if (usedBy && usedBy.success && usedBy.data && Array.isArray(usedBy.data.used_by)) {
            usedBy.data.used_by.forEach(ref => {
              batchPayload.relations.push({
                mta_id: mtaId,
                used_by_id: ref.id,
                used_by_type: ref.type,
                used_by_name: ref.name
              });
            });
          }
        }

        if (batchPayload.ips.length > 0 || batchPayload.relations.length > 0 || batchPayload.processed_mta_ids.length > 0) {
            await fetch('https://ga-manager.skitalets-od.workers.dev/api/update-inventory', {
              method: 'POST', body: JSON.stringify(batchPayload)
            });
        }
      }

      for (let i = 0; i < ruleIds.length; i += chunkSize) {
        btn.innerHTML = `⏳ 3/3: Syncing Pools (${Math.min(i+chunkSize, ruleIds.length)}/${ruleIds.length})...`;
        const chunk = ruleIds.slice(i, i+chunkSize);
        const rulesRes = await fetch('https://ga-manager.skitalets-od.workers.dev/api/ga-details', { method: 'POST', body: JSON.stringify({ type: 'routing_rules', ids: chunk }) });
        const rulesData = await rulesRes.json();

        let batchPayload = { ips: [], rules: [], relations: [] };

        rulesData.forEach(r => {
          if (r && r.success && r.data && r.data.routing_rule) {
            const ruleData = r.data.routing_rule;
            batchPayload.rules.push({
              id: ruleData.id,
              name: ruleData.name,
              randomization_type: ruleData.default?.randomization_type || null,
              raw_json: JSON.stringify(ruleData)
            });
          }
        });

        if (batchPayload.rules.length > 0) {
            await fetch('https://ga-manager.skitalets-od.workers.dev/api/update-inventory', {
              method: 'POST', body: JSON.stringify(batchPayload)
            });
        }
      }

      btn.innerHTML = `✅ Finalizing...`;
      await init();
    } catch (err) { console.error(err); alert("Sync failed. Check Console for details."); }
    finally { btn.innerHTML = originalText; btn.disabled = false; }
  };

  (window as any).downloadCSV = () => {
    const headers = ['IP', 'MTA Name', 'Hostname', 'Template', 'Pools', 'SNDS', 'Complaints', 'Traps', 'Google'];
    const csv = [headers.join(','), ...currentFilteredData.map(d => [
      d.ip, d.name, d.hostname, d.throttling_template, `"${d.pools.join(', ')}"`, d.snds_filter, d.complaints, d.traps, d.google_rep
    ].join(','))].join('\n');
    const link = document.createElement('a');
    link.href = URL.createObjectURL(new Blob([csv], { type: 'text/csv' }));
    link.download = `inventory_${new Date().toISOString().split('T')[0]}.csv`;
    link.click();
  };

  (window as any).sortBy = (col) => { if (sortCol === col) sortAsc = !sortAsc; else { sortCol = col; sortAsc = true; } applyFiltersAndRender(); };
  (window as any).setStatFilter = (f) => { activeStatFilter = f; applyFiltersAndRender(); };
  (window as any).setView = (v) => {
    document.getElementById('ipsView').style.display = v === 'ips' ? 'block' : 'none';
    document.getElementById('poolsView').style.display = v === 'pools' ? 'block' : 'none';
    document.getElementById('btnViewIps').classList.toggle('active', v === 'ips');
    document.getElementById('btnViewPools').classList.toggle('active', v === 'pools');
  };
  (window as any).jumpToPool = (p) => { 
    activePool = p; 
    (document.getElementById('poolFilter') as HTMLSelectElement).value = p; 
    (window as any).setView('ips'); 
    applyFiltersAndRender(); 
  };

  init();
</script>

