  (window as any).renderSendPoolsView = () => {
    let filtered = enrichedRules;

    if (hidePureIpPools) {
        filtered = filtered.filter(r => {
            const hasOverrides = r.domain_overrides.length > 0;
            const hasNestedRules = r.default_route.rules.length > 0;
            return hasOverrides || hasNestedRules;
        });
    }

    if (spActiveFilter === 'SHARED') {
        const shared = ['a-tec35', 'a-tec80', 'a-tec83', 'a-tec87', 'a-tec91'];
        filtered = filtered.filter(r => shared.includes(r.name));
    } else if (spActiveFilter === 'DEDICATED') {
        filtered = filtered.filter(r => r.name.toLowerCase().includes('dedicated'));
    } else if (spActiveFilter === 'STRATEGIC') {
        filtered = filtered.filter(r => r.name.toLowerCase().includes('strategic'));
    }

    const tbody = document.getElementById('sendPoolsTableBody');
    if (!tbody) return;
    
    tbody.innerHTML = filtered.map(r => {
        const isIpPool = (name) => enrichedData.some(d => d.pools.includes(name));
        
        let nestedRulesDisplay = r.default_route.rules.map(n => {
            const hash = isIpPool(n.name) ? `#ippool=${encodeURIComponent(n.name)}` : `#sendpool=${encodeURIComponent(n.name)}`;
            const color = isIpPool(n.name) ? '#38a169' : '#2b6cb0'; 
            return `<a href="${hash}" onclick="event.stopPropagation()" class="table-link" style="color: ${color};">${n.name}</a>`;
        }).join(', ');
        
        let domainsDisplay = r.domain_overrides.length > 0 
          ? `<span class="badge badge-gray">${r.domain_overrides.length} Overrides</span>` 
          : `<span class="text-gray" style="font-style:italic;">No overrides</span>`;

        return `
