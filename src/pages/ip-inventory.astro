---
import Layout from '../layouts/Layout.astro';
---

<Layout title="IP Inventory | ivandeliver.email">
  <main class="domains-wrapper">
  <nav class="tool-nav">
      <a href="/deliverability" class="nav-link back-link">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
        Hub
      </a>
      <div class="nav-divider"></div>
      <a href="/domains" class="nav-link">DNS Monitor</a>
      <a href="/monitor" class="nav-link">SNDS</a>
      <a href="/postmaster" class="nav-link">GPT</a>
      <a href="/ip-inventory" class="nav-link active">IP Inventory</a> </nav>
    <div class="content-header">
      <div class="title-area">
        <h1>Global IP Inventory</h1>
        <p>Unified dashboard mapping IP pools to Microsoft SNDS status and Google Postmaster reputation.</p>
      </div>
      <div class="header-actions">
        <button class="btn-primary" onclick="window.syncData(this)">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.5 2v6h-6M21.34 15.57a10 10 0 1 1-.92-10.44l5.08 5.08"/></svg>
          Refresh Data
        </button>
      </div>
    </div>

    <div class="summary-grid" id="inventory-summary">
      </div>

    <div class="table-actions-bar">
      <div class="left-actions" style="display: flex; gap: 15px; align-items: center;">
        <input type="text" id="ipSearch" placeholder="Search IP or Hostname..." class="input-field search-input" />
        
        <select id="poolFilter" class="input-field select-custom" style="width: 250px;">
          <option value="ALL">🌐 All Pools</option>
          </select>
      </div>
      
      <button class="btn-export" onclick="window.downloadCSV()">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
        Export CSV
      </button>
    </div>

    <div class="card table-outer-container">
      <div class="table-scroll">
        <table>
          <thead>
            <tr>
              <th class="sortable" onclick="window.sortBy('ip')">IP Address</th>
              <th class="sortable" onclick="window.sortBy('hostname')">Hostname (PTR)</th>
              <th>Assigned Pools</th>
              <th class="center sortable" onclick="window.sortBy('snds_filter')">SNDS Status</th>
              <th class="center sortable" onclick="window.sortBy('complaints')">Complaints</th>
              <th class="center sortable" onclick="window.sortBy('traps')">Traps</th>
              <th class="center sortable" onclick="window.sortBy('google_rep')">Google Rep</th>
            </tr>
          </thead>
          <tbody id="tableBody">
            <tr><td colspan="7" class="center" style="padding: 40px; color: #a0aec0;">Fetching data from SNDS and Postmaster...</td></tr>
          </tbody>
        </table>
      </div>
    </div>

  </main>
</Layout>

<script>
  const INVENTORY_URL = 'https://d1-template.skitalets-od.workers.dev/api/inventory';
  const SNDS_URL = 'https://d1-template.skitalets-od.workers.dev/api/data';
  const POSTMASTER_URL = 'https://postmaster-sync.skitalets-od.workers.dev/api/domains';
  
  let enrichedData = [];
  let currentFilteredData = [];
  
  let sortCol = 'ip';
  let sortAsc = true;
  let activePool = 'ALL';

  async function init() {
    try {
      // 1. Запрашиваем данные из всех трех источников параллельно (максимальная скорость)
      const [invRes, sndsRes, pmRes] = await Promise.all([
        fetch(INVENTORY_URL),
        fetch(SNDS_URL),
        fetch(POSTMASTER_URL)
      ]);

      const inventory = await invRes.json();
      const sndsData = await sndsRes.json();
      const pmData = await pmRes.json();

      // 2. Создаем "Словарь" репутации Google для быстрого поиска по IP
      const googleIpMap = {};
      pmData.forEach(domainRow => {
        if(domainRow.ip_rep_detailed && domainRow.ip_rep_detailed !== '[]') {
          try {
            const reps = JSON.parse(domainRow.ip_rep_detailed);
            reps.forEach(r => {
              if(r.sampleIps) {
                r.sampleIps.forEach(ip => {
                  // Если IP светится в разных доменах с разной репутацией, берем самую худшую (пессимистичный подход)
                  if(!googleIpMap[ip] || r.reputation === 'BAD' || r.reputation === 'LOW') {
                    googleIpMap[ip] = r.reputation;
                  }
                });
              }
            });
          } catch(e) {}
        }
      });

      // 3. Собираем список всех уникальных пулов для фильтра
      const allPools = new Set();

      // 4. Обогащаем инвентарь (сливаем 3 базы в одну)
      enrichedData = inventory.map(item => {
        // Собираем пулы в один массив, отбрасывая пустые
        const pools = [item.pool1, item.pool2, item.pool3, item.pool4].filter(p => p && p.trim() !== '');
        pools.forEach(p => allPools.add(p));

        // Ищем самую свежую запись SNDS для этого IP
        const sndsRecord = sndsData.find(s => s.ip === item.ip) || {};

        return {
          ip: item.ip,
          hostname: item.hostname || '—',
          pools: pools,
          snds_filter: sndsRecord.filter_result || 'UNKNOWN',
          complaints: sndsRecord.complaints || 0,
          traps: sndsRecord.traps || 0,
          jmr: sndsRecord.jmr_p1_sender || '',
          google_rep: googleIpMap[item.ip] || 'UNKNOWN',
          snds_date: sndsRecord.date || null
        };
      });

      populatePoolDropdown(Array.from(allPools).sort());
      applyFiltersAndRender();
      
      document.getElementById('ipSearch')?.addEventListener('input', applyFiltersAndRender);
      document.getElementById('poolFilter')?.addEventListener('change', (e) => {
        activePool = (e.target as HTMLSelectElement).value;
        applyFiltersAndRender();
      });

    } catch (err) {
      console.error("Data Merge Error:", err);
      document.getElementById('tableBody').innerHTML = `<tr><td colspan="7" class="center error-text" style="color:#e53e3e;">Error compiling inventory data. Check console.</td></tr>`;
    }
  }

  function populatePoolDropdown(pools) {
    const select = document.getElementById('poolFilter');
    if (!select) return;
    
    // Сохраняем опцию ALL, удаляем остальные
    select.innerHTML = '<option value="ALL">🌐 All Pools</option>';
    pools.forEach(pool => {
      select.innerHTML += `<option value="${pool}">${pool}</option>`;
    });
  }

  function applyFiltersAndRender() {
    const searchTerm = (document.getElementById('ipSearch') as HTMLInputElement)?.value.toLowerCase() || '';
    
    let filtered = enrichedData.filter(d => {
      const matchSearch = d.ip.toLowerCase().includes(searchTerm) || d.hostname.toLowerCase().includes(searchTerm);
      const matchPool = activePool === 'ALL' ? true : d.pools.includes(activePool);
      return matchSearch && matchPool;
    });

    // Сортировка
    filtered.sort((a, b) => {
      let valA = a[sortCol];
      let valB = b[sortCol];

      if (typeof valA === 'number' && typeof valB === 'number') {
        return sortAsc ? valA - valB : valB - valA;
      }
      
      // Сортировка IP адресов (улучшенная, чтобы 10.0.0.2 был перед 10.0.0.10)
      if (sortCol === 'ip') {
        const numA = ipToNumber(a.ip);
        const numB = ipToNumber(b.ip);
        return sortAsc ? numA - numB : numB - numA;
      }

      let strA = String(valA).toLowerCase();
      let strB = String(valB).toLowerCase();
      if (strA < strB) return sortAsc ? -1 : 1;
      if (strA > strB) return sortAsc ? 1 : -1;
      return 0;
    });

    currentFilteredData = filtered;
    renderSummary(filtered); 
    renderTable(filtered);    
  }

  // Вспомогательная функция для правильной сортировки IP
  function ipToNumber(ip) {
    return ip.split('.').reduce((acc, octet) => (acc << 8) + parseInt(octet, 10), 0) >>> 0;
  }

  function renderSummary(data) {
    const container = document.getElementById('inventory-summary');
    if (!container) return;
    
    const total = data.length;
    const sndsRed = data.filter(d => d.snds_filter === 'RED').length;
    const trapCount = data.filter(d => d.traps > 0).length;
    const googleBad = data.filter(d => d.google_rep === 'BAD' || d.google_rep === 'LOW').length;

    container.innerHTML = `
      <div class="stat-card info">
        <span class="stat-label">Total IPs (Filtered)</span>
        <span class="stat-value">${total}</span>
      </div>
      <div class="stat-card ${sndsRed > 0 ? 'danger' : 'success'}">
        <span class="stat-label">SNDS: Red Status</span>
        <span class="stat-value">${sndsRed}</span>
      </div>
      <div class="stat-card ${trapCount > 0 ? 'warning' : 'success'}">
        <span class="stat-label">Hitting Traps</span>
        <span class="stat-value">${trapCount}</span>
      </div>
      <div class="stat-card ${googleBad > 0 ? 'danger-light' : 'success'}">
        <span class="stat-label">Google: Bad/Low</span>
        <span class="stat-value">${googleBad}</span>
      </div>
    `;
  }

  function renderTable(data) {
    const tbody = document.getElementById('tableBody');
    if (!tbody) return;
    
    if (data.length === 0) {
      tbody.innerHTML = `<tr><td colspan="7" class="center" style="padding: 20px;">No IP addresses match your filters.</td></tr>`;
      return;
    }

    let html = '';
    data.forEach(row => {
      
      const poolBadges = row.pools.length > 0 
        ? row.pools.map(p => `<span class="pool-tag">${p}</span>`).join(' ')
        : `<span class="text-gray">—</span>`;

      // Подсветка строки, если есть серьезные проблемы
      const isCritical = row.snds_filter === 'RED' || row.google_rep === 'BAD' || row.traps > 0;

      html += `
        <tr class="domain-row ${isCritical ? 'row-alert' : ''}">
          <td class="domain-text"><strong>${row.ip}</strong></td>
          <td style="font-family: monospace; font-size: 0.85rem; color: #4a5568;">${row.hostname}</td>
          <td><div class="pools-container">${poolBadges}</div></td>
          <td class="center">${formatSNDS(row.snds_filter)}</td>
          <td class="center" style="${row.complaints > 0.3 ? 'color:#e53e3e; font-weight:bold;' : ''}">${row.complaints}%</td>
          <td class="center" style="${row.traps > 0 ? 'color:#e53e3e; font-weight:bold;' : ''}">${row.traps > 0 ? '🚨 ' + row.traps : '0'}</td>
          <td class="center">${formatGoogleRep(row.google_rep)}</td>
        </tr>
      `;
    });
    tbody.innerHTML = html;
  }

  function formatSNDS(status) {
    if (!status || status === 'UNKNOWN') return `<span class="badge badge-gray">UNKNOWN</span>`;
    let cls = 'badge-green';
    if (status === 'YELLOW') cls = 'badge-yellow';
    if (status === 'RED') cls = 'badge-red';
    return `<span class="badge ${cls}">${status}</span>`;
  }

  function formatGoogleRep(rep) {
    if (!rep || rep === 'UNKNOWN') return `<span class="badge badge-gray">UNKNOWN</span>`;
    let cls = 'badge-gray';
    if (rep === 'HIGH') cls = 'badge-green';
    if (rep === 'MEDIUM') cls = 'badge-yellow';
    if (rep === 'LOW' || rep === 'BAD') cls = 'badge-red';
    return `<span class="badge ${cls}">${rep}</span>`;
  }

  (window as any).sortBy = (col) => {
    if (sortCol === col) sortAsc = !sortAsc;
    else { sortCol = col; sortAsc = true; }
    applyFiltersAndRender();
  };

  (window as any).syncData = async (btn) => {
    const originalText = btn.innerHTML;
    btn.innerHTML = '⏳ Refreshing...';
    btn.disabled = true;
    await init();
    btn.innerHTML = originalText;
    btn.disabled = false;
  };

  (window as any).downloadCSV = () => {
    if (currentFilteredData.length === 0) {
      alert("No data available to export.");
      return;
    }
    
    const headers = ['IP Address', 'Hostname', 'Pools', 'SNDS Status', 'Complaints %', 'Traps', 'JMR Incident', 'Google Rep', 'Last SNDS Update'];
    const rows = currentFilteredData.map(d => [
      d.ip,
      d.hostname,
      `"${d.pools.join(', ')}"`, // Заворачиваем в кавычки, чтобы запятые пулов не сломали CSV
      d.snds_filter,
      d.complaints,
      d.traps,
      d.jmr,
      d.google_rep,
      d.snds_date || 'N/A'
    ]);
    
    const csvContent = [headers.join(','), ...rows.map(row => row.join(','))].join('\n');
    const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
    const url = URL.createObjectURL(blob);
    const link = document.createElement('a');
    link.setAttribute('href', url);
    link.setAttribute('download', `ip_inventory_${activePool.replace(/[^a-z0-9]/gi, '_')}_${new Date().toISOString().split('T')[0]}.csv`);
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
  };

  init();
</script>

<style is:global>
  .domains-wrapper { padding: 2rem; max-width: 1400px; margin: 0 auto; font-family: system-ui, -apple-system, sans-serif; }
  .content-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 2rem; }
  .title-area h1 { font-size: 2.25rem; font-weight: 800; color: #ffffff !important; margin: 0; }
  .title-area p { color: #a0aec0 !important; font-size: 1.1rem; margin: 0.5rem 0 0 0; }
  
  .header-actions { display: flex; gap: 15px; }
  .btn-primary { display: flex; align-items: center; gap: 8px; background: #3182ce; color: #fff; padding: 12px 24px; border-radius: 8px; font-weight: 700; border: none; cursor: pointer; transition: 0.2s; }
  .btn-primary:hover { background: #2b6cb0; }
  .btn-primary:disabled { opacity: 0.5; cursor: not-allowed; }
  
  .summary-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; margin-bottom: 2rem; }
  
  .stat-card { background: #fff !important; padding: 1.5rem; border-radius: 12px; border: 1px solid #cbd5e0; box-shadow: 0 4px 6px rgba(0,0,0,0.05); }
  .stat-card.danger { border-left: 6px solid #e53e3e !important; }
  .stat-card.danger-light { border-left: 6px solid #ed8936 !important; } 
  .stat-card.warning { border-left: 6px solid #ecc94b !important; } 
  .stat-card.success { border-left: 6px solid #48bb78 !important; }
  .stat-card.info { border-left: 6px solid #3182ce !important; }
  
  .stat-label { font-size: 0.8rem; font-weight: 800; text-transform: uppercase; color: #4a5568 !important; display: block; margin-bottom: 4px; }
  .stat-value { font-size: 2.5rem; font-weight: 900; color: #1a202c !important; line-height: 1.1; }

  .table-actions-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; gap: 15px; }
  .input-field { padding: 12px 18px; border: 2px solid #cbd5e0; border-radius: 10px; font-weight: 600; background: #fff !important; color: #000 !important; font-size: 0.95rem; }
  .search-input { width: 300px; }
  .select-custom { cursor: pointer; border-color: #a0aec0; }
  
  .btn-export { display: flex; align-items: center; gap: 8px; padding: 12px 20px; border-radius: 10px; border: none; background: #2d3748; color: #fff; font-weight: 700; font-size: 0.9rem; cursor: pointer; transition: all 0.2s; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
  .btn-export:hover { background: #4a5568; transform: translateY(-1px); }

  .table-outer-container { background: #fff !important; border-radius: 12px; border: 1px solid #cbd5e0; overflow: hidden; }
  .table-scroll { max-height: 70vh; overflow-y: auto; }
  
  table { width: 100%; border-collapse: separate; border-spacing: 0; }
  thead th { position: sticky; top: 0; background: #f7fafc !important; font-weight: 800; text-transform: uppercase; font-size: 0.75rem; padding: 16px 12px; border-bottom: 2px solid #cbd5e0; color: #1a202c !important; text-align: left; z-index: 5; }
  .sortable { cursor: pointer; user-select: none; }
  .sortable:hover { background: #edf2f7 !important; }
  
  td { padding: 14px 12px; border-bottom: 1px solid #edf2f7; font-size: 0.95rem; color: #2d3748 !important; }
  .domain-row:hover { background-color: #f8fafc !important; }
  .row-alert { background-color: #fff5f5 !important; }
  
  .center { text-align: center; }
  .domain-text strong { font-size: 1.05rem; }
  .text-gray { color: #a0aec0 !important; }

  .badge { padding: 6px 12px; border-radius: 6px; font-size: 0.75rem; font-weight: 900; }
  .badge-green { background: #c6f6d5 !important; color: #22543d !important; }
  .badge-red { background: #fed7d7 !important; color: #822727 !important; }
  .badge-yellow { background: #feebc8 !important; color: #744210 !important; }
  .badge-gray { background: #edf2f7 !important; color: #4a5568 !important; }

  .pools-container { display: flex; flex-wrap: wrap; gap: 6px; }
  .pool-tag { background: #e2e8f0; color: #2d3748; padding: 4px 8px; border-radius: 6px; font-size: 0.75rem; font-weight: 700; border: 1px solid #cbd5e0; }

/* --- TOOL NAVIGATION BAR --- */
  .tool-nav {
    display: inline-flex;
    align-items: center;
    background: #0f172a; /* Темный фон таблетки */
    padding: 6px;
    border-radius: 100px;
    margin-bottom: 2rem;
    border: 1px solid #334155;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.2);
  }
  .nav-link {
    color: #94a3b8;
    text-decoration: none;
    padding: 8px 20px;
    border-radius: 100px;
    font-weight: 700;
    font-size: 0.95rem;
    transition: all 0.2s ease;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .nav-link:hover:not(.active) {
    color: #f8fafc;
    background: rgba(255, 255, 255, 0.05);
  }
  .nav-link.active {
    background: #3b82f6; /* Синий цвет активного пункта */
    color: #ffffff;
    box-shadow: 0 2px 4px rgba(59, 130, 246, 0.3);
  }
  .nav-divider {
    width: 1px;
    height: 24px;
    background: #334155;
    margin: 0 8px;
  }
</style>